{
  "name": "zhugangban-v3",
  "version": "3.0.0",
  "description": "住港伴 — 香港身份规划 AI 伴侣 · 微信小程序",
  "private": true,
  "scripts": {
    "test": "jest --verbose --maxWorkers=4",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "jest -c tests/e2e/jest.config.js --verbose --forceExit",
    "test:e2e:smoke": "jest -c tests/e2e/jest.config.js --verbose --forceExit --testPathPattern=smoke",
    "test:e2e:docs": "jest -c tests/e2e/jest.config.js --verbose --forceExit --testPathPattern=documents",
    "test:e2e:process": "jest -c tests/e2e/jest.config.js --verbose --forceExit --testPathPattern=process",
    "test:e2e:chat": "jest -c tests/e2e/jest.config.js --verbose --forceExit --testPathPattern=ai-chat",
    "test:e2e:regression": "jest -c tests/e2e/jest.config.js --verbose --forceExit --testPathPattern=regression",
    "test:e2e:guidebooks": "jest -c tests/e2e/jest.config.js --verbose --forceExit --testPathPattern=guidebooks",
    "test:e2e:reminders": "jest -c tests/e2e/jest.config.js --verbose --forceExit --testPathPattern=reminders",
    "test:ci": "bash scripts/ci/run-e2e.sh",
    "test:ci:quick": "SKIP_UNIT=1 bash scripts/ci/run-e2e.sh smoke",
    "verify": "bash scripts/verify.sh",
    "verify:baseline": "bash scripts/verify.sh --baseline",
    "verify:diff": "bash scripts/verify.sh --diff",
    "wetest:gen": "node scripts/ci/wetest-cloud.js",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "jest": {
    "testEnvironment": "node",
    "setupFiles": [
      "<rootDir>/__tests__/jest-setup.js"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.js",
      "**/tests/jest/**/*.test.js",
      "**/tests/smoke/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "pages/**/*.js",
      "cloudfunctions/**/*.js",
      "data/**/*.js",
      "utils/**/*.js",
      "!**/node_modules/**",
      "!**/__tests__/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 0,
        "functions": 0,
        "lines": 0,
        "statements": 0
      }
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^29.0.0",
    "jest-html-reporter": "^3.10.0",
    "miniprogram-automator": "^0.12.0",
    "prettier": "^3.8.3"
  },
  "dependencies": {
    "@cloudbase/node-sdk": "^3.18.1"
  }
}
