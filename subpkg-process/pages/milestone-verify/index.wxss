.verify-desc { font-size: var(--font-sm); color: var(--color-text-secondary); display: block; margin: 8rpx 0 20rpx; }
.upload-actions { display: flex; gap: 16rpx; }
.upload-actions .btn { flex: 1; }
.verify-image { width: 100%; height: 400rpx; border-radius: var(--radius-sm); }
.verify-status { text-align: center; padding: 24rpx 0; }
.verify-icon { font-size: 48rpx; }
.verify-pass { font-size: var(--font-lg); color: var(--color-success); font-weight: 600; display: block; margin-top: 8rpx; }
.verify-fail { font-size: var(--font-md); color: var(--color-danger); display: block; margin: 8rpx 0 16rpx; }
.ocr-preview { margin-top: 16rpx; padding-top: 16rpx; border-top: 1rpx solid var(--color-border); }
.ocr-label { font-size: var(--font-xs); color: var(--color-text-muted); }
.ocr-field { font-size: var(--font-xs); display: block; margin-top: 4rpx; }
.privacy-note { font-size: var(--font-xs); color: var(--color-text-muted); }
