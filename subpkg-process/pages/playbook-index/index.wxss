/* pages/playbook/index/index.wxss */
.page {
  min-height: 100vh;
  background: var(--gray-100);
  padding-bottom: 40rpx;
}

.search-bar {
  padding: 20rpx 24rpx;
  background: var(--white);
}
.search-input-wrap {
  display: flex;
  align-items: center;
  background: var(--gray-100);
  border-radius: 32rpx;
  padding: 16rpx 24rpx;
}
.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}
.search-input {
  flex: 1;
  font-size: 28rpx;
  background: transparent;
}
.search-clear {
  font-size: 28rpx;
  color: #999;
  padding: 8rpx;
}

.category-bar {
  white-space: nowrap;
  padding: 16rpx 24rpx;
  background: var(--white);
  border-bottom: 1rpx solid #f0f0f0;
}
.category-item {
  display: inline-block;
  padding: 12rpx 24rpx;
  margin-right: 12rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #666;
  background: var(--gray-100);
}
.category-item.active {
  background: var(--color-primary);
  color: var(--white);
}

.guide-list {
  padding: 16rpx 24rpx;
}
.guide-card {
  background: var(--white);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}
.card-header {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 12rpx;
}
.domain-tag {
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  display: inline-block;
  width: fit-content;
}
.domain-tag.QMAS {
  background: #e3f2fd;
  color: #1565c0;
}
.domain-tag.TTPS {
  background: #fff3e0;
  color: #e65100;
}
.domain-tag.IANG {
  background: #e8f5e9;
  color: #2e7d32;
}
.domain-tag.ASMTP {
  background: #f3e5f5;
  color: #6a1b9a;
}
.domain-tag.LIFE {
  background: #fce4ec;
  color: #c62828;
}
.domain-tag.TAX {
  background: #e0f2f1;
  color: #00695c;
}
.domain-tag.EDUCATION {
  background: #fff8e1;
  color: #f57f17;
}
.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #202124;
  line-height: 1.4;
}
.card-summary {
  font-size: 26rpx;
  color: #5f6368;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 16rpx;
}
.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.topic-tag {
  font-size: 22rpx;
  color: var(--color-primary);
  background: var(--color-primary-light);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 8rpx;
}
.useful-btn {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 26rpx;
  color: #999;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  background: var(--gray-100);
}
.useful-btn.voted {
  color: var(--color-primary);
  background: var(--color-primary-light);
}

.load-more,
.no-more {
  text-align: center;
  padding: 32rpx;
  font-size: 26rpx;
  color: #999;
}
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
  color: #999;
}
.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}
.empty-hint {
  font-size: 24rpx;
  margin-top: 8rpx;
}
