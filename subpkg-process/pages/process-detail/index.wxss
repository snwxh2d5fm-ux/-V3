.stages-list {
  padding: 0 32rpx;
}
.stage-card {
  padding: 20rpx;
  margin: 0 0 12rpx;
}
.stage-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.stage-number {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-sm);
  font-weight: 600;
  flex-shrink: 0;
  background: var(--color-bg);
  color: var(--color-text-muted);
}
.stage-number.current {
  background: var(--color-primary);
  color: var(--color-bg-card);
}
.stage-number.completed {
  background: var(--color-success);
  color: var(--color-bg-card);
}
.stage-info {
  flex: 1;
}
.stage-name {
  font-size: var(--font-md);
  font-weight: 600;
  display: block;
}
.stage-desc {
  font-size: var(--font-xs);
  color: var(--color-text-secondary);
}
.stage-arrow {
  color: var(--color-text-muted);
  font-size: var(--font-xs);
}
.stage-detail {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--color-border);
}
.step-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 10rpx 0;
}
.step-check {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border: 2rpx solid var(--color-border);
  font-size: var(--font-xs);
  color: var(--color-text-muted);
}
.step-check.done {
  background: var(--color-success);
  border-color: var(--color-success);
  color: var(--color-bg-card);
}
.step-text {
  font-size: var(--font-sm);
}
.step-text.done {
  color: var(--color-text-muted);
  text-decoration: line-through;
}
.btn--sm {
  padding: 10rpx 24rpx;
  font-size: var(--font-sm);
}
