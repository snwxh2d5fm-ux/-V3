.page-share-records {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
  box-sizing: border-box;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #1a73e8;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  0% {
    transform: rotate(0deg);
  }
  100% {
    transform: rotate(360deg);
  }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #999;
}

/* 空状态 */
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #ccc;
}

/* 记录列表 */
.records-list {
  width: 100%;
  max-height: calc(100vh - 40rpx);
}

/* 记录卡片 */
.record-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-header {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.content-type-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
  line-height: 1.4;
}

.content-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  flex: 1;
}

.card-meta {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.meta-type {
  font-size: 24rpx;
  color: #1a73e8;
  background-color: #e8f0fe;
  padding: 2rpx 14rpx;
  border-radius: 6rpx;
  margin-right: 16rpx;
}

.meta-time {
  font-size: 24rpx;
  color: #999;
}

.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-top: 2rpx solid #f0f0f0;
  padding-top: 20rpx;
}

/* 状态徽章 */
.status-badge-wrap {
  display: flex;
  align-items: center;
}

.status-badge {
  display: flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.status-active {
  background-color: #e6f7e6;
}

.status-revoked {
  background-color: #fff0f0;
}

.status-expired {
  background-color: #f5f5f5;
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 8rpx;
}

.dot-green {
  background-color: #52c41a;
}

.dot-red {
  background-color: #ff4d4f;
}

.dot-gray {
  background-color: #bbb;
}

.status-text {
  font-size: 24rpx;
  font-weight: 500;
}

.status-active .status-text {
  color: #52c41a;
}

.status-revoked .status-text {
  color: #ff4d4f;
}

.status-expired .status-text {
  color: #999;
}

/* 撤回按钮 */
.revoke-btn {
  padding: 8rpx 20rpx;
}

.revoke-btn-text {
  font-size: 26rpx;
  color: #ff4d4f;
}
