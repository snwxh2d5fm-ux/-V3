<!-- 住港伴 V3 — 家庭空间邀请页 -->
<view class="page">

  <!-- ========== 加载状态 ========== -->
  <view class="loading-wrap" wx:if="{{loading}}">
    <view class="spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- ========== 接受邀请模式 ========== -->
  <block wx:elif="{{mode === 'accept'}}">

    <!-- 加载失败/邀请无效 -->
    <view class="empty-state" wx:if="{{acceptError && !inviteInfo}}">
      <text class="empty-icon">😞</text>
      <text class="empty-title">邀请无效</text>
      <text class="empty-desc">{{acceptError}}</text>
      <button class="btn btn-primary" bindtap="onGoHome">返回我的</button>
    </view>

    <!-- 邀请详情 -->
    <block wx:elif="{{inviteInfo}}">

      <!-- 成功视图 -->
      <view class="success-view" wx:if="{{showSuccess}}">
        <text class="success-icon">🎉</text>
        <text class="success-title">已加入家庭空间</text>
        <view class="success-card">
          <text class="success-label">空间ID</text>
          <text class="success-value" selectable="true">{{spaceId}}</text>
        </view>
        <button class="btn btn-primary" bindtap="onGoHome">返回我的</button>
      </view>

      <!-- 接受邀请确认 -->
      <view class="invite-card" wx:else>
        <view class="invite-header">
          <text class="invite-icon">🏠</text>
          <text class="invite-title">家庭空间邀请</text>
        </view>

        <view class="invite-detail">
          <view class="detail-row">
            <text class="detail-label">角色</text>
            <text class="detail-value role-tag {{inviteInfo.role}}">
              {{inviteInfo.role === 'spouse' ? '配偶' : '子女'}}
            </text>
          </view>
          <view class="detail-row" wx:if="{{inviteInfo.inviterHint}}">
            <text class="detail-label">邀请人</text>
            <text class="detail-value">{{inviteInfo.inviterHint}}</text>
          </view>
          <view class="detail-row">
            <text class="detail-label">权限范围</text>
            <view class="permission-chips">
              <text class="perm-chip" wx:for="{{inviteInfo.permissions || []}}" wx:key="*this">
                {{item === 'personal_info' ? '个人信息' : item === 'documents' ? '证件' : item === 'reminders' ? '提醒' : item === 'process' ? '流程' : item}}
              </text>
            </view>
          </view>
        </view>

        <view class="risk-notice">
          <text class="risk-notice-icon">⚠️</text>
          <text class="risk-notice-text">加入家庭空间后，你的部分数据将对家庭成员可见。请注意保护个人隐私。</text>
        </view>

        <button class="btn btn-primary" loading="{{accepting}}" disabled="{{accepting}}" bindtap="onAcceptInvite">
          {{accepting ? '加入中...' : '确认加入'}}
        </button>

        <view class="accept-error" wx:if="{{acceptError}}">
          <text>{{acceptError}}</text>
        </view>
      </view>
    </block>
  </block>

  <!-- ========== 管理模式 ========== -->
  <block wx:else>

    <!-- 空状态：尚无家庭空间 -->
    <view class="empty-state" wx:if="{{!hasSpace}}">
      <text class="empty-icon">🏠</text>
      <text class="empty-title">暂无家庭空间</text>
      <text class="empty-desc">创建家庭空间后，可邀请配偶、子女共同管理身份规划资料</text>
      <button class="btn btn-primary" bindtap="onCreateInvite">创建家庭空间</button>
    </view>

    <!-- 成员列表 -->
    <view class="space-section" wx:else>
      <view class="card">
        <view class="section-header">
          <text class="section-title">家庭成员</text>
          <text class="member-count">{{members.length}} 人</text>
        </view>

        <view class="member-list">
          <view class="member-card" wx:for="{{members}}" wx:key="userId">
            <view class="member-info">
              <text class="member-avatar">{{item.role === 'spouse' ? '👩' : '👶'}}</text>
              <view class="member-detail">
                <view class="member-top">
                  <text class="member-name">{{item.nickname || item.userId}}</text>
                  <text class="member-role role-{{item.role}}">
                    {{item.role === 'spouse' ? '配偶' : '子女'}}
                  </text>
                </view>
                <text class="member-date" wx:if="{{item.joinedAt}}">加入于 {{item.joinedAt}}</text>
                <view class="member-permissions">
                  <text class="perm-chip mini" wx:for="{{item.permissions || []}}" wx:key="*this">
                    {{item === 'personal_info' ? '个人信息' : item === 'documents' ? '证件' : item === 'reminders' ? '提醒' : item === 'process' ? '流程' : item}}
                  </text>
                </view>
              </view>
            </view>
            <view class="member-actions">
              <text class="action-btn danger" bindtap="onRemoveMember" data-user-id="{{item.userId}}">移除</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 添加家属入口 -->
      <view class="card add-card">
        <view class="add-inner" bindtap="onCreateInvite">
          <text class="add-icon">+</text>
          <view class="add-texts">
            <text class="add-title">添加家属</text>
            <text class="add-desc">邀请配偶或子女加入家庭空间</text>
          </view>
          <text class="add-arrow">›</text>
        </view>
      </view>
    </view>

    <!-- ===== 创建邀请面板 ===== -->
    <view class="card create-panel" wx:if="{{hasSpace}}">
      <text class="create-panel-title">创建新邀请</text>

      <!-- 接收方姓名 -->
      <view class="recipient-name-section">
        <text class="picker-label">接收方姓名</text>
        <input class="recipient-input" placeholder="请输入家属姓名" value="{{newRecipientName}}" bindinput="onRecipientNameInput" maxlength="20" />
      </view>

      <!-- 角色选择 -->
      <view class="role-picker">
        <text class="picker-label">角色</text>
        <view class="role-options">
          <view class="role-option {{selectedRole === 'spouse' ? 'active' : ''}}" bindtap="onRoleSelect" data-role="spouse">
            <text class="role-option-icon">👩</text>
            <text class="role-option-text">配偶</text>
          </view>
          <view class="role-option {{selectedRole === 'child' ? 'active' : ''}}" bindtap="onRoleSelect" data-role="child">
            <text class="role-option-icon">👶</text>
            <text class="role-option-text">子女</text>
          </view>
        </view>
      </view>

      <!-- 权限选择 -->
      <view class="permission-picker">
        <text class="picker-label">授权范围</text>
        <view class="permission-options">
          <view class="perm-option {{selectedPermissions.indexOf('personal_info') !== -1 ? 'active' : ''}}" bindtap="onPermissionToggle" data-permission="personal_info">
            <text class="perm-check">{{selectedPermissions.indexOf('personal_info') !== -1 ? '✓' : ''}}</text>
            <view class="perm-info">
              <text class="perm-title">个人信息</text>
              <text class="perm-desc">姓名、联系方式等基础信息</text>
            </view>
          </view>
          <view class="perm-option {{selectedPermissions.indexOf('documents') !== -1 ? 'active' : ''}}" bindtap="onPermissionToggle" data-permission="documents">
            <text class="perm-check">{{selectedPermissions.indexOf('documents') !== -1 ? '✓' : ''}}</text>
            <view class="perm-info">
              <text class="perm-title">证件</text>
              <text class="perm-desc">共享证件夹中的文件</text>
            </view>
          </view>
          <view class="perm-option {{selectedPermissions.indexOf('reminders') !== -1 ? 'active' : ''}}" bindtap="onPermissionToggle" data-permission="reminders">
            <text class="perm-check">{{selectedPermissions.indexOf('reminders') !== -1 ? '✓' : ''}}</text>
            <view class="perm-info">
              <text class="perm-title">提醒</text>
              <text class="perm-desc">共享提醒事项</text>
            </view>
          </view>
          <view class="perm-option {{selectedPermissions.indexOf('process') !== -1 ? 'active' : ''}}" bindtap="onPermissionToggle" data-permission="process">
            <text class="perm-check">{{selectedPermissions.indexOf('process') !== -1 ? '✓' : ''}}</text>
            <view class="perm-info">
              <text class="perm-title">流程</text>
              <text class="perm-desc">共享流程进度</text>
            </view>
          </view>
        </view>
      </view>

      <button class="btn btn-primary" bindtap="onCreateInvite" loading="{{creating}}" disabled="{{creating}}">
        {{creating ? '生成中...' : '生成邀请码'}}
      </button>
    </view>

    <!-- ===== 邀请码展示 ===== -->
    <view class="invite-code-card card" wx:if="{{newInviteCode}}">
      <text class="invite-code-title">✅ 邀请已生成</text>
      <view class="invite-code-box">
        <text class="invite-code" selectable="true">{{newInviteCode}}</text>
      </view>
      <text class="invite-code-expiry" wx:if="{{newInviteExpiresAt}}">
        有效期至：{{newInviteExpiresAt}}
      </text>
      <view class="invite-code-actions">
        <button class="btn btn-outline action" bindtap="onCopyInviteCode">📋 复制邀请码</button>
        <button class="btn btn-primary action share-btn" open-type="share">💬 分享到微信</button>
      </view>
    </view>

    <!-- ===== 接收邀请入口（手动输入邀请码） ===== -->
    <view class="card accept-entry" wx:if="{{hasSpace || !hasSpace}}">
      <text class="accept-entry-title">🔑 接收家庭邀请</text>
      <text class="accept-entry-desc">如果你收到了家人的邀请码，在此输入即可加入</text>
      <view class="accept-entry-row">
        <input class="accept-input" placeholder="粘贴邀请码" value="{{acceptInputCode}}" bindinput="onAcceptInputCode" maxlength="32" />
        <button class="btn btn-primary accept-btn" bindtap="onGoAccept" disabled="{{!acceptInputCode}}">进入 ›</button>
      </view>
    </view>
  </block>

  <!-- ========== 风险提示弹窗 ========== -->
  <view class="overlay" wx:if="{{showRiskDialog}}" bindtap="onRiskCancelled">
    <view class="risk-modal" catchtap="">
      <text class="risk-modal-icon">⚠️</text>
      <text class="risk-modal-title">授权风险提示</text>
      <view class="risk-modal-body">
        <text class="risk-modal-text">
          你将授权"{{selectedRole === 'spouse' ? '配偶' : '子女'}}"访问以下数据：
        </text>
        <view class="risk-modal-permissions">
          <text class="risk-modal-perm" wx:for="{{selectedPermissions}}" wx:key="*this">
            · {{item === 'personal_info' ? '个人信息' : item === 'documents' ? '证件' : item === 'reminders' ? '提醒' : item === 'process' ? '流程' : item}}
          </text>
        </view>
        <text class="risk-modal-warning">
          请注意：授权后家庭成员将可查看上述数据。你可以随时在家庭空间管理中调整权限或移除成员。
        </text>
      </view>
      <view class="risk-modal-actions">
        <button class="btn btn-ghost" bindtap="onRiskCancelled">取消</button>
        <button class="btn btn-primary" bindtap="onRiskConfirmed" data-role="{{selectedRole}}">确认授权</button>
      </view>
    </view>
  </view>

  <view class="safe-bottom"></view>
</view>
