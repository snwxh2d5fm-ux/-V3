.page-share-preview {
  min-height: 100vh;
  background-color: #f5f5f5;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx;
  box-sizing: border-box;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #1a73e8;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #999;
}

/* 内容区域 */
.content-area {
  width: 100%;
  max-width: 600rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 标题区 */
.section-header {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.content-type-badge {
  font-size: 22rpx;
  color: #1a73e8;
  background-color: #e8f0fe;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

/* 卡片预览 */
.card-preview-area {
  width: 100%;
  margin-bottom: 40rpx;
}

/* 文本预览兜底 */
.text-preview-area {
  width: 100%;
  margin-bottom: 40rpx;
}

.preview-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.preview-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.5;
  margin-bottom: 20rpx;
}

.preview-digest {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 30rpx;
}

.preview-footer {
  border-top: 2rpx solid #f0f0f0;
  padding-top: 20rpx;
}

.preview-brand {
  font-size: 24rpx;
  color: #999;
}

/* 操作按钮 */
.action-area {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.btn {
  width: 100%;
  height: 88rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 28rpx;
  padding: 0;
  margin: 0;
  line-height: 88rpx;
  border: none;
  outline: none;
}

.btn::after {
  border: none;
}

.btn-primary {
  background-color: #1a73e8;
  color: #ffffff;
}

.btn-primary:active {
  background-color: #1557b0;
}

.btn-outline {
  background-color: #ffffff;
  color: #333;
  border: 2rpx solid #ddd;
}

.btn-outline:active {
  background-color: #f5f5f5;
}

.btn-icon {
  font-size: 32rpx;
}

.btn-text {
  font-size: 28rpx;
}

/* 免责声明 */
.disclaimer-area {
  width: 100%;
  text-align: center;
  padding: 20rpx 0;
}

.disclaimer-text {
  font-size: 22rpx;
  color: #bbb;
}
