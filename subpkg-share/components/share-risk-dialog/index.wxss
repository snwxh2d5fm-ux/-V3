.risk-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: var(--z-modal, 800);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity var(--duration, 0.25s) var(--easing, cubic-bezier(0.4, 0, 0.2, 1));
}

.risk-overlay--visible {
  opacity: 1;
  pointer-events: auto;
}

.risk-dialog {
  width: 600rpx;
  background-color: var(--color-bg-card, #ffffff);
  border-radius: var(--radius, 16rpx);
  padding: 48rpx 40rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: var(--shadow-lg, 0 8rpx 32rpx rgba(0, 0, 0, 0.12));
}

.risk-dialog__icon {
  font-size: 64rpx;
  line-height: 1;
  margin-bottom: var(--space-lg, 24rpx);
}

.risk-dialog__title {
  font-size: var(--font-lg, 32rpx);
  font-weight: 600;
  color: var(--color-text-primary, #111827);
  margin-bottom: var(--space-lg, 24rpx);
}

.risk-dialog__desc {
  font-size: var(--font-md, 28rpx);
  color: var(--color-text-secondary, #5f6368);
  line-height: 1.6;
  text-align: left;
  margin-bottom: var(--space-xl, 32rpx);
}

.risk-dialog__checkbox {
  display: flex;
  align-items: center;
  align-self: flex-start;
  padding: var(--space-sm, 12rpx) 0;
  margin-bottom: var(--space-xl, 32rpx);
}

.risk-dialog__checkbox-box {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid var(--gray-300, #d1d5db);
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--space-sm, 12rpx);
  flex-shrink: 0;
}

.risk-dialog__checkbox-box--checked {
  background-color: #1a73e8;
  border-color: #1a73e8;
}

.risk-dialog__checkbox-icon {
  color: #ffffff;
  font-size: 24rpx;
  font-weight: bold;
}

.risk-dialog__checkbox-label {
  font-size: var(--font-md, 28rpx);
  color: var(--color-text-primary, #111827);
}

.risk-dialog__actions {
  display: flex;
  width: 100%;
  gap: var(--space-lg, 24rpx);
}

.risk-dialog__btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: var(--font-md, 28rpx);
  border-radius: var(--radius-pill, 20rpx);
  border: none;
  padding: 0;
}

.risk-dialog__btn::after {
  border: none;
}

.risk-dialog__btn--cancel {
  background-color: var(--gray-100, #f3f4f6);
  color: var(--color-text-secondary, #5f6368);
}

.risk-dialog__btn--confirm {
  background-color: #1a73e8;
  color: #ffffff;
}

.risk-dialog__btn--disabled {
  background-color: var(--gray-200, #e5e7eb);
  color: var(--gray-400, #757f8c);
}
