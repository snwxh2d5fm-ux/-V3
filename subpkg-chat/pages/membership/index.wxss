/* pages/membership/index — 会员方案页样式 */

page {
  background: var(--gray-100);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', sans-serif;
}

.page {
  padding-bottom: 60rpx;
}

/* ========== 加载态 ========== */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}
.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: var(--gray-400);
}

/* ========== 状态栏 ========== */
.status-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 24rpx 32rpx;
  padding: 28rpx 32rpx;
  background: var(--white);
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}
.status-label {
  font-size: 24rpx;
  color: var(--gray-400);
  display: block;
  margin-bottom: 4rpx;
}
.status-level {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--gray-700);
}
.status-level.free {
  color: var(--gray-400);
}
.status-level.basic {
  color: var(--color-success);
}
.status-level.pro {
  color: var(--color-info);
}
.status-level.premium {
  color: #7c3aed;
}
.lock-badge {
  font-size: 24rpx;
  color: var(--color-error);
  padding: 8rpx 16rpx;
  background: var(--color-error-bg);
  border-radius: 8rpx;
}

/* ========== 快捷入口 ========== */
.quick-entries {
  display: flex;
  margin: 0 32rpx 24rpx;
  gap: 16rpx;
}

.quick-entry {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  background: var(--white);
  border-radius: 14rpx;
  padding: 24rpx 0;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.entry-icon {
  font-size: 36rpx;
}
.entry-text {
  font-size: 28rpx;
  color: var(--gray-700);
  font-weight: 500;
}

/* ========== 周期切换 ========== */
.period-switch {
  display: flex;
  margin: 0 32rpx 24rpx;
  background: var(--gray-200);
  border-radius: 12rpx;
  padding: 6rpx;
}
.period-option {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: var(--gray-500);
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}
.period-option.active {
  background: var(--white);
  color: var(--color-primary);
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}
.save-tag {
  font-size: 20rpx;
  color: var(--white);
  background: var(--color-error);
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
}

/* ========== 方案卡片 ========== */
.plans-grid {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 0 32rpx;
}

.plan-card {
  position: relative;
  background: var(--white);
  border-radius: 20rpx;
  padding: 36rpx 32rpx;
  border: 2rpx solid var(--gray-200);
  transition: all 0.2s;
}
.plan-card.highlighted {
  border-color: var(--color-primary);
  box-shadow: 0 4rpx 24rpx rgba(26, 115, 232, 0.12);
  background: linear-gradient(135deg, var(--color-info-bg) 0%, var(--white) 40%);
}
.plan-card.current {
  opacity: 0.7;
}

/* 标签 */
.plan-badge {
  position: absolute;
  top: 0;
  right: 32rpx;
  background: linear-gradient(135deg, var(--color-primary), var(--color-info));
  color: var(--white);
  font-size: 22rpx;
  padding: 6rpx 20rpx;
  border-radius: 0 0 12rpx 12rpx;
  font-weight: 600;
}

/* 方案头部 */
.plan-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}
.plan-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a2e;
}
.plan-level-tag {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
  font-weight: 600;
}
.plan-level-tag.basic {
  background: var(--color-success-bg);
  color: var(--color-success);
}
.plan-level-tag.pro {
  background: var(--color-info-bg);
  color: var(--color-info);
}
.plan-level-tag.premium {
  background: #f5f3ff;
  color: #7c3aed;
}

/* 价格 */
.plan-price {
  display: flex;
  align-items: baseline;
  margin-bottom: 8rpx;
}
.price-symbol {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a2e;
}
.price-value {
  font-size: 60rpx;
  font-weight: 800;
  color: #1a1a2e;
  line-height: 1;
}
.price-unit {
  font-size: 26rpx;
  color: var(--gray-400);
  margin-left: 6rpx;
}
.plan-price-compare {
  font-size: 24rpx;
  color: var(--gray-400);
  margin-bottom: 20rpx;
}

/* 权益列表 */
.plan-features {
  border-top: 1rpx solid #f0f0f0;
  padding-top: 24rpx;
  margin-bottom: 28rpx;
}
.feature-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 8rpx 0;
}
.feature-check {
  font-size: 22rpx;
  color: var(--color-success);
  font-weight: 700;
  width: 28rpx;
  text-align: center;
}
.feature-text {
  font-size: 26rpx;
  color: #555;
}

/* 订阅按钮 */
.subscribe-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 12rpx;
  text-align: center;
  border: none;
  /* Kill WeChat native button styles */
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: visible;
}
.subscribe-btn::after {
  border: none;
}
.subscribe-btn.primary {
  background: linear-gradient(135deg, var(--color-primary), var(--color-info));
  color: var(--white);
}
.subscribe-btn.outline {
  background: var(--white);
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
}
.subscribe-btn.current-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 12rpx;
  text-align: center;
  background: var(--gray-100);
  color: var(--gray-400);
}

/* ========== 支付结果弹窗 ========== */
.result-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}
.result-modal {
  background: var(--white);
  border-radius: 24rpx;
  padding: 60rpx 48rpx;
  width: 560rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}
.result-icon {
  font-size: 80rpx;
}
.result-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a2e;
}
.result-msg {
  font-size: 28rpx;
  color: var(--gray-500);
  margin-bottom: 16rpx;
}
.result-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 12rpx;
  background: linear-gradient(135deg, var(--color-primary), var(--color-info));
  color: var(--white);
  border: none;
  text-align: center;
}
.result-btn::after {
  border: none;
}
