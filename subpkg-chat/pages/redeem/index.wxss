/* subpkg-chat/pages/redeem/index.wxss */

.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 32rpx;
  box-sizing: border-box;
}

/* ===== 兑换卡片 ===== */
.redeem-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
}

.card-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.card-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 12rpx;
}

.card-desc {
  display: block;
  font-size: 26rpx;
  color: #999;
}

/* ===== 输入组 ===== */
.input-group {
  margin-bottom: 32rpx;
}

.code-input {
  width: 100%;
  height: 96rpx;
  background: #f7f8fa;
  border: 2rpx solid #e5e5e5;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 36rpx;
  font-family: monospace;
  letter-spacing: 4rpx;
  text-align: center;
  color: #1a1a1a;
  box-sizing: border-box;
}

.code-input:focus {
  border-color: #1a73e8;
  background: #fff;
}

.input-placeholder {
  font-size: 28rpx;
  letter-spacing: 2rpx;
  color: #bbb;
}

.format-hint {
  display: block;
  font-size: 22rpx;
  color: #ff4d4f;
  margin-top: 12rpx;
  text-align: center;
}

/* ===== 预览框 ===== */
.preview-box {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
  background: #f0f9ff;
  border-radius: 12rpx;
  margin-bottom: 32rpx;
}

.preview-box.warning {
  background: #fff7e6;
}

.preview-icon {
  font-size: 36rpx;
  flex-shrink: 0;
}

.preview-text {
  font-size: 26rpx;
  color: #333;
  line-height: 1.5;
}

/* ===== 按钮组 ===== */
.btn-group {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  padding: 0;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: #1a73e8;
  color: #fff;
}

.btn-primary[disabled] {
  background: #a0c4f0;
  color: #fff;
}

.btn-outline {
  background: #fff;
  color: #1a73e8;
  border: 2rpx solid #1a73e8;
}

.btn-outline[disabled] {
  border-color: #ccc;
  color: #ccc;
}

.btn-ghost {
  background: transparent;
  color: #666;
  font-weight: 400;
  font-size: 26rpx;
  height: 64rpx;
  line-height: 64rpx;
}

.btn-sm {
  width: auto;
  padding: 0 32rpx;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 26rpx;
}

/* ===== 挽留区 ===== */
.retain-box {
  margin-top: 32rpx;
  padding-top: 32rpx;
  border-top: 1rpx solid #eee;
  text-align: center;
}

.retain-text {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.retain-actions {
  display: flex;
  gap: 16rpx;
  justify-content: center;
}

/* ===== 成功卡片 ===== */
.success-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 64rpx 32rpx 48rpx;
  text-align: center;
}

.success-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.success-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 40rpx;
}

.success-info {
  background: #f7f8fa;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 40rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}

.info-row:first-child {
  border-bottom: 1rpx solid #e5e5e5;
  padding-bottom: 20rpx;
  margin-bottom: 8rpx;
}

.info-label {
  font-size: 28rpx;
  color: #666;
}

.info-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
}

/* ===== 反馈区 ===== */
.feedback-box {
  margin-bottom: 32rpx;
  text-align: left;
}

.feedback-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.feedback-input {
  width: 100%;
  height: 120rpx;
  background: #f7f8fa;
  border-radius: 12rpx;
  padding: 16rpx;
  font-size: 26rpx;
  color: #333;
  box-sizing: border-box;
  margin-bottom: 16rpx;
}
