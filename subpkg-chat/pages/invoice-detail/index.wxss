/* 发票详情样式 */

page {
  background: #f5f7fa;
}
.page {
  padding-bottom: 60rpx;
}

.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 200rpx 0;
}
.loading-text {
  font-size: 28rpx;
  color: var(--gray-400);
}

.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 40rpx;
}
.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}
.empty-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 40rpx;
}

/* 状态头 */
.status-header {
  margin: 24rpx 32rpx;
  padding: 36rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.status-header.status-pending {
  background: linear-gradient(135deg, var(--color-warning-bg), #fde68a);
}
.status-header.status-issued {
  background: linear-gradient(135deg, #d1fae5, #a7f3d0);
}
.status-header.status-rejected {
  background: linear-gradient(135deg, #fee2e2, #fecaca);
}

.status-icon {
  font-size: 44rpx;
}
.status-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
}

/* 信息段 */
.section {
  margin: 0 32rpx 16rpx;
  background: var(--white);
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 0;
}

.label {
  font-size: 26rpx;
  color: var(--gray-400);
}
.value {
  font-size: 26rpx;
  color: #333;
  text-align: right;
}
.value.bold {
  font-weight: 600;
}
.value.price {
  font-weight: 700;
  color: var(--color-error);
  font-size: 32rpx;
}
.value.issued {
  color: var(--color-success);
  font-weight: 500;
}
.value.mono {
  font-family: monospace;
  word-break: break-all;
}
.value.small {
  font-size: 22rpx;
  color: #666;
}

/* 提示 */
.hint {
  margin: 24rpx 32rpx;
  padding: 20rpx 28rpx;
  background: var(--color-info-bg);
  border-radius: 12rpx;
  font-size: 24rpx;
  color: var(--color-info);
  line-height: 1.6;
}

.btn-ghost {
  width: calc(100% - 64rpx);
  margin: 16rpx 32rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: var(--white);
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
  border-radius: 14rpx;
  font-size: 28rpx;
  text-align: center;
}

.btn-ghost::after {
  border: none;
}

.safe-bottom {
  height: 40rpx;
}
