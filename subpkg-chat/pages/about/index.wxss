/* 关于住港伴 — 产品介绍 + 法律声明 */
.page {
  min-height: 100vh;
  background: var(--gray-100);
  padding-bottom: 60rpx;
}

/* 品牌标识区 */
.brand-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0 60rpx;
  background: linear-gradient(135deg, #1a73e8 0%, #1557b0 100%);
  margin-bottom: 0;
}
.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.logo-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}
.app-name {
  font-size: 48rpx;
  font-weight: 800;
  color: #ffffff;
  letter-spacing: 4rpx;
}
.app-version {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 4rpx;
}
.app-tagline {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 20rpx;
  font-weight: 500;
}
.app-motto {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.65);
  margin-top: 8rpx;
  letter-spacing: 8rpx;
}

/* 通用卡片 */
.card {
  margin: 24rpx;
  background: var(--white);
  border-radius: 20rpx;
  padding: 28rpx;
}
.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #202124;
  display: block;
  margin-bottom: 16rpx;
}
.card-text {
  font-size: 26rpx;
  color: #5f6368;
  line-height: 1.7;
  display: block;
  margin-bottom: 12rpx;
}
.card-text:last-child {
  margin-bottom: 0;
}

/* 功能列表 */
.feature-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.feature-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}
.feature-icon {
  font-size: 36rpx;
  width: 48rpx;
  text-align: center;
  flex-shrink: 0;
}
.feature-body {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.feature-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #202124;
}
.feature-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
  line-height: 1.5;
}

/* 法律声明卡片 */
.legal-card {
  border-left: 6rpx solid #1a73e8;
}
.legal-section {
  margin-bottom: 24rpx;
}
.legal-section:last-child {
  margin-bottom: 0;
}
.legal-heading {
  font-size: 26rpx;
  font-weight: 700;
  color: #1a73e8;
  margin-bottom: 8rpx;
  display: block;
}
.legal-section .card-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.75;
}

/* 法律文档入口 */
.doc-link {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--gray-100);
}
.doc-link:last-child {
  border-bottom: none;
}
.doc-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}
.doc-name {
  flex: 1;
  font-size: 28rpx;
  color: #202124;
}
.doc-arrow {
  font-size: 32rpx;
  color: #ccc;
}

/* 联系方式 */
.contact-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid var(--gray-100);
}
.contact-row:last-child {
  border-bottom: none;
}
.contact-label {
  font-size: 26rpx;
  color: #5f6368;
}
.contact-value {
  font-size: 26rpx;
  color: #202124;
}

/* 版本信息 */
.version-card {
  opacity: 0.85;
}
.version-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 0;
}
.version-label {
  font-size: 24rpx;
  color: #999;
}
.version-value {
  font-size: 24rpx;
  color: #666;
  font-family: monospace;
}

/* 版权信息 */
.copyright {
  text-align: center;
  padding: 32rpx 40rpx;
}
.copyright text {
  display: block;
  font-size: 22rpx;
  color: #bbb;
  line-height: 1.8;
}
.icp-text {
  margin-top: 8rpx;
}

.safe-bottom {
  height: 40rpx;
}
