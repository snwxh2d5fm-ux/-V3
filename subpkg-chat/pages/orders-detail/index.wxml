<!-- 订单详情 -->
<view class="page">

  <view class="loading-wrap" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
  </view>

  <view class="empty-wrap" wx:elif="{{notFound}}">
    <text class="empty-icon">🔍</text>
    <text class="empty-text">订单不存在</text>
    <button class="btn-ghost" bindtap="goBack">返回</button>
  </view>

  <view class="detail-card" wx:else>
    <!-- 顶部状态 -->
    <view class="detail-header">
      <text class="header-icon">{{order.status === 'completed' ? '✅' : order.status === 'pending' ? '⏳' : order.status === 'failed' ? '❌' : '📋'}}</text>
      <view>
        <text class="header-title">{{order.productName}}</text>
        <text class="header-status {{order.status}}">{{order.statusLabel}}</text>
      </view>
    </view>

    <!-- 金额 -->
    <view class="amount-block">
      <text class="amount-value">¥{{order.amountYuan}}</text>
      <text class="amount-label">支付金额</text>
    </view>

    <!-- 订单信息 -->
    <view class="info-section">
      <view class="info-title">订单信息</view>
      <view class="info-row">
        <text class="info-label">订单编号</text>
        <text class="info-value mono">{{order.orderId}}</text>
      </view>
      <view class="info-row" wx:if="{{order.subscriptionActivated}}">
        <text class="info-label">会员状态</text>
        <text class="info-value success">已激活 ✓</text>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="actions">
      <button
        wx:if="{{canInvoice && !hasInvoice}}"
        class="btn-primary"
        bindtap="applyInvoice"
      >
        📄 申请发票
      </button>

      <view wx:if="{{hasInvoice}}" class="invoice-done">
        <text>📄 已申请发票</text>
        <text class="invoice-status-tag {{invoiceStatus}}">
          {{invoiceStatus === 'issued' ? '已开具' : '处理中'}}
        </text>
      </view>

      <button class="btn-ghost" bindtap="goBack">返回订单列表</button>
    </view>
  </view>

  <floating-ai visible="{{true}}" />
</view>
