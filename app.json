  "window": {
    "navigationBarBackgroundColor": "#1a73e8",
    "navigationBarTitleText": "住港伴",
    "navigationBarTextStyle": "white",
    "backgroundColor": "#f5f5f5",
    "backgroundTextStyle": "dark"
  },
  "tabBar": {
    "color": "#999999",
    "selectedColor": "#1a73e8",
    "backgroundColor": "#ffffff",
    "borderStyle": "white",
    "list": [
      {
        "pagePath": "pages/guidebooks/index/index",
        "text": "攻略书",
        "iconPath": "images/tab-guide.png",
        "selectedIconPath": "images/tab-guide-active.png"
      },
      {
        "pagePath": "pages/documents/index/index",
        "text": "证件夹",
        "iconPath": "images/tab-docs.png",
        "selectedIconPath": "images/tab-docs-active.png"
      },
      {
        "pagePath": "pages/reminders/index/index",
        "text": "提醒器",
        "iconPath": "images/tab-reminder.png",
        "selectedIconPath": "images/tab-reminder-active.png"
      },
      {
        "pagePath": "pages/process/index/index",
        "text": "流程控",
        "iconPath": "images/tab-process.png",
        "selectedIconPath": "images/tab-process-active.png"
      },
      {
        "pagePath": "pages/mine/index/index",
        "text": "我的",
        "iconPath": "images/tab-mine.png",
        "selectedIconPath": "images/tab-mine-active.png"
      }
    ]
  },
  "permission": {
    "scope.userLocation": {
      "desc": "用于显示附近入境处办事处位置"
    }
  },
  "usingComponents": {
    "privacy-toggle": "/components/privacy-toggle/privacy-toggle",
    "timeline": "/components/timeline/timeline",
    "progress-bar": "/components/progress-bar/progress-bar",
    "checklist": "/components/checklist/checklist",
    "milestone-lock": "/components/milestone-lock/milestone-lock",
    "floating-ai": "/components/floating-ai/floating-ai",
    "stage-indicator": "/components/stage-indicator/stage-indicator",
    "status-badge": "/components/status-badge/status-badge"
  },
  "sitemapLocation": "sitemap.json",
  "style": "v2",
  "lazyCodeLoading": "requiredComponents"
}
