  "preloadRule": {
    "pages/guidebooks/index/index": {
      "network": "wifi",
      "packages": ["guide"]
    },
    "pages/documents/index/index": {
      "network": "wifi",
      "packages": ["docs"]
    },
    "pages/process/index/index": {
      "network": "wifi",
      "packages": ["process"]
    }
