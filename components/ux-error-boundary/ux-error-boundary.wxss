/* ux-error-boundary 错误边界样式 */
.err-boundary {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 400rpx;
  padding: 60rpx 40rpx;
}
.err-boundary__inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  max-width: 500rpx;
}
.err-boundary__icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.8;
}
.err-boundary__title {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 12rpx;
}
.err-boundary__desc {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  line-height: 1.6;
  margin-bottom: 28rpx;
}
.err-boundary__actions {
  display: flex;
  gap: 16rpx;
}
