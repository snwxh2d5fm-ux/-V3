.stage-indicator {
  background: var(--white);
  padding: 12rpx 16rpx 8rpx;
  border-bottom: 1rpx solid var(--gray-200);
}

.stage-track {
  width: 100%;
}

.stage-nodes {
  display: flex;
  align-items: flex-start;
  padding: 4rpx 8rpx;
}

.stage-node {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  width: 88rpx;
}

.stage-dot {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.stage-dot.done {
  background: var(--color-success);
  color: var(--white);
}

.stage-dot.active {
  background: var(--color-primary);
  color: var(--white);
  box-shadow: 0 0 0 6rpx rgba(26, 115, 232, 0.15);
}

.stage-dot.pending {
  background: var(--gray-200);
  color: var(--gray-500);
}

.stage-dot.locked {
  background: var(--gray-100);
  color: var(--gray-400);
}

.stage-label {
  font-size: 18rpx;
  margin-top: 4rpx;
  text-align: center;
  max-width: 88rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.stage-label.done {
  color: var(--color-success);
}
.stage-label.active {
  color: var(--color-primary);
  font-weight: 600;
}
.stage-label.pending {
  color: var(--gray-500);
}
.stage-label.locked {
  color: var(--gray-400);
}

.stage-connector {
  width: 20rpx;
  height: 2rpx;
  margin-top: 20rpx;
  flex-shrink: 0;
}

.stage-connector.done {
  background: var(--color-success);
}
.stage-connector.active {
  background: linear-gradient(90deg, var(--color-primary), var(--gray-200));
}
.stage-connector.pending {
  background: var(--gray-200);
}
.stage-connector.locked {
  background: var(--gray-100);
}

.stage-progress-bar {
  height: 4rpx;
  background: var(--gray-200);
  border-radius: 2rpx;
  margin: 8rpx 8rpx 0;
  overflow: hidden;
}

.stage-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--color-primary), #4a9af5);
  border-radius: 2rpx;
  transition: width 0.4s ease;
}
