    20|/* ── card ── */
    21|.sk-card {
    22|  background: var(--color-bg-card);
    23|  border-radius: var(--radius);
    24|  margin: 12rpx 0;
    25|  padding: 28rpx;
    26|  box-shadow: var(--shadow-sm);
    27|  display: flex;
    28|  gap: 20rpx;
    29|}
    30|.sk-card__img {
    31|  width: 100rpx;
    32|  height: 100rpx;
    33|  border-radius: var(--radius-sm);
    34|  flex-shrink: 0;
    35|}
    36|.*** { flex: 1; display: flex; flex-direction: column; gap: 12rpx; }
    37|.*** { height: 32rpx; width: 70%; }
    38|.*** { height: 22rpx; width: 100%; }
    39|.sk-car...hort { width: 55%; }
    40|
    41|/* ── list ── */
    42|.sk-list {
    43|  background: var(--color-bg-card);
    44|  padding: 22rpx 28rpx;
    45|  display: flex;
    46|  align-items: center;
    47|  gap: 20rpx;
    48|  border-bottom: 1rpx solid var(--gray-100);
    49|}
    50|.*** {
    51|  width: 64rpx;
    52|  height: 64rpx;
    53|  border-radius: 50%;
    54|  flex-shrink: 0;
    55|}
    56|.*** { flex: 1; display: flex; flex-direction: column; gap: 10rpx; }
    57|.*** { height: 28rpx; width: 60%; }
    58|.sk-list__sub { height: 22rpx; width: 40%; }
    59|
    60|/* ── grid ── */
    61|.sk-grid {
    62|  display: grid;
    63|  grid-template-columns: 1fr 1fr;
    64|  gap: 16rpx;
    65|  margin: 12rpx 0;
    66|}
    67|.*** {
    68|  background: var(--color-bg-card);
    69|  border-radius: var(--radius);
    70|  padding: 28rpx;
    71|  display: flex;
    72|  flex-direction: column;
    73|  align-items: center;
    74|  gap: 14rpx;
    75|  box-shadow: var(--shadow-sm);
    76|}
    77|.*** { width: 68rpx; height: 68rpx; border-radius: 16rpx; }
    78|.*** { width: 70%; height: 24rpx; }
    79|
    80|/* ── text ── */
    81|.sk-text {
    82|  display: flex;
    83|  flex-direction: column;
    84|  gap: 14rpx;
    85|  padding: 24rpx 0;
    86|}
    87|.*** { height: 22rpx; width: 100%; }
    88|.sk-tex...-w80 { width: 80%; }
