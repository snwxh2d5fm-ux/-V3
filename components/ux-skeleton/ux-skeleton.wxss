/* ux-skeleton 骨架屏样式 */
.skeleton-container {
  padding: 0 24rpx;
}

/* shimmer 底色 */
.sk-shimmer {
  background: linear-gradient(90deg, #E8EBF0 25%, #F0F2F5 50%, #E8EBF0 75%);
  background-size: 200% 100%;
  border-radius: 6rpx;
}
.sk-animated .sk-shimmer {
  animation: skShimmer 1.5s infinite;
}
@keyframes skShimmer {
  0%   { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* ── card ── */
.sk-card {
  background: var(--white);
  border-radius: var(--radius);
  margin: 12rpx 0;
  padding: 28rpx;
  box-shadow: var(--shadow-sm);
  display: flex;
  gap: 20rpx;
}
.sk-card__img {
  width: 100rpx;
  height: 100rpx;
  border-radius: var(--radius-sm);
  flex-shrink: 0;
}
.sk-card__body { flex: 1; display: flex; flex-direction: column; gap: 12rpx; }
.sk-card__title { height: 32rpx; width: 70%; }
.sk-card__line { height: 22rpx; width: 100%; }
.sk-card__line--short { width: 55%; }

/* ── list ── */
.sk-list {
  background: var(--white);
  padding: 22rpx 28rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  border-bottom: 1rpx solid var(--gray-100);
}
.sk-list__avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  flex-shrink: 0;
}
.sk-list__body { flex: 1; display: flex; flex-direction: column; gap: 10rpx; }
.sk-list__title { height: 28rpx; width: 60%; }
.sk-list__sub { height: 22rpx; width: 40%; }

/* ── grid ── */
.sk-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin: 12rpx 0;
}
.sk-grid__item {
  background: var(--white);
  border-radius: var(--radius);
  padding: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
  box-shadow: var(--shadow-sm);
}
.sk-grid__icon { width: 68rpx; height: 68rpx; border-radius: 16rpx; }
.sk-grid__title { width: 70%; height: 24rpx; }

/* ── text ── */
.sk-text {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  padding: 24rpx 0;
}
.sk-text__line { height: 22rpx; width: 100%; }
.sk-text__line--w80 { width: 80%; }
