     1|/* ux-skeleton 骨架屏样式 */
     2|.skeleton-container {
     3|  padding: 0 24rpx;
     4|}
     5|
     6|/* shimmer 底色 */
     7|.sk-shimmer {
     8|  background: linear-gradient(90deg, #E8EBF0 25%, #F0F2F5 50%, #E8EBF0 75%);
     9|  background-size: 200% 100%;
    10|  border-radius: 6rpx;
    11|}
    12|.sk-animated .sk-shimmer {
    13|  animation: skShimmer 1.5s infinite;
    14|}
    15|@keyframes skShimmer {
    16|  0%   { background-position: 200% 0; }
    17|  100% { background-position: -200% 0; }
    18|}
