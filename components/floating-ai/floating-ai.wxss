   167|.typing-dots .dot:nth-child(3) { animation-delay: 0.4s; }
   168|@keyframes typingBounce {
   169|  0%, 60%, 100% { transform: translateY(0); }
   170|  30% { transform: translateY(-10rpx); }
   171|}
   172|
