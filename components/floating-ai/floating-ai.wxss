     1|/* 住港伴 v5 — 悬浮AI组件样式 (DSG-3 令牌穿透 ✅ UI马良) */
     2|
     3|/* ===== 悬浮按钮 ===== */
     4|.float-btn {
     5|  position: fixed;
     6|  bottom: 200rpx;
     7|  right: 32rpx;
     8|  z-index: 900;
     9|  width: 104rpx;
    10|  height: 104rpx;
    11|  border-radius: 50%;
    12|  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
    13|  display: flex;
    14|  align-items: center;
    15|  justify-content: center;
    16|  box-shadow: 0 8rpx 28rpx rgba(26,115,232,0.4);
    17|  transition: all 0.2s ease;
    18|}
    19|.float-btn:active { transform: scale(0.9); }
    20|.float-btn.hidden { transform: scale(0); opacity: 0; pointer-events: none; }
    21|
    22|.float-btn-icon { font-size: 48rpx; }
    23|.float-btn-img { width: 72rpx; height: 72rpx; border-radius: 50%; }
    24|.float-btn-dot {
    25|  position: absolute;
    26|  top: 12rpx;
    27|  right: 12rpx;
    28|  width: 16rpx;
    29|  height: 16rpx;
    30|  border-radius: 50%;
    31|  background: var(--color-success);
    32|  border: 3rpx solid var(--color-bg-card);
    33|}
    34|
    35|/* ===== AI 对话面板 ===== */
    36|.ai-panel {
    37|  position: fixed;
    38|  bottom: 0;
    39|  left: 0;
    40|  right: 0;
    41|  height: 80vh;
    42|  background: var(--color-bg-card);
    43|  border-radius: 32rpx 32rpx 0 0;
    44|  z-index: 950;
    45|  display: flex;
    46|  flex-direction: column;
    47|  transform: translateY(100%);
    48|  transition: transform 0.3s ease;
    49|  box-shadow: 0 -8rpx 40rpx rgba(0,0,0,0.15);
    50|}
    51|.ai-panel.open { transform: translateY(0); }
    52|
    53|/* 面板头部 */
    54|.panel-header {
    55|  display: flex;
    56|  align-items: center;
    57|  justify-content: space-between;
    58|  padding: 24rpx 28rpx;
    59|  border-bottom: 1rpx solid var(--gray-200);
    60|  flex-shrink: 0;
    61|  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
    62|  border-radius: 32rpx 32rpx 0 0;
    63|  color: var(--color-bg-card);
    64|}
    65|.panel-header-left { display: flex; align-items: center; gap: 16rpx; }
    66|.panel-avatar { font-size: 44rpx; }
    67|.panel-avatar-img { width: 72rpx; height: 72rpx; border-radius: 50%; border: 3rpx solid rgba(255,255,255,0.6); }
    68|.panel-title { font-size: var(--font-lg); font-weight: 700; display: block; }
    69|.panel-subtitle { font-size: var(--font-xs); opacity: 0.75; display: block; }
    70|.panel-header-right { display: flex; gap: 20rpx; }
    71|.panel-btn { font-size: var(--font-lg); padding: 8rpx; opacity: 0.8; }
    72|.panel-btn:active { opacity: 0.5; }
    73|
    74|/* 消息体 */
    75|.panel-body {
    76|  flex: 1;
    77|  overflow-y: auto;
    78|  background: var(--gray-50);
    79|  padding: 16rpx 0;
    80|}
    81|.msg-list { padding: 0 24rpx; }
    82|
    83|.msg-item {
    84|  display: flex;
    85|  align-items: flex-start;
    86|  margin-bottom: 24rpx;
    87|  gap: 12rpx;
    88|}
    89|.msg-item.user { flex-direction: row-reverse; }
    90|
    91|.msg-avatar {
    92|  width: 56rpx;
    93|  height: 56rpx;
    94|  border-radius: 50%;
    95|  background: var(--color-primary-light);
    96|  display: flex;
    97|  align-items: center;
    98|  justify-content: center;
    99|  font-size: var(--font-lg);
   100|  flex-shrink: 0;
   101|  overflow: hidden;
   102|}
   103|.msg-avatar-img { width: 100%; height: 100%; border-radius: 50%; }
   104|
   105|.msg-bubble {
   106|  max-width: 75%;
   107|  padding: 20rpx 24rpx;
   108|  border-radius: 20rpx;
