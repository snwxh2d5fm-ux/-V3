/* 住港伴 v5 — 悬浮AI组件样式 (DSG-1 P0-03: 令牌重构) */

/* ===== 悬浮按钮 ===== */
.float-btn {
  position: fixed;
  bottom: 200rpx;
  right: 32rpx;
  z-index: 900;
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--blue), var(--blue-dark));
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 28rpx rgba(26,115,232,0.4);
  transition: all 0.2s ease;
}
.float-btn:active { transform: scale(0.9); }
.float-btn.hidden { transform: scale(0); opacity: 0; pointer-events: none; }

.float-btn-icon { font-size: 48rpx; }
.float-btn-img { width: 72rpx; height: 72rpx; border-radius: 50%; }
.float-btn-dot {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--green);
  border: 3rpx solid var(--white);
}

/* ===== AI 对话面板 ===== */
.ai-panel {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 80vh;
  background: var(--white);
  border-radius: 32rpx 32rpx 0 0;
  z-index: 950;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  box-shadow: 0 -8rpx 40rpx rgba(0,0,0,0.15);
}
.ai-panel.open { transform: translateY(0); }

/* 面板头部 */
.panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid var(--gray-200);
  flex-shrink: 0;
  background: linear-gradient(135deg, var(--blue), var(--blue-dark));
  border-radius: 32rpx 32rpx 0 0;
  color: var(--white);
}
.panel-header-left { display: flex; align-items: center; gap: 16rpx; }
.panel-avatar { font-size: 44rpx; }
.panel-avatar-img { width: 72rpx; height: 72rpx; border-radius: 50%; border: 3rpx solid rgba(255,255,255,0.6); }
.panel-title { font-size: var(--font-lg); font-weight: 700; display: block; }
.panel-subtitle { font-size: var(--font-xs); opacity: 0.75; display: block; }
.panel-header-right { display: flex; gap: 20rpx; }
.panel-btn { font-size: var(--font-lg); padding: 8rpx; opacity: 0.8; }
.panel-btn:active { opacity: 0.5; }

/* 消息体 */
.panel-body {
  flex: 1;
  overflow-y: auto;
  background: var(--gray-50);
  padding: 16rpx 0;
}
.msg-list { padding: 0 24rpx; }

.msg-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
  gap: 12rpx;
}
.msg-item.user { flex-direction: row-reverse; }

.msg-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--blue-light);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-lg);
  flex-shrink: 0;
  overflow: hidden;
}
.msg-avatar-img { width: 100%; height: 100%; border-radius: 50%; }

.msg-bubble {
  max-width: 75%;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  font-size: var(--font-md);
  line-height: 1.7;
  word-break: break-word;
}
.msg-bubble.assistant {
  background: var(--white);
  color: var(--gray-800);
  border-top-left-radius: 6rpx;
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.04);
}
.msg-bubble.user {
  background: var(--blue);
  color: var(--white);
  border-top-right-radius: 6rpx;
}
.msg-text { white-space: pre-wrap; }

/* 快捷回复 */
.msg-quick-replies {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--gray-200);
}
.qr-btn {
  display: inline-block;
  padding: 10rpx 22rpx;
  border-radius: 32rpx;
  font-size: var(--font-xs);
  color: var(--blue);
  background: var(--blue-light);
  border: 1rpx solid var(--blue-light);
  transition: all 0.15s;
}
.qr-btn:active { background: var(--gray-100); }

/* 加载动画 */
.loading-bubble {
  padding: 28rpx 32rpx;
  display: flex;
  align-items: center;
}
.typing-dots {
  display: flex;
  gap: 8rpx;
}
.typing-dots .dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--gray-400);
  animation: typingBounce 1.4s infinite;
}
.typing-dots .dot:nth-child(2) { animation-delay: 0.2s; }
.typing-dots .dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes typingBounce {
  0%, 60%, 100% { transform: translateY(0); }
  30% { transform: translateY(-10rpx); }
}

/* 路径评估引导条 */
.path-test-banner {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  margin: 12rpx 24rpx;
  background: linear-gradient(135deg, var(--blue), var(--blue-dark));
  border-radius: var(--radius);
  box-shadow: 0 4rpx 16rpx rgba(26,115,232,0.3);
}
.path-test-icon { font-size: var(--font-xxl); flex-shrink: 0; }
.path-test-info { flex: 1; min-width: 0; }
.path-test-title { font-size: var(--font-sm); font-weight: 700; color: var(--white); display: block; }
.path-test-desc { font-size: var(--font-xs); color: rgba(255,255,255,0.8); display: block; margin-top: 4rpx; }
.path-test-go {
  font-size: var(--font-sm);
  font-weight: 700;
  color: var(--white);
  background: rgba(255,255,255,0.2);
  padding: 12rpx 20rpx;
  border-radius: var(--radius-lg);
  flex-shrink: 0;
}
.path-test-go:active { background: rgba(255,255,255,0.35); }

/* 快捷入口 */
.quick-entries {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  overflow-x: auto;
  flex-shrink: 0;
  background: var(--gray-50);
  border-top: 1rpx solid var(--gray-200);
}
.qe-item {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 16rpx 20rpx;
  background: var(--white);
  border-radius: var(--radius);
  box-shadow: 0 1rpx 3rpx rgba(0,0,0,0.05);
  transition: transform 0.15s;
}
.qe-item:active { transform: scale(0.95); }
.qe-icon { font-size: var(--font-xl); }
.qe-label { font-size: var(--font-xs); color: var(--gray-500); font-weight: 500; }

/* 底部输入栏 */
.panel-footer {
  flex-shrink: 0;
  padding: 16rpx 24rpx 32rpx;
  background: var(--white);
  border-top: 1rpx solid var(--gray-200);
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}
.input-wrapper {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: var(--gray-100);
  border-radius: 40rpx;
  padding: 6rpx 6rpx 6rpx 28rpx;
}
.chat-input {
  flex: 1;
  height: 68rpx;
  font-size: var(--font-md);
  background: transparent;
  border: none;
  outline: none;
}
.send-btn {
  flex-shrink: 0;
  padding: 16rpx 28rpx;
  border-radius: 32rpx;
  font-size: var(--font-sm);
  font-weight: 600;
  color: var(--gray-400);
  background: var(--gray-200);
  transition: all 0.2s;
}
.send-btn.active {
  color: var(--white);
  background: var(--blue);
}

/* 遮罩 */
.ai-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 940;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
}
.ai-mask.open {
  opacity: 1;
  pointer-events: auto;
}
