.privacy-toggle {
  display: inline-flex;
  gap: 4rpx;
}
.mode-dot {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.15);
}
.mode-dot.active {
  background: rgba(255, 255, 255, 0.4);
}
.mode-icon {
  font-size: 22rpx;
}
