<view class="privacy-toggle" role="radiogroup" aria-label="隐私模式切换">
  <view class="mode-dot {{currentMode === item.key ? 'active' : ''}}"
        wx:for="{{modes}}" wx:key="key"
        data-mode="{{item.key}}"
        bindtap="switchMode"
        role="radio"
        aria-checked="{{currentMode === item.key}}"
        aria-label="{{item.label}}">
    <text class="mode-icon">{{item.icon}}</text>
  </view>
</view>
