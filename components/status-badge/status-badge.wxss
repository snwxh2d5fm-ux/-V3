.badge-bar {
  display: flex; align-items: center; gap: 14rpx;
  padding: 12rpx 24rpx;
}

.badge {
  display: flex; align-items: center; gap: 8rpx;
  padding: 8rpx 16rpx; border-radius: 20rpx;
  font-size: 22rpx; font-weight: 600;
}

.badge--identity {
  background: var(--gray-100);
  color: var(--gray-700);
}

.badge--path {
  background: var(--color-info-bg);
  color: var(--color-info);
}

.badge__lock { font-size: 16rpx; opacity: 0.5; margin-right: 2rpx; }
.badge__text { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 200rpx; }
.badge__arrow { font-size: 22rpx; color: var(--gray-400); margin-left: 2rpx; }

/* ===== 支付拦截弹窗 ===== */
.paywall-overlay {
  position: fixed; inset: 0; z-index: 10000;
  background: rgba(0,0,0,0.5);
  display: flex; align-items: center; justify-content: center;
}
.paywall-card {
  width: 600rpx; background: var(--color-bg-card); border-radius: 24rpx;
  padding: 48rpx 40rpx 36rpx; text-align: center;
}
.paywall__icon { font-size: 64rpx; display: block; margin-bottom: 16rpx; }
.paywall__title { font-size: 34rpx; font-weight: 800; color: var(--color-text-primary); display: block; margin-bottom: 12rpx; }
.paywall__desc { font-size: 26rpx; color: var(--gray-500); line-height: 1.6; display: block; margin-bottom: 24rpx; }
.paywall__price {
  background: var(--gray-50); border-radius: 14rpx; padding: 20rpx; margin-bottom: 28rpx;
}
.paywall__amount { font-size: 48rpx; font-weight: 800; color: var(--color-error); display: block; }
.paywall__note { font-size: 22rpx; color: var(--gray-400); display: block; margin-top: 4rpx; }
.paywall__actions { display: flex; gap: 16rpx; }
.paywall__actions .btn { flex: 1; }
