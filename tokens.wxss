/**
 * 住港伴 — DSG-3 语义色令牌体系
 * 禁止直接使用 hex 值，全部通过 var() 引用本文件变量
 */

page {
  /* ═══ 主色系统 ═══ */
  --color-primary: #1a73e8;
  --color-primary-dark: #1557b0;
  --color-primary-light: #e8f0fe;

  /* ═══ 中性色 (Bug #3: 统一权威源，采用 v5 对比度增强值) ═══ */
  --color-text-primary: #111827;
  --color-text-secondary: #5f6368;
  --color-text-muted: #757F8C;
  --color-bg-page: #f8f9fa;
  --color-bg-card: #ffffff;
  --color-border: #e5e7eb;

  /* ═══ 语义色 ═══ */
  --color-success: #059669;
  --color-success-bg: #ecfdf5;
  --color-warning: #ea580c;
  --color-warning-bg: #fff7ed;
  --color-error: #dc2626;
  --color-error-bg: #fef2f2;
  --color-info: #2563eb;
  --color-info-bg: #eff6ff;

  /* ═══ 灰阶 (v5 对比度增强: gray-400/500 白色背景 ≥4.5:1) ═══ */
  --gray-50: #F9FAFB;
  --gray-100: #F3F4F6;
  --gray-200: #E5E7EB;
  --gray-300: #D1D5DB;
  --gray-400: #757F8C;
  --gray-500: #5E6773;
  --gray-600: #4B5563;
  --gray-700: #374151;
  --gray-800: #1F2937;
  --gray-900: #111827;

  /* ═══ 间距 ═══ */
  --space-xs: 8rpx;
  --space-sm: 12rpx;
  --space-md: 16rpx;
  --space-lg: 24rpx;
  --space-xl: 32rpx;

  /* ═══ 圆角 ═══ */
  --radius-xs: 6rpx;
  --radius-sm: 8rpx;
  --radius: 16rpx;
  --radius-lg: 24rpx;
  --radius-pill: 20rpx;

  /* ═══ 字号 ═══ */
  --font-xs: 22rpx;
  --font-sm: 26rpx;
  --font-md: 30rpx;
  --font-lg: 34rpx;
  --font-xl: 40rpx;
  --font-xxl: 48rpx;

  /* ═══ 阴影 ═══ */
  --shadow-sm: 0 2rpx 8rpx rgba(0,0,0,0.04);
  --shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
  --shadow-lg: 0 8rpx 32rpx rgba(0,0,0,0.12);
}
