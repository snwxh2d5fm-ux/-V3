/**
 * 住港伴 — DSG-3 语义色令牌体系 v2.0
 * 禁止直接使用 hex 值，全部通过 var() 引用本文件变量
 * 单源真相 — 所有颜色/间距/字号/阴影在此定义
 */

page {
  /* ═══ 主色系统 ═══ */
  --color-primary: #1a73e8;
  --color-primary-dark: #1557b0;
  --color-primary-light: #e8f0fe;

  /* ═══ 中性色 (对比度增强: gray-400/500 在白色背景 ≥4.5:1) ═══ */
  --color-text-primary: #111827;
  --color-text-secondary: #5f6368;
  --color-text-muted: #757f8c;
  --color-bg-page: #f8f9fa;
  --color-bg-card: #ffffff;
  --color-border: #e5e7eb;

  /* ═══ 语义色 ═══ */
  --color-success: #059669;
  --color-success-bg: #ecfdf5;
  --color-warning: #ea580c;
  --color-warning-bg: #fff7ed;
  --color-error: #dc2626;
  --color-error-bg: #fef2f2;
  --color-info: #2563eb;
  --color-info-bg: #eff6ff;

  /* ═══ 品牌渐变色 ═══ */
  --gradient-header: linear-gradient(135deg, #1557b0, #1a73e8);
  --gradient-hero: linear-gradient(135deg, #2563eb, #1a73e8);
  --gradient-success: linear-gradient(135deg, #059669, #047857);
  --gradient-membership: linear-gradient(135deg, #1557b0, #2563eb);
  --gradient-vault: linear-gradient(135deg, #7c3aed, #a855f7);
  --gradient-warm: linear-gradient(135deg, #fff8e1, #fff3cd);

  /* ═══ 灰阶 ═══ */
  --gray-50: #f9fafb;
  --gray-100: #f3f4f6;
  --gray-200: #e5e7eb;
  --gray-300: #d1d5db;
  --gray-400: #757f8c;
  --gray-500: #5e6773;
  --gray-600: #4b5563;
  --gray-700: #374151;
  --gray-800: #1f2937;
  --gray-900: #111827;

  /* ═══ 间距 (4rpx 栅格) ═══ */
  --space-xs: 8rpx;
  --space-sm: 12rpx;
  --space-md: 16rpx;
  --space-lg: 24rpx;
  --space-xl: 32rpx;
  --space-2xl: 48rpx;

  /* ═══ 圆角 ═══ */
  --radius-xs: 6rpx;
  --radius-sm: 8rpx;
  --radius: 16rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-pill: 20rpx;

  /* ═══ 字号 ═══ */
  --font-xs: 22rpx;
  --font-sm: 26rpx;
  --font-md: 28rpx;
  --font-lg: 32rpx;
  --font-xl: 36rpx;
  --font-xxl: 44rpx;

  /* ═══ 阴影 ═══ */
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  --shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  --shadow-md: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  --shadow-lg: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);

  /* ═══ 动效时长 ═══ */
  --duration-fast: 0.15s;
  --duration: 0.25s;
  --duration-slow: 0.4s;
  --easing: cubic-bezier(0.4, 0, 0.2, 1);

  /* ═══ Z-Index ═══ */
  --z-base: 1;
  --z-dropdown: 100;
  --z-sticky: 200;
  --z-overlay: 500;
  --z-modal: 800;
  --z-toast: 1000;
}
