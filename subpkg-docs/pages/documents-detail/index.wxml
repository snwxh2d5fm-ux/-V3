<!-- pages/documents/detail/detail.wxml -->
<view class="page">
  <!-- 图片展示区 -->
  <view class="image-area" wx:if="{{doc && doc.filePath}}" bindtap="previewImage">
    <image class="detail-image" src="{{doc.filePath}}" mode="aspectFit" />
    <view class="image-tap-hint">点击查看大图</view>
  </view>

  <!-- 证件基本信息 -->
  <view class="card doc-info" wx:if="{{doc}}">
    <view class="card-header">
      <text class="card-title">{{doc.name || doc.docType || '证件'}}</text>
      <view class="status-badge {{isArchived ? 'archived' : 'active'}}">
        {{isArchived ? '已归档' : '使用中'}}
      </view>
    </view>

    <view class="ocr-fields" wx:if="{{ocrFields.length}}">
      <text class="section-title">识别信息</text>
      <view class="field-row" wx:for="{{ocrFields}}" wx:key="key">
        <text class="field-label">{{item.label}}</text>
        <text class="field-value">{{item.value}}</text>
      </view>
    </view>

    <view class="empty-ocr" wx:else>
      <text>暂无识别信息</text>
    </view>

    <view class="doc-specs" wx:if="{{spec}}">
      <text class="section-title">📋 材料要求</text>
      <view class="spec-row"><text class="spec-label">格式</text><text class="spec-value">{{spec.tip}}</text></view>
      <view class="spec-row"><text class="spec-label">有效期</text><text class="spec-value">{{spec.validity}}</text></view>
      <view class="spec-row"><text class="spec-label">规格</text><text class="spec-value">{{spec.size}}</text></view>
      <view class="spec-row"><text class="spec-label">份数</text><text class="spec-value">至少1份，建议备份</text></view>
    </view>

    <view class="doc-time">
      <text>添加于: {{doc.createdAt || '未知'}}</text>
      <text wx:if="{{doc.updatedAt}}">更新于: {{doc.updatedAt}}</text>
    </view>
  </view>

  <!-- 操作区 -->
  <view class="card actions">
    <button class="action-item" bindtap="{{isArchived ? 'restoreDocument' : 'archiveDocument'}}">
      <text>{{isArchived ? '↩️ 恢复' : '📦 归档'}}</text>
    </button>
    <button class="action-item" bindtap="replaceDocument" wx:if="{{!isArchived}}">
      <text>🔄 替换</text>
    </button>
    <button class="action-item danger" bindtap="deleteDocument">
      <text>🗑️ 删除</text>
    </button>
  </view>

  <floating-ai visible="{{true}}" />
</view>
