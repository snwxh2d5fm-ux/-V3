/* 住港伴 v3 — 添加证件页样式 */

/* ===== Step 1: 输入方式选择 ===== */
.input-modes {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  padding: 24rpx 24rpx 0;
}
.input-mode-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 28rpx 18rpx;
  background: var(--color-bg-card);
  border-radius: 18rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
  border: 2rpx solid var(--gray-200);
  transition: all 0.15s;
}
.input-mode-card:active {
  border-color: var(--color-primary);
  background: var(--color-primary-light);
  transform: scale(0.98);
}
.input-mode-icon {
  font-size: 64rpx;
}
.input-mode-title {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--gray-800);
}
.input-mode-desc {
  font-size: var(--font-xs);
  color: var(--gray-500);
}
/* 卡槽专属指引卡片 */
.slot-guide-card { margin: 20rpx 24rpx 0; padding: 24rpx; border-radius: 18rpx; background: linear-gradient(135deg, var(--color-info-bg), var(--color-info-bg)); border: 2rpx solid rgba(26,115,232,0.2); }
.slot-guide__head { display: flex; align-items: center; gap: 12rpx; margin-bottom: 16rpx; }
.slot-guide__icon { font-size: 40rpx; }
.slot-guide__title { font-size: 28rpx; font-weight: 700; color: var(--color-primary-dark); }
.slot-guide__items { display: flex; flex-direction: column; gap: 10rpx; }
.slot-guide__item { display: flex; align-items: flex-start; gap: 10rpx; font-size: 24rpx; color: var(--gray-700); line-height: 1.6; }
.slot-guide__dot { color: var(--color-info); flex-shrink: 0; font-size: 16rpx; margin-top: 6rpx; }
.slot-guide__pii { margin-top: 16rpx; padding: 14rpx 18rpx; border-radius: 12rpx; background: var(--color-error-bg); border: 1rpx solid rgba(220,38,38,0.15); }
.pii-label { font-size: 22rpx; color: var(--color-error); font-weight: 600; display: block; margin-bottom: 4rpx; }
.pii-fields { font-size: 22rpx; color: var(--color-error); }
.slot-guide__specimen { display: flex; align-items: center; gap: 8rpx; margin-top: 12rpx; padding: 12rpx 16rpx; border-radius: 10rpx; background: var(--color-success-bg); border: 1rpx solid rgba(5,150,105,0.15); }
.specimen-icon { font-size: 24rpx; }
.specimen-text { font-size: 22rpx; color: var(--color-success); }

/* ═══ R4: 证件线框示意图 (脱敏案例库驱动) ═══ */
.doc-wireframe { margin: 16rpx 24rpx 0; padding: 24rpx; border-radius: 18rpx; background: var(--gray-50); border: 1rpx solid var(--gray-200); position: relative; }
/* 证件卡片 */
.wf-card { padding: 24rpx; border-radius: 12rpx; background: var(--white); border: 2rpx solid var(--gray-300); position: relative; z-index: 1; }
/* 头部 */
.wf-header { display: flex; align-items: center; gap: 16rpx; padding-bottom: 20rpx; margin-bottom: 16rpx; border-bottom: 1rpx solid var(--gray-200); }
.wf-logo-line { width: 56rpx; height: 56rpx; border-radius: 8rpx; border: 2rpx dashed var(--gray-300); flex-shrink: 0; }
.wf-title { font-size: 24rpx; font-weight: 600; color: var(--gray-600); }
/* 正文区 */
.wf-body { display: flex; gap: 20rpx; }
.wf-photo { width: 130rpx; height: 160rpx; border-radius: 6rpx; border: 2rpx dashed var(--gray-300); display: flex; flex-direction: column; align-items: center; justify-content: center; flex-shrink: 0; position: relative; }
.wf-photo__frame { width: 90rpx; height: 110rpx; border: 2rpx dotted var(--gray-300); border-radius: 4rpx; }
.wf-photo__tag { font-size: 18rpx; color: var(--gray-400); margin-top: 8rpx; }
/* 字段线框 */
.wf-fields { flex: 1; display: flex; flex-direction: column; gap: 16rpx; padding-top: 4rpx; }
.wf-field { position: relative; }
.wf-line { height: 2rpx; border-radius: 1rpx; background: var(--gray-300); margin-bottom: 6rpx; }
.wf-line--short { width: 45%; }
.wf-line--mid { width: 65%; }
.wf-line--long { width: 82%; }
.wf-line--full { width: 95%; }
.wf-label { font-size: 20rpx; color: var(--gray-400); }
.wf-pii-tag { position: absolute; right: 0; top: 0; font-size: 18rpx; color: var(--color-error); background: var(--color-error-bg); padding: 2rpx 8rpx; border-radius: 4rpx; }
/* 底部印章 */
.wf-footer { display: flex; align-items: center; gap: 12rpx; margin-top: 20rpx; padding-top: 16rpx; border-top: 1rpx solid var(--gray-200); }
.wf-seal { width: 64rpx; height: 64rpx; border-radius: 50%; border: 3rpx dashed var(--gray-300); flex-shrink: 0; }
.wf-footer-label { font-size: 20rpx; color: var(--gray-400); }
/* 四角标尺 */
.wf-ruler-tl, .wf-ruler-tr, .wf-ruler-bl, .wf-ruler-br { position: absolute; width: 36rpx; height: 36rpx; z-index: 0; }
.wf-ruler-tl { top: 8rpx; left: 8rpx; border-top: 4rpx solid var(--color-primary); border-left: 4rpx solid var(--color-primary); border-radius: 4rpx 0 0 0; }
.wf-ruler-tr { top: 8rpx; right: 8rpx; border-top: 4rpx solid var(--color-primary); border-right: 4rpx solid var(--color-primary); border-radius: 0 4rpx 0 0; }
.wf-ruler-bl { bottom: 8rpx; left: 8rpx; border-bottom: 4rpx solid var(--color-primary); border-left: 4rpx solid var(--color-primary); border-radius: 0 0 0 4rpx; }
.wf-ruler-br { bottom: 8rpx; right: 8rpx; border-bottom: 4rpx solid var(--color-primary); border-right: 4rpx solid var(--color-primary); border-radius: 0 0 4rpx 0; }
.wf-hint { display: block; text-align: center; margin-top: 16rpx; font-size: 22rpx; color: var(--gray-400); }

/* 通用指引（无卡槽上下文时） */
.capture-guide { margin: 20rpx 24rpx 0; padding: 24rpx; border-radius: 16rpx; background: var(--gray-50); border: 1rpx solid var(--gray-100); }
.capture-guide__title { font-size: 28rpx; font-weight: 700; color: var(--color-text-primary); margin-bottom: 16rpx; }
.capture-guide__list { display: flex; flex-direction: column; gap: 10rpx; }
.capture-guide__item { display: flex; align-items: flex-start; gap: 10rpx; font-size: 24rpx; color: var(--gray-700); line-height: 1.5; }
.capture-guide__icon { flex-shrink: 0; width: 32rpx; text-align: center; }
.capture-guide__note { display: block; margin-top: 16rpx; padding: 12rpx 16rpx; border-radius: 10rpx; background: var(--color-info-bg); font-size: 22rpx; color: var(--color-info); line-height: 1.5; }

.privacy-notice {
  margin: 0 24rpx;
  padding: 20rpx 24rpx;
  background: var(--color-success-bg);
  border-radius: var(--radius-sm);
  font-size: var(--font-xs);
  color: var(--color-success);
  text-align: center;
  line-height: 1.6;
}

/* ===== Step 2: 图片预览 + OCR状态 ===== */
.image-preview {
  margin: 16rpx 24rpx;
  border-radius: var(--radius);
  overflow: hidden;
  background: var(--gray-100);
  display: flex;
  align-items: center;
  justify-content: center;
  height: 480rpx;
}
.preview-img {
  width: 100%;
  height: 100%;
}

.ocr-status {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx;
  gap: 14rpx;
}
.ocr-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid var(--gray-200);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin {
  to { transform: rotate(360deg); }
}
.ocr-status-text {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--gray-700);
}
.ocr-status-sub {
  font-size: var(--font-xs);
  color: var(--gray-400);
}

.quality-warnings {
  margin: 12rpx 24rpx;
  padding: 20rpx 24rpx;
  background: var(--orange-light);
  border-radius: var(--radius-sm);
  border-left: 6rpx solid var(--orange);
}

/* 隐私说明卡片 */
.privacy-inline {
  margin: 4rpx 24rpx 20rpx;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, var(--color-success-bg) 0%, var(--color-success-bg) 100%);
  border-radius: var(--radius-sm);
  border: 1rpx solid rgba(5,150,105,0.15);
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}
.privacy-inline__icon {
  font-size: 36rpx;
  line-height: 1;
  flex-shrink: 0;
  margin-top: 2rpx;
}
.privacy-inline__body {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.privacy-inline__title {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--color-success);
}
.privacy-inline__desc {
  font-size: 22rpx;
  color: var(--color-success);
  line-height: 1.6;
}
.quality-title {
  font-size: var(--font-sm);
  font-weight: 700;
  color: var(--orange);
  display: block;
  margin-bottom: 8rpx;
}
.quality-item {
  font-size: var(--font-xs);
  color: var(--color-warning);
  display: block;
  line-height: 1.8;
}

/* ===== Step 3: OCR结果确认 ===== */
.image-thumb {
  margin: 16rpx 24rpx;
  position: relative;
  border-radius: var(--radius);
  overflow: hidden;
  height: 200rpx;
  background: var(--gray-100);
}
.thumb-img {
  width: 100%;
  height: 100%;
  opacity: 0.7;
}
.thumb-badge {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  font-size: 36rpx;
  background: rgba(255,255,255,0.9);
  border-radius: 50%;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ===== 极低置信度横幅 ===== */
.low-confidence-banner {
  display: flex; gap: 12rpx; align-items: flex-start;
  margin: 0 24rpx 16rpx; padding: 20rpx 24rpx;
  background: var(--color-error-bg); border: 2rpx solid rgba(220,38,38,0.15); border-radius: 14rpx;
}
.low-confidence-icon { font-size: 36rpx; flex-shrink: 0; }
.low-confidence-body { flex: 1; }
.low-confidence-title { font-size: 28rpx; font-weight: 700; color: var(--color-error); display: block; margin-bottom: 4rpx; }
.low-confidence-desc { font-size: 24rpx; color: var(--color-error); line-height: 1.6; display: block; }

.confidence-hint {
  font-size: 24rpx;
  color: var(--orange);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  margin-top: 12rpx;
  padding: 10rpx 16rpx;
  background: var(--orange-light);
  border-radius: 10rpx;
  font-weight: 500;
}

/* OCR字段行 */
.field-row {
  display: flex;
  align-items: center;
  padding: 16rpx 28rpx;
  border-bottom: 1rpx solid var(--gray-100);
  gap: 16rpx;
}
.field-label {
  font-size: var(--font-sm);
  color: var(--gray-500);
  width: 140rpx;
  flex-shrink: 0;
  font-weight: 500;
}
.field-input {
  flex: 1;
  font-size: var(--font-md);
  color: var(--gray-800);
  text-align: right;
  border: none;
  background: transparent;
}

/* ===== Step 4: 所属人选择 ===== */
.owner-select {
  padding: 0 24rpx;
  margin-top: 20rpx;
}
.owner-select__label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--gray-700);
  margin-bottom: 16rpx;
  display: block;
}
.owner-select__options {
  display: flex;
  gap: 16rpx;
}
.owner-opt {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 20rpx 12rpx;
  background: var(--color-bg-card);
  border-radius: var(--radius);
  border: 2rpx solid var(--gray-200);
  position: relative;
  transition: all 0.2s;
}
.owner-opt--active {
  border-color: var(--color-primary);
  background: var(--color-primary-light);
}
.owner-opt__icon {
  font-size: 40rpx;
}
.owner-opt__label {
  font-size: 26rpx;
  color: var(--gray-500);
}
.owner-opt--active .owner-opt__label {
  color: var(--color-primary);
  font-weight: 600;
}
.owner-opt__check {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: var(--color-primary);
  color: var(--color-bg-card);
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.owner-name-input {
  margin-top: 16rpx;
  padding: 14rpx 20rpx;
  background: var(--color-bg-card);
  border-radius: var(--radius);
  border: 2rpx solid var(--gray-200);
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
}

/* ===== Step 4: 分类选择 ===== */
.category-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  padding: 0 24rpx;
  margin: 20rpx 0;
}
.category-card {
  position: relative;
  background: var(--color-bg-card);
  border-radius: var(--radius);
  padding: 24rpx 20rpx;
  text-align: center;
  border: 2rpx solid var(--gray-200);
  transition: all 0.2s;
}
.category-card:active {
  transform: scale(0.97);
}
.category-card.selected {
  border-color: var(--color-primary);
  background: var(--color-primary-light);
}
.category-icon {
  font-size: 40rpx;
  display: block;
  margin-bottom: 8rpx;
}
.category-label {
  font-size: var(--font-md);
  font-weight: 700;
  display: block;
  color: var(--gray-800);
}
.category-desc {
  font-size: var(--font-xs);
  color: var(--gray-400);
  display: block;
  margin-top: 4rpx;
}
.category-check {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: var(--color-primary);
  color: var(--color-bg-card);
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ═══ 证件对齐裁切 ═══ */
.crop-container { position: relative; width: 100%; height: 600rpx; background: var(--gray-900); overflow: hidden; }
.crop-movable { width: 750rpx; height: 600rpx; }
.crop-view { display: flex; align-items: center; justify-content: center; width: 200%; height: 200%; }
.crop-img { width: 100%; opacity: 0.8; }
/* 遮罩层 */
.crop-mask { position: absolute; background: rgba(0,0,0,0.55); z-index: 2; }
.crop-mask--top { top: 0; left: 0; right: 0; height: 80rpx; }
.crop-mask--bottom { bottom: 0; left: 0; right: 0; height: 80rpx; }
.crop-mask--left { top: 80rpx; left: 0; bottom: 80rpx; width: 40rpx; }
.crop-mask--right { top: 80rpx; right: 0; bottom: 80rpx; width: 40rpx; }
/* 证件框 */
.crop-frame { position: absolute; top: 80rpx; left: 40rpx; right: 40rpx; bottom: 80rpx; z-index: 3; border: 4rpx dashed rgba(255,255,255,0.7); border-radius: 12rpx; }
.crop-corner { position: absolute; width: 32rpx; height: 32rpx; }
.crop-corner--tl { top: -4rpx; left: -4rpx; border-top: 6rpx solid #3B82F6; border-left: 6rpx solid #3B82F6; }
.crop-corner--tr { top: -4rpx; right: -4rpx; border-top: 6rpx solid #3B82F6; border-right: 6rpx solid #3B82F6; }
.crop-corner--bl { bottom: -4rpx; left: -4rpx; border-bottom: 6rpx solid #3B82F6; border-left: 6rpx solid #3B82F6; }
.crop-corner--br { bottom: -4rpx; right: -4rpx; border-bottom: 6rpx solid #3B82F6; border-right: 6rpx solid #3B82F6; }
/* ═══ 预览脱敏遮罩图层 (Bug #12: 动态位置，去掉硬编码) ═══ */
.privacy-overlay { position: absolute; top: 0; left: 0; right: 0; bottom: 0; z-index: 2; pointer-events: none; }
.privacy-bar { position: absolute; background: rgba(0,0,0,0.65); border-radius: 4rpx; }
.privacy-label { position: absolute; color: var(--color-bg-card); font-size: 18rpx; text-align: center; opacity: 0.8;
  /* 用top偏移微调使标签居中对齐遮罩条 */ transform: translateY(-110%); }

/* 按钮行 */
.btn-flex {
  flex: 1;
}

/* ═══ Bug #2: 自由模式证件类型选择 ═══ */
.doc-type-scroll { white-space: nowrap; padding: 4rpx 0; }
.doc-type-chip { display: inline-flex; align-items: center; padding: 12rpx 20rpx; margin-right: 12rpx; border-radius: 16rpx; background: var(--color-bg-card); border: 2rpx solid var(--gray-200); font-size: 24rpx; transition: all 0.15s; }
.doc-type-chip.active { border-color: var(--color-primary); background: var(--color-info-bg); }
.doc-type-chip__icon { font-size: 28rpx; margin-right: 6rpx; }
.doc-type-chip__label { color: var(--gray-600); }
.doc-type-chip.active .doc-type-chip__label { color: var(--color-primary); font-weight: 600; }

/* Bug #2: 自由模式拍摄要求列表 */
.free-guide-items { display: flex; flex-direction: column; padding: 16rpx 0 0; }
.free-guide-item { display: flex; align-items: flex-start; font-size: 22rpx; color: var(--gray-600); line-height: 1.5; margin-bottom: 8rpx; }
.free-guide-item:last-child { margin-bottom: 0; }
.free-guide-dot { color: var(--color-primary); flex-shrink: 0; font-size: 14rpx; margin-top: 6rpx; margin-right: 8rpx; }

/* ═══ Bug #5: 旋转+扫描件工具栏 ═══ */
.img-toolbar { display: flex; padding: 12rpx 24rpx; }
.img-tool { display: flex; align-items: center; padding: 14rpx 24rpx; border-radius: 12rpx; background: var(--color-bg-card); border: 2rpx solid var(--gray-200); font-size: 24rpx; margin-right: 16rpx; }
.img-tool:active { background: var(--gray-100); transform: scale(0.96); }
.img-tool.disabled { opacity: 0.5; display: none; }
.img-tool__icon { font-size: 28rpx; margin-right: 8rpx; }
.img-tool:last-child { margin-right: 0; }
.img-tool__label { color: var(--gray-600); }

/* ═══ Bug #6: 质量检测增强可见性 ═══ */
.quality-card { margin: 12rpx 24rpx; padding: 24rpx; border-radius: 16rpx; background: var(--color-bg-card); border: 2rpx solid var(--gray-200); }
.quality-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.quality-header__title { font-size: 26rpx; font-weight: 700; color: var(--gray-800); }
.quality-header__status { font-size: 22rpx; font-weight: 600; padding: 4rpx 14rpx; border-radius: 10rpx; }
.quality-header__status.pass { color: var(--color-success); background: var(--color-success-bg); }
.quality-header__status.fail { color: var(--color-error); background: var(--color-error-bg); }
.quality-score-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10rpx; }
.quality-score-label { font-size: 24rpx; color: var(--gray-500); }
.quality-score { font-size: 28rpx; font-weight: 700; }
.quality-score--good { color: var(--color-success); }
.quality-score--fair { color: var(--color-info); }
.quality-score--avg { color: var(--color-warning); }
.quality-score--poor { color: var(--color-error); }
.quality-bar { height: 10rpx; background: var(--gray-100); border-radius: 5rpx; margin-bottom: 6rpx; overflow: hidden; }
.quality-bar__fill { height: 100%; border-radius: 5rpx; transition: width 0.4s; }
.quality-bar__fill--good { background: var(--color-success); }
.quality-bar__fill--fair { background: var(--color-info); }
.quality-bar__fill--avg { background: var(--color-warning); }
.quality-bar__fill--poor { background: var(--color-error); }
.quality-score-hint { font-size: 20rpx; color: var(--gray-400); display: block; margin-bottom: 12rpx; }
.quality-issue { display: flex; align-items: flex-start; padding: 8rpx 0; }
.quality-issue__icon { font-size: 22rpx; flex-shrink: 0; margin-top: 2rpx; margin-right: 8rpx; }
.quality-issue__msg { font-size: 22rpx; color: var(--gray-600); line-height: 1.5; }
.quality-action { margin-top: 12rpx; padding: 10rpx 14rpx; border-radius: 8rpx; background: var(--color-error-bg); }
.quality-action__text { font-size: 22rpx; color: var(--color-error); }
/* 质量检测加载中 */
.quality-card--pending { display: flex; align-items: center; padding: 32rpx 24rpx; justify-content: center; }
.quality-pending__icon { font-size: 36rpx; margin-right: 12rpx; }
.quality-pending__text { font-size: 24rpx; color: var(--gray-400); }
/* 步骤提示 */
.step-hint { text-align: center; padding: 8rpx 24rpx; }
.step-hint .step-hint-txt { font-size: 20rpx; color: var(--color-warning); }

/* #7: 旋转工具栏 */
.crop-tools { display: flex; gap: 12rpx; padding: 16rpx 24rpx; }
.crop-tool-btn { flex: 1; padding: 18rpx 12rpx; border-radius: 12rpx; font-size: 24rpx; font-weight: 600; background: var(--gray-100); color: var(--gray-700); border: 1rpx solid var(--gray-200); text-align: center; }
.crop-tool-btn--primary { background: var(--color-primary); color: var(--white); border: none; }
.crop-tool-btn::after { border: none; }
.crop-tool-btn--primary::after { border: none; }
.crop-hint { display: block; text-align: center; font-size: 22rpx; color: var(--gray-400); padding: 8rpx 24rpx; }


/* 证件面选择 */
.side-selector { display: flex; margin: 16rpx 24rpx; gap: 16rpx; }
.side-tab { flex: 1; padding: 20rpx; text-align: center; background: #f5f5f5; border-radius: 12rpx; font-size: 28rpx; color: #666; border: 2rpx solid transparent; }
.side-tab.active { background: #e8f0fe; border-color: #3e6ae1; color: #3e6ae1; font-weight: 600; }
.photo-side-tag { position: absolute; top: 16rpx; right: 16rpx; padding: 4rpx 16rpx; background: rgba(0,0,0,0.6); color: #fff; border-radius: 8rpx; font-size: 22rpx; }
.both-sides-status { display: flex; justify-content: center; gap: 32rpx; padding: 12rpx 24rpx; font-size: 24rpx; }
.both-sides-status .done { color: #3e6ae1; }
