/* 住港伴 v5 — 全局样式 (DSG-3 令牌体系 v2.0) */
@import "tokens.wxss";

page {
  /* ═══ 兼容别名 (保持现有代码不报错) ═══ */
  --blue: var(--color-primary);
  --blue-dark: var(--color-primary-dark);
  --blue-light: var(--color-primary-light);
  --green: var(--color-success);
  --green-light: var(--color-success-bg);
  --green-dark: #047857;
  --orange: var(--color-warning);
  --orange-light: var(--color-warning-bg);
  --red: var(--color-error);
  --red-light: var(--color-error-bg);
  --white: var(--color-bg-card);

  /* 语义别名 */
  /* --color-primary: from tokens.wxss */
  /* --color-primary-dark: from tokens.wxss (no override needed) */
  /* --color-primary-light: from tokens.wxss */
  /* --color-success: from tokens.wxss */
  /* --color-warning: from tokens.wxss */
  /* --color-danger: legacy alias — prefer --color-error */
  --color-bg: var(--color-bg-page);
  /* --color-bg-card: from tokens.wxss */
  --color-text: var(--color-text-primary);
  /* --color-border: from tokens.wxss */

  /* --radius-sm: from tokens.wxss */
  /* --radius: from tokens.wxss */
  /* --radius-md: from tokens.wxss */
  /* --radius-lg: from tokens.wxss */
  /* --radius-xs: from tokens.wxss */
  /* --radius-pill: from tokens.wxss */
  /* --space-xs: from tokens.wxss */
  /* --space-sm: from tokens.wxss */
  /* --space-md: from tokens.wxss */
  /* --space-lg: from tokens.wxss */
  /* --space-xl: from tokens.wxss */
  /* --space-2xl: from tokens.wxss */
  /* --shadow-sm: from tokens.wxss */
  /* --shadow: from tokens.wxss */
  /* --shadow-md: from tokens.wxss */
  /* --shadow-lg: from tokens.wxss */

  /* --font-xs: from tokens.wxss */
  /* --font-sm: from tokens.wxss */
  /* --font-md: from tokens.wxss */
  /* --font-lg: from tokens.wxss */
  /* --font-xl: from tokens.wxss */
  /* --font-xxl: from tokens.wxss */

  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Microsoft YaHei', 'Helvetica Neue', sans-serif;
  font-size: var(--font-md);
  color: var(--color-text-primary);
  background-color: var(--color-bg);
  box-sizing: border-box;
  line-height: 1.6;
}

/* ===== 通用容器 ===== */
.container {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* ===== 页面顶部栏 — 全局统一蓝底白字 (v2: 使用梯度令牌) ===== */
.page-header, .page-header__wrap {
  padding: 24rpx 32rpx 20rpx;
  background: var(--gradient-header);
  color: var(--color-bg-card);
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.page-header-title, .page-header__title {
  font-size: var(--font-lg);
  font-weight: 800;
  color: #FFF;
  letter-spacing: 0.5rpx;
}
.page-header-sub, .page-header__subtitle {
  font-size: var(--font-xs);
  opacity: 0.8;
  margin-top: 4rpx;
  color: rgba(255,255,255,0.8);
}

/* ===== 隐私指示条 ===== */
.privacy-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background: var(--color-success-bg);
  font-size: var(--font-xs);
  color: var(--color-success);
  font-weight: 500;
}

/* ===== 卡片系统 ===== */
.card {
  background: var(--color-bg-card);
  border-radius: var(--radius);
  padding: 28rpx;
  margin: 16rpx 24rpx;
  box-shadow: var(--shadow-sm);
  transition: box-shadow var(--duration-fast) var(--easing);
}
.card--flat {
  margin: 0;
  border-radius: 0;
  box-shadow: none;
}
.card--outlined {
  border: 1rpx solid var(--color-border);
  box-shadow: none;
}
.card--highlight {
  border-left: 6rpx solid var(--color-primary);
}
.card--urgent {
  border-left: 6rpx solid var(--red);
}
.card--warning {
  border-left: 6rpx solid var(--orange);
}
.card--success {
  border-left: 6rpx solid var(--color-success);
}

.card-title {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 16rpx;
}
.card-subtitle {
  font-size: var(--font-xs);
  color: var(--color-text-secondary);
}

.card-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
}
.card-row + .card-row {
  border-top: 1rpx solid var(--gray-100);
}
.card-row-label {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
}
.card-row-value {
  font-size: var(--font-sm);
  font-weight: 600;
}

/* ===== 按钮系统 ===== */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx 36rpx;
  border-radius: var(--radius-sm);
  font-size: var(--font-md);
  font-weight: 600;
  border: none;
  transition: all var(--duration-fast) var(--easing);
}
.btn:active { opacity: 0.85; transform: scale(0.97); }

.btn-primary { background: var(--color-primary); color: var(--color-bg-card); }
.btn-primary:active { background: var(--color-primary-dark); }
.btn-outline { background: var(--color-bg-card); color: var(--color-primary); border: 1.5rpx solid var(--color-primary); }
.btn-outline:active { background: var(--color-primary-light); }
.btn-ghost { background: transparent; color: var(--color-text-secondary); }
.btn-danger { background: var(--red); color: var(--color-bg-card); }
.btn-success { background: var(--color-success); color: var(--color-bg-card); }
.btn-sm { padding: 10rpx 24rpx; font-size: var(--font-sm); }
.btn-lg { padding: 22rpx 44rpx; font-size: var(--font-lg); width: 100%; }
.btn-block { display: flex; width: 100%; }
.btn-disabled { opacity: 0.5; pointer-events: none; }
.btn-muted { background: #9CA3AF; color: #fff; }

/* ===== 标签系统 ===== */
.tag {
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  font-size: var(--font-xs);
  font-weight: 600;
}
.tag-success { background: var(--color-success-bg); color: var(--color-success); }
.tag-warning { background: var(--orange-light); color: var(--orange); }
.tag-danger { background: var(--red-light); color: var(--red); }
.tag-info { background: var(--color-primary-light); color: var(--color-primary); }
.tag-muted { background: var(--gray-100); color: var(--gray-500); }

/* ===== 进度条 ===== */
.progress {
  height: 10rpx;
  background: var(--gray-200);
  border-radius: 5rpx;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  border-radius: 5rpx;
  transition: width var(--duration-slow) var(--easing);
}
.progress-fill.blue { background: var(--color-primary); }
.progress-fill.green { background: var(--color-success); }
.progress-fill.orange { background: var(--orange); }
.progress-fill.red { background: var(--red); }

/* ===== 列表项 ===== */
.list-item {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  background: var(--color-bg-card);
  gap: 16rpx;
  border-bottom: 1rpx solid var(--gray-100);
  transition: background var(--duration-fast);
}
.list-item:active { background: var(--gray-50); }
.list-item-icon { font-size: 40rpx; flex-shrink: 0; }
.list-item-content { flex: 1; min-width: 0; }
.list-item-title { font-size: var(--font-md); font-weight: 600; }
.list-item-desc { font-size: var(--font-xs); color: var(--color-text-secondary); margin-top: 4rpx; }
.list-item-arrow { font-size: 28rpx; color: var(--gray-400); }
.list-item-archived { background: var(--gray-50); opacity: 0.65; }

/* ===== 分区标题 ===== */
.section-header {
  padding: 24rpx 28rpx 12rpx;
  font-size: var(--font-sm);
  font-weight: 700;
  color: var(--gray-500);
  letter-spacing: 0.5rpx;
}

/* ===== 搜索栏 ===== */
.search-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 24rpx;
  margin: 16rpx 24rpx;
  background: var(--gray-100);
  border-radius: var(--radius-sm);
}
.search-bar-icon { font-size: 28rpx; color: var(--gray-400); }
.search-bar-input {
  flex: 1;
  border: none;
  background: transparent;
  font-size: var(--font-md);
  outline: none;
}
.search-bar-input::placeholder { color: var(--gray-400); }

/* ===== 双列网格 ===== */
.grid-2 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  padding: 0 24rpx;
  margin: 12rpx 0;
}
.grid-item {
  background: var(--color-bg-card);
  border-radius: var(--radius);
  padding: 28rpx;
  text-align: center;
  box-shadow: var(--shadow-sm);
  transition: transform var(--duration-fast);
}
.grid-item:active { transform: scale(0.97); }
.grid-item-icon { font-size: 44rpx; margin-bottom: 10rpx; }
.grid-item-title { font-size: var(--font-sm); font-weight: 700; }
.grid-item-desc { font-size: var(--font-xs); color: var(--color-text-secondary); margin-top: 6rpx; }

/* ===== 步骤指示器 ===== */
.steps {
  display: flex;
  align-items: center;
  gap: 0;
  overflow-x: auto;
  padding: 8rpx 0;
}
.step {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex-shrink: 0;
  font-size: var(--font-xs);
  color: var(--gray-400);
}
.step-circle {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-xs);
  font-weight: 700;
  border: 2rpx solid var(--gray-300);
  background: var(--color-bg-card);
  flex-shrink: 0;
}
.step.done .step-circle { background: var(--color-success); border-color: var(--color-success); color: var(--color-bg-card); }
.step.active .step-circle { background: var(--color-primary); border-color: var(--color-primary); color: var(--color-bg-card); }
.step-line { width: 28rpx; height: 2rpx; background: var(--gray-300); }
.step.done .step-line { background: var(--color-success); }

/* ===== 模式切换 ===== */
.mode-tabs {
  display: flex;
  background: var(--gray-100);
  border-radius: var(--radius-sm);
  padding: 4rpx;
  margin: 16rpx 24rpx;
}
.mode-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  border-radius: 6rpx;
  font-size: var(--font-sm);
  font-weight: 600;
  color: var(--gray-500);
  transition: all var(--duration) var(--easing);
}
.mode-tab.active { background: var(--color-bg-card); color: var(--color-primary); box-shadow: var(--shadow-sm); }

/* ===== 折叠面板 ===== */
.collapse-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  background: var(--color-bg-card);
  font-size: var(--font-md);
  font-weight: 600;
  border-bottom: 1rpx solid var(--gray-100);
}
.collapse-header .arrow {
  font-size: var(--font-xs);
  color: var(--gray-400);
  transition: transform var(--duration) var(--easing);
}
.collapse-header.open .arrow { transform: rotate(180deg); }
.collapse-body {
  display: none;
  padding: 20rpx 28rpx;
  background: var(--color-bg-card);
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  line-height: 2;
}
.collapse-body.open { display: block; }

/* ===== 锁区域 ===== */
.lock-section {
  background: var(--gray-50);
  border: 2rpx dashed var(--gray-300);
  border-radius: var(--radius);
  padding: 36rpx 28rpx;
  text-align: center;
  margin: 16rpx 24rpx;
}
.lock-icon { font-size: 52rpx; margin-bottom: 12rpx; }
.lock-title { font-size: var(--font-md); font-weight: 700; color: var(--gray-600); margin-bottom: 6rpx; }
.lock-desc { font-size: var(--font-xs); color: var(--gray-500); margin-bottom: 16rpx; }

/* ===== 政策卡片 ===== */
.policy-card {
  background: var(--color-bg-card);
  border-radius: var(--radius);
  padding: 20rpx 24rpx;
  margin: 0 24rpx 12rpx;
  box-shadow: var(--shadow-sm);
  border-left: 4rpx solid var(--gray-200);
}
.policy-card.urgent { border-left-color: var(--red); }
.policy-card.important { border-left-color: var(--orange); }
.policy-date { font-size: var(--font-xs); color: var(--gray-400); }
.policy-title { font-size: var(--font-md); font-weight: 600; margin: 6rpx 0; }
.policy-impact { font-size: var(--font-xs); color: var(--color-text-secondary); }

/* ===== 归档卡片 ===== */
.archive-banner {
  background: var(--gradient-success);
  color: var(--color-bg-card);
  padding: 32rpx;
  margin: 16rpx 24rpx;
  border-radius: var(--radius);
  text-align: center;
}
.archive-icon { font-size: 60rpx; margin-bottom: 12rpx; }
.archive-title { font-size: var(--font-lg); font-weight: 800; margin-bottom: 6rpx; }
.archive-desc { font-size: var(--font-sm); opacity: 0.85; }

/* ===== 模态弹窗 ===== */
.modal-overlay {
  position: fixed;
  top: 0; left: 0;
  width: 100%; height: 100%;
  background: rgba(0,0,0,0.4);
  z-index: var(--z-modal);
  display: flex;
  align-items: flex-end;
}
.modal-sheet {
  background: var(--color-bg-card);
  border-radius: 28rpx 28rpx 0 0;
  width: 100%;
  max-height: 75vh;
  overflow-y: auto;
  padding: 16rpx 0 36rpx;
  animation: slideUp var(--duration-slow) var(--easing);
}
@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}
.modal-handle {
  width: 52rpx;
  height: 6rpx;
  background: var(--gray-300);
  border-radius: 3rpx;
  margin: 12rpx auto 20rpx;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
}
.empty-icon { font-size: 80rpx; opacity: 0.4; }
.empty-text { font-size: var(--font-md); color: var(--color-text-muted); margin-top: 16rpx; }

/* ===== 底部安全区 ===== */
.safe-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* ===== 动画 ===== */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}
.fade-in { animation: fadeIn var(--duration-slow) var(--easing); }

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}
.pulse { animation: pulse 2s infinite; }

@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}
.skeleton-line {
  height: 80rpx;
  background: linear-gradient(90deg, var(--gray-100) 25%, var(--gray-50) 50%, var(--gray-100) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: var(--radius-sm);
  margin-bottom: 16rpx;
}

/* ===== 骨架屏 (Skeleton) ===== */
.skeleton-card {
  padding: 24rpx;
  margin: 16rpx 24rpx;
  background: var(--color-bg-card);
  border-radius: var(--radius);
}
.skeleton-avatar {
  width: 72rpx; height: 72rpx;
  border-radius: 50%;
  background: var(--gray-100);
  animation: pulse 1.5s infinite;
}
.skeleton-line-sm {
  height: 24rpx;
  width: 60%;
  background: var(--gray-100);
  border-radius: 4rpx;
  animation: pulse 1.5s infinite;
  margin: 8rpx 0;
}
.skeleton-line-md {
  height: 32rpx;
  width: 80%;
  background: var(--gray-100);
  border-radius: 4rpx;
  animation: pulse 1.5s infinite;
  margin: 8rpx 0;
}

/* ===== 添加提醒 FAB ===== */
.add-fab {
  position: fixed;
  bottom: 140rpx;
  left: 28rpx;
  z-index: var(--z-sticky);
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: var(--color-primary);
  color: var(--color-bg-card);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  box-shadow: 0 6rpx 24rpx rgba(26,115,232,0.35);
  transition: transform var(--duration-fast);
}
.add-fab:active { transform: scale(0.9); }

/* ===== 回到顶部按钮 ===== */
.scroll-top-btn {
  position: fixed;
  bottom: 300rpx;
  right: 28rpx;
  z-index: var(--z-sticky);
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(26,115,232,0.85);
  color: var(--color-bg-card);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  box-shadow: 0 4rpx 16rpx rgba(26,115,232,0.3);
}

/* ===== 固定底栏 ===== */
.fixed-bottom {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: var(--color-bg-card);
  border-top: 1rpx solid var(--gray-100);
  z-index: var(--z-sticky);
  box-shadow: 0 -2rpx 8rpx rgba(0,0,0,0.04);
}

/* ===== 横幅通知 ===== */
.banner {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 24rpx;
  margin: 16rpx 24rpx;
  border-radius: var(--radius-sm);
  font-size: var(--font-sm);
  font-weight: 500;
}
.banner--info { background: var(--color-info-bg); color: var(--color-info); }
.banner--success { background: var(--color-success-bg); color: var(--color-success); }
.banner--warning { background: var(--color-warning-bg); color: var(--color-warning); }
.banner--error { background: var(--color-error-bg); color: var(--color-error); }

/* ===== 分隔线 ===== */
.divider {
  height: 1rpx;
  background: var(--gray-100);
  margin: 0 24rpx;
}
.divider--thick {
  height: 8rpx;
  background: var(--gray-100);
  margin: 0;
}

/* ===== 计数徽标 ===== */
.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  border-radius: 16rpx;
  background: var(--red);
  color: var(--color-bg-card);
  font-size: 20rpx;
  font-weight: 700;
}
.badge--dot {
  min-width: 16rpx;
  width: 16rpx;
  height: 16rpx;
  padding: 0;
}
