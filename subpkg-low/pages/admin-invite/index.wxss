/* subpkg-low/pages/admin-invite/index.wxss */

.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
  box-sizing: border-box;
}

/* ===== 概览 ===== */
.stats-grid {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.stat-card {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  text-align: center;
}

.stat-num {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.stat-num.green {
  color: #52c41a;
}
.stat-num.gray {
  color: #ccc;
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

.rate-bar {
  margin-bottom: 32rpx;
}

.rate-text {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
  display: block;
}

.rate-track {
  height: 12rpx;
  background: #eee;
  border-radius: 6rpx;
  overflow: hidden;
}

.rate-fill {
  height: 100%;
  background: #1a73e8;
  border-radius: 6rpx;
  transition: width 0.3s;
}

/* ===== Tabs ===== */
.tabs {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 8rpx;
  margin-bottom: 24rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  font-size: 28rpx;
  color: #666;
  border-radius: 12rpx;
}

.tab.active {
  background: #1a73e8;
  color: #fff;
  font-weight: 600;
}

.tab-content {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

/* ===== 表单 ===== */
.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background: #f7f8fa;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #1a1a1a;
  box-sizing: border-box;
}

.form-picker {
  width: 100%;
  height: 80rpx;
  background: #f7f8fa;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #1a1a1a;
  line-height: 80rpx;
  box-sizing: border-box;
}

/* ===== 按钮 ===== */
.btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  padding: 0;
  margin-bottom: 16rpx;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: #1a73e8;
  color: #fff;
}

.btn-primary[disabled] {
  background: #a0c4f0;
}

.btn-outline {
  background: #fff;
  color: #1a73e8;
  border: 2rpx solid #1a73e8;
}

.btn-outline[disabled] {
  border-color: #ccc;
  color: #ccc;
}

.btn-danger {
  background: #fff;
  color: #ff4d4f;
  border: 2rpx solid #ff4d4f;
  width: auto;
  padding: 0 32rpx;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 26rpx;
}

.btn-sm {
  width: auto;
  padding: 0 32rpx;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 26rpx;
}

/* ===== 生成结果 ===== */
.result-box {
  margin-top: 24rpx;
}

.result-header {
  margin-bottom: 16rpx;
}

.result-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.result-warn {
  display: block;
  font-size: 22rpx;
  color: #ff4d4f;
  margin-top: 4rpx;
}

.code-list {
  max-height: 400rpx;
  background: #f7f8fa;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
}

.code-item {
  font-family: monospace;
  font-size: 28rpx;
  padding: 8rpx 0;
  color: #1a73e8;
  border-bottom: 1rpx solid #eee;
}

.code-item:last-child {
  border-bottom: none;
}

/* ===== 查询结果 ===== */
.search-result {
  margin-top: 24rpx;
  background: #f7f8fa;
  border-radius: 12rpx;
  padding: 24rpx;
}

.result-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #eee;
}

.result-row:last-child {
  border-bottom: none;
}

.r-label {
  font-size: 26rpx;
  color: #999;
}

.r-value {
  font-size: 26rpx;
  color: #1a1a1a;
  font-weight: 500;
}

.r-value.green {
  color: #52c41a;
}

/* ===== 熔断 ===== */
.kill-switch {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
}

.switch-label {
  font-size: 28rpx;
  color: #1a1a1a;
  font-weight: 500;
}
