.container {
  padding: 24rpx;
}
.header {
  text-align: center;
  padding: 40rpx 0 32rpx;
}
.header__title {
  font-size: 36rpx;
  font-weight: 800;
  color: #1a1a1a;
  display: block;
}
.header__sub {
  font-size: 26rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}
.path-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.path-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}
.path-card:active {
  background: #f5f5f5;
}
.path-card__left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
}
.path-card__icon {
  font-size: 40rpx;
}
.path-card__name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a1a;
  display: block;
}
.path-card__desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
  display: block;
}
.path-card__arrow {
  font-size: 36rpx;
  color: #ccc;
}
