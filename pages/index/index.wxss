/* 住港伴 v4 — 流程控中枢样式 */

/* ===== 顶部 ===== */
.header-left {
  flex: 1;
}
.header-title {
  font-size: var(--font-xl);
  font-weight: 700;
  display: block;
}
.header-sub {
  font-size: var(--font-xs);
  opacity: 0.85;
  display: block;
  margin-top: 6rpx;
}

/* ===== 标签切换 ===== */
.hub-tabs {
  display: flex;
  background: var(--color-bg-card);
  padding: 4rpx;
  margin: 16rpx 24rpx;
  border-radius: var(--radius-sm);
  box-shadow: var(--shadow-sm);
}
.hub-tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 18rpx 8rpx;
  border-radius: 6rpx;
  font-size: var(--font-sm);
  font-weight: 600;
  color: var(--gray-500);
  transition: all 0.2s;
}
.hub-tab.active {
  background: var(--color-bg-card);
  color: var(--color-primary);
  box-shadow: var(--shadow-sm);
}
.hub-tab-icon {
  font-size: 24rpx;
}
.hub-tab-label {
  font-size: var(--font-sm);
}

.tab-content {
  padding-bottom: 40rpx;
}

/* ===== 流程英雄卡片 ===== */
.process-hero {
  background: linear-gradient(135deg, var(--color-primary-dark), var(--color-primary));
  color: var(--color-bg-card);
  padding: 32rpx 28rpx;
  border-radius: var(--radius);
  margin: 16rpx 24rpx;
  box-shadow: var(--shadow-md);
}
.hero-label {
  font-size: var(--font-xs);
  opacity: 0.8;
  display: block;
  margin-bottom: 6rpx;
}
.hero-title {
  font-size: var(--font-xl);
  font-weight: 800;
  display: block;
  margin-bottom: 20rpx;
}
.hero-footer {
  margin-top: 16rpx;
  font-size: var(--font-xs);
  opacity: 0.9;
}
.hero-stage {
  display: block;
}

/* 流程步骤覆盖（白色主题下的步骤） */
.process-hero .step {
  color: rgba(255, 255, 255, 0.7);
}
.process-hero .step.pending .step-circle {
  border-color: rgba(255, 255, 255, 0.3);
  background: transparent;
}
.process-hero .step.current .step-circle {
  background: var(--color-bg-card);
  border-color: var(--color-bg-card);
  color: var(--color-primary);
}
.process-hero .step.done .step-circle {
  background: rgba(255, 255, 255, 0.3);
  border-color: rgba(255, 255, 255, 0.4);
  color: var(--color-bg-card);
}
.process-hero .step-line {
  background: rgba(255, 255, 255, 0.25);
}
.process-hero .step.done .step-line {
  background: rgba(255, 255, 255, 0.5);
}
.process-hero .step-name {
  font-size: 18rpx;
  white-space: nowrap;
}

/* 无流程 */
.hero-empty {
  text-align: center;
  padding: 56rpx 32rpx;
}
.hero-empty-icon {
  font-size: 72rpx;
  display: block;
  margin-bottom: 16rpx;
}
.hero-empty-title {
  font-size: var(--font-lg);
  font-weight: 700;
  display: block;
  margin-bottom: 8rpx;
}
.hero-empty-desc {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  display: block;
  margin-bottom: 28rpx;
}

/* 材料清单 */
.material-list {
  margin-bottom: 20rpx;
}
.material-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--gray-100);
  gap: 12rpx;
}
.material-item:last-child {
  border-bottom: none;
}
.material-status {
  font-size: 24rpx;
  flex-shrink: 0;
}
.material-name {
  flex: 1;
  font-size: var(--font-sm);
}
.material-action {
  font-size: var(--font-xs);
  color: var(--color-primary);
  font-weight: 500;
}
.material-action.done {
  color: var(--gray-400);
}

.material-progress {
  margin-top: 8rpx;
}
.progress-label {
  font-size: var(--font-xs);
  color: var(--color-text-secondary);
  display: block;
  margin-bottom: 8rpx;
}

/* 快捷操作 */
.quick-row {
  display: flex;
  gap: 16rpx;
  padding: 0 24rpx;
  margin-bottom: 12rpx;
}
.flex-1 {
  flex: 1;
}

/* 里程碑卡片 */
.milestone-card {
  border: 2rpx dashed var(--color-primary);
  background: var(--color-primary-light);
}
.milestone-divider {
  border-top: 1rpx dashed var(--color-primary);
  margin: 20rpx 0;
  opacity: 0.4;
}
.milestone-hint {
  font-size: var(--font-xs);
  color: var(--gray-500);
  display: block;
  margin-bottom: 16rpx;
}
.btn-green-outline {
  border-color: var(--color-success) !important;
  color: var(--color-success) !important;
}

/* 帮助卡片 */
.help-card {
  background: var(--gray-50);
}
.help-line {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  display: block;
}
.help-note {
  font-size: var(--font-xs);
  color: var(--gray-400);
  display: block;
  margin-top: 6rpx;
}

/* ===== 攻略书 ===== */
.guide-rec-card {
  cursor: pointer;
}
.guide-rec-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.guide-rec-icon {
  font-size: 44rpx;
  flex-shrink: 0;
}
.guide-rec-info {
  flex: 1;
  min-width: 0;
}
.guide-rec-title {
  font-size: var(--font-md);
  font-weight: 600;
  display: block;
}
.guide-rec-desc {
  font-size: var(--font-xs);
  color: var(--color-text-secondary);
  display: block;
  margin-top: 4rpx;
}
.guide-rec-tag {
  flex-shrink: 0;
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
  font-size: var(--font-xs);
  color: var(--color-primary);
  background: var(--color-primary-light);
  font-weight: 500;
}

/* ===== 效率宝 ===== */
.precheck-intro {
  text-align: center;
  padding: 40rpx 28rpx;
}
.precheck-icon {
  font-size: 64rpx;
  display: block;
  margin-bottom: 12rpx;
}
.precheck-title {
  font-size: var(--font-xl);
  font-weight: 700;
  display: block;
  margin-bottom: 8rpx;
}
.precheck-desc {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  display: block;
  line-height: 1.8;
}

.precheck-insufficient-icon {
  font-size: 64rpx;
  display: block;
  text-align: center;
  margin-bottom: 12rpx;
}
.precheck-insufficient-title {
  font-size: var(--font-lg);
  font-weight: 700;
  display: block;
  text-align: center;
  margin-bottom: 8rpx;
}
.precheck-insufficient-desc {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  display: block;
  text-align: center;
  margin-bottom: 24rpx;
}

.feature-list {
  padding: 8rpx 0;
}
.feature-item {
  display: block;
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  padding: 10rpx 0;
  line-height: 1.6;
}

.privacy-notice {
  background: var(--color-success-bg);
  border: 1rpx solid var(--color-success);
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.privacy-notice-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}
.privacy-notice-text {
  font-size: var(--font-xs);
  color: var(--color-success);
  flex: 1;
}

/* ===== 模态弹窗 ===== */
.modal-title {
  font-size: var(--font-lg);
  font-weight: 700;
  padding: 0 28rpx;
  margin-bottom: 16rpx;
}
.modal-body {
  display: flex;
  gap: 16rpx;
  padding: 0 28rpx 24rpx;
}
.upload-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 24rpx 16rpx;
  background: var(--gray-50);
  border-radius: var(--radius);
  border: 1rpx solid var(--gray-200);
}
.upload-option:active {
  background: var(--gray-100);
}
.upload-option-icon {
  font-size: 44rpx;
}
.upload-option-label {
  font-size: var(--font-xs);
  color: var(--color-text-secondary);
}

.archive-confirm {
  text-align: center;
  padding: 20rpx 28rpx 32rpx;
}
.archive-confirm-icon {
  font-size: 72rpx;
  display: block;
  margin-bottom: 12rpx;
}
.archive-confirm-title {
  font-size: var(--font-xl);
  font-weight: 700;
  display: block;
  margin-bottom: 8rpx;
}
.archive-confirm-desc {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  display: block;
  margin-bottom: 28rpx;
}
.archive-confirm-btns {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
