<view class="container">
  <view class="page-header">
    <view><text class="header-title">数据库管理</text><text class="header-sub">云端同步 · 数据迭代 · 备份管理</text></view>
  </view>
  <view class="card">
    <view class="card-title">📡 同步状态</view>
    <view class="card-row"><text class="card-row-label">云端连接</text><text class="tag tag-success">已连接</text></view>
    <view class="card-row"><text class="card-row-label">上次同步</text><text>{{lastSyncTime ? '刚刚' : '从未'}}</text></view>
    <view class="card-row"><text class="card-row-label">同步状态</text><text class="tag {{syncStatus === 'synced' ? 'tag-success' : syncStatus === 'syncing' ? 'tag-info' : 'tag-muted'}}">{{syncStatus === 'synced' ? '已同步' : syncStatus === 'syncing' ? '同步中' : '待同步'}}</text></view>
  </view>
  <view class="card">
    <view class="card-title">☁️ 云端统计</view>
    <view style="display:flex;justify-content:space-around;text-align:center">
      <view><text style="font-size:var(--font-xl);font-weight:700;color:var(--blue);display:block">{{cloudStats.documents || '--'}}</text><text style="font-size:var(--font-xs);color:var(--gray-500)">证件</text></view>
      <view><text style="font-size:var(--font-xl);font-weight:700;color:var(--green);display:block">{{cloudStats.reminders || '--'}}</text><text style="font-size:var(--font-xs);color:var(--gray-500)">提醒</text></view>
      <view><text style="font-size:var(--font-xl);font-weight:700;color:var(--orange);display:block">{{cloudStats.processes || '--'}}</text><text style="font-size:var(--font-xs);color:var(--gray-500)">流程</text></view>
    </view>
  </view>
  <view class="section-header">⚡ 数据操作</view>
  <view class="card" style="padding:0">
    <view class="list-item" wx:for="{{operations}}" wx:key="id" bindtap="handleOperation" data-op="{{item.id}}">
      <text class="list-item-icon">{{item.icon}}</text><view class="list-item-content"><text class="list-item-title">{{item.title}}</text><text class="list-item-desc">{{item.desc}}</text></view><text class="list-item-arrow">›</text>
    </view>
  </view>
  <view class="card" style="margin-top:16rpx">
    <view class="card-title">🤖 AI模型配置</view>
    <text style="font-size:var(--font-sm);color:var(--color-text-secondary);display:block;margin-bottom:16rpx">当前模型：DeepSeek V4 (deepseek-chat)</text>
    <button class="btn btn-outline btn-block" bindtap="updateAIModel">更新模型配置</button>
  </view>
  <view class="card" style="background:var(--gray-50);margin-top:16rpx">
    <text style="font-size:var(--font-sm);color:var(--gray-500);display:block;line-height:1.8">💡 数据库持续迭代机制：· 每次打开应用自动增量同步 · 证件/提醒/流程数据实时云端备份 · AI对话历史本地存储（不上云） · 敏感数据脱敏后加密传输 · 支持手动全量同步</text>
  </view>
  <view class="safe-bottom"></view>
</view>
