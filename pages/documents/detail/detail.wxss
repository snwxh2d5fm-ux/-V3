/* pages/documents/detail/detail.wxss */
@import '../../../app.wxss';

.page {
  min-height: 100vh;
  background: var(--gray-50);
  padding-bottom: 40rpx;
}

/* ===== 图片展示区 ===== */
.image-area {
  position: relative;
  margin: 20rpx 24rpx;
  border-radius: 20rpx;
  overflow: hidden;
  background: var(--gray-900);
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.12);
}
.detail-image {
  width: 100%;
  height: 500rpx;
  display: block;
}
.image-tap-hint {
  position: absolute;
  bottom: 16rpx;
  right: 20rpx;
  background: rgba(0,0,0,0.55);
  color: #fff;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
}

/* 顶部操作栏 */
.header-actions {
  display: flex;
  padding: 20rpx;
  gap: 16rpx;
}
.action-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background: var(--card-bg, #fff);
  border-radius: 20rpx;
  font-size: 26rpx;
  color: var(--text-secondary, #5f6368);
  border: 1rpx solid var(--border, var(--gray-200));
}

/* 证件信息卡片 */
.doc-info {
  margin: 16rpx 24rpx;
  padding: 32rpx;
}
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}
.card-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text, #202124);
}
.status-badge {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
}
.status-badge.active { background: var(--color-success-bg); color: var(--color-success); }
.status-badge.archived { background: var(--color-warning-bg); color: var(--color-warning); }

/* OCR字段 */
.section-title {
  font-size: 28rpx;
  color: var(--text-secondary, #5f6368);
  display: block;
  margin-bottom: 16rpx;
}
.field-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border, var(--gray-200));
}
.field-row:last-child { border-bottom: none; }
.field-label {
  width: 160rpx;
  font-size: 28rpx;
  color: var(--text-secondary, #5f6368);
}
.field-value {
  flex: 1;
  font-size: 28rpx;
  color: var(--text, #202124);
}
.field-value.pii {
  color: var(--color-warning);
  font-family: monospace;
}
.field-pii-tag {
  margin-left: 8rpx;
  font-size: 24rpx;
}

/* 时间 */
.doc-time {
  margin-top: 24rpx;
  font-size: 24rpx;
  color: var(--gray-400);
  display: flex;
  gap: 24rpx;
}

/* 操作区 */
.actions {
  margin: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.action-item {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  background: var(--card-bg, #fff);
  border-radius: 16rpx;
  font-size: 30rpx;
  border: 1rpx solid var(--border, var(--gray-200));
}
.action-item.danger {
  color: var(--color-error);
  border-color: #FECACA;
}
.action-item::after { border: none; }

/* 隐私面板 */
.privacy-panel {
  position: fixed;
  inset: 0;
  z-index: 1000;
  display: none;
}
.privacy-panel.show { display: block; }
.panel-overlay {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.4);
}
.panel-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--card-bg, #fff);
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  max-height: 70vh;
  overflow-y: auto;
}
.panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}
.panel-title { font-size: 34rpx; font-weight: 600; }
.panel-close { font-size: 36rpx; color: #999; padding: 8rpx; }

.privacy-score {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: var(--color-info-bg);
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}
.score-label { font-size: 28rpx; color: #5f6368; }
.score-ring {
  text-align: center;
}
.score-number { font-size: 48rpx; font-weight: 700; color: var(--color-primary); }
.score-desc { font-size: 24rpx; color: var(--color-primary); display: block; }

.privacy-items { margin-bottom: 24rpx; }
.privacy-item {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--gray-100);
}
.item-label { font-size: 28rpx; color: #5f6368; }
.item-value { font-size: 28rpx; color: var(--color-text); }
.item-value.green { color: var(--color-success); }

.panel-footer { text-align: center; margin-bottom: 20rpx; }
.footer-text { font-size: 24rpx; color: #999; }

.level-btn {
  background: var(--color-primary);
  color: #fff;
  border-radius: 16rpx;
  font-size: 30rpx;
  padding: 24rpx;
  text-align: center;
}
.level-btn::after { border: none; }

.empty-ocr {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 28rpx;
}
