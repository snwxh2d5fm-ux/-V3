<!-- 住港伴 v3 — 添加证件页 -->
<view class="container">

  <!-- ===== Step 1: 选择输入方式 ===== -->
  <block wx:if="{{step === 1}}">
    <view class="page-header">
      <text class="page-header-title">添加证件</text>
      <text class="page-header-sub">选择一种方式录入证件信息</text>
    </view>

    <view class="input-modes">
      <view class="input-mode-card" bindtap="onTapCamera">
        <text class="input-mode-icon">📷</text>
        <text class="input-mode-title">拍照识别</text>
        <text class="input-mode-desc">自动识别证件关键信息</text>
      </view>
      <view class="input-mode-card" bindtap="onTapAlbum">
        <text class="input-mode-icon">🖼️</text>
        <text class="input-mode-title">从相册选择</text>
        <text class="input-mode-desc">选择已有照片进行识别</text>
      </view>
      <view class="input-mode-card" bindtap="onTapManual">
        <text class="input-mode-icon">✍️</text>
        <text class="input-mode-title">手动录入</text>
        <text class="input-mode-desc">直接填写证件信息</text>
      </view>
    </view>

    <view class="privacy-notice">
      <text>🔒 证件照片和识别数据仅存储在您的设备本地，不上传服务器</text>
    </view>
  </block>

  <!-- ===== Step 2: 图片预览 + OCR处理中 ===== -->
  <block wx:if="{{step === 2}}">
    <view class="page-header">
      <text class="page-header-title">识别中...</text>
      <text class="page-header-sub">{{ocrProcessing ? 'AI正在分析证件信息' : '处理完成'}}</text>
    </view>

    <!-- 图片预览 -->
    <view class="image-preview" wx:if="{{imagePath}}">
      <image src="{{imagePath}}" mode="aspectFit" class="preview-img" aria-label="证件图片预览" />
    </view>

    <!-- OCR处理指示器 -->
    <view class="ocr-status" wx:if="{{ocrProcessing}}">
      <view class="ocr-spinner"></view>
      <text class="ocr-status-text">正在识别证件信息...</text>
      <text class="ocr-status-sub">请稍候，通常需要 2-5 秒</text>
    </view>

    <!-- 隐私说明：提升信任度 -->
    <view class="privacy-inline" wx:if="{{ocrProcessing}}">
      <view class="privacy-inline__icon">🔒</view>
      <view class="privacy-inline__body">
        <text class="privacy-inline__title">你的隐私，我们守护</text>
        <text class="privacy-inline__desc">证件照片仅用于本地识别，上传云端后<text style="font-weight:700;color:#059669">识别完成即刻删除</text>，不留存任何副本</text>
      </view>
    </view>

    <!-- 质量提示 -->
    <view class="quality-warnings" wx:if="{{qualityIssues.length > 0}}">
      <text class="quality-title">⚠️ 质量提示</text>
      <text class="quality-item" wx:for="{{qualityIssues}}" wx:key="*this">{{item}}</text>
    </view>
  </block>

  <!-- ===== Step 3: OCR结果确认 ===== -->
  <block wx:if="{{step === 3}}">
    <view class="page-header">
      <text class="page-header-title">确认信息</text>
      <text class="page-header-sub">识别类型: {{docTypeLabel}} · 置信度 {{confidencePercent}}%</text>
    </view>

    <!-- 极低置信度横幅：引导手动填写 -->
    <view class="low-confidence-banner" wx:if="{{confidence < 0.3}}">
      <text class="low-confidence-icon">⚠️</text>
      <view class="low-confidence-body">
        <text class="low-confidence-title">AI无法可靠识别此证件</text>
        <text class="low-confidence-desc">建议点击下方「手动填写」按钮，自行录入证件信息，确保数据准确。</text>
      </view>
    </view>

    <!-- 图片缩略图 -->
    <view class="image-thumb" wx:if="{{imagePath}}">
      <image src="{{imagePath}}" mode="aspectFill" class="thumb-img" aria-label="识别证件缩略图" />
      <view class="thumb-badge">📷</view>
    </view>

    <!-- 置信度进度条 -->
    <view class="card" style="margin-top:16rpx">
      <view class="card-row">
        <text class="card-row-label">AI识别置信度</text>
        <text style="font-weight:700;color:{{confidence >= 0.7 ? 'var(--green)' : confidence >= 0.4 ? 'var(--orange)' : 'var(--red)'}}">{{confidencePercent}}%</text>
      </view>
      <view class="progress">
        <view class="progress-fill {{confidence >= 0.7 ? 'green' : confidence >= 0.4 ? 'orange' : 'red'}}" style="width:{{confidencePercent}}%"></view>
      </view>
      <view class="confidence-hint" wx:if="{{confidence < 0.7}}">
        <text>⚠️</text>
        <text>AI识别置信度较低，建议核对并修正下方字段</text>
      </view>
    </view>

    <!-- OCR字段列表 -->
    <view class="card" style="padding:0;margin-top:16rpx">
      <view class="section-header" style="padding:24rpx 28rpx 14rpx">📋 识别到的字段</view>
      <view class="field-row" wx:for="{{ocrFieldList}}" wx:key="key">
        <text class="field-label">{{item.label}}</text>
        <input class="field-input" value="{{item.value}}" bindinput="onFieldChange" data-field="{{item.key}}" placeholder="未识别" />
      </view>
    </view>

    <!-- 操作按钮 -->
    <view style="display:flex;gap:16rpx;padding:0 24rpx;margin-top:20rpx">
      <button class="btn btn-outline btn-flex" bindtap="retakePhoto">🔄 重拍</button>
      <button class="btn btn-outline btn-flex" bindtap="switchToManual">✍️ 手动填写</button>
    </view>
    <view style="display:flex;gap:16rpx;padding:0 24rpx;margin-top:12rpx">
      <button class="btn btn-outline btn-flex" style="border-color:#DC2626;color:#DC2626" bindtap="cancelAdd">✕ 取消</button>
      <button class="btn btn-primary btn-flex" bindtap="confirmAndProceed">✅ 确认无误</button>
    </view>
  </block>

  <!-- ===== Step 4: 选择分类 + 确认保存 ===== -->
  <block wx:if="{{step === 4}}">
    <view class="page-header">
      <text class="page-header-title">{{inputMode === 'manual' ? '手动录入' : '选择分类'}}</text>
      <text class="page-header-sub">请选择证件所属分类</text>
    </view>

    <!-- 所属人选择 -->
    <view class="owner-select">
      <text class="owner-select__label">所属人</text>
      <view class="owner-select__options">
        <view class="owner-opt {{ownerType === item.value ? 'owner-opt--active' : ''}}"
              wx:for="{{ownerOptions}}" wx:key="value"
              bindtap="selectOwner" data-value="{{item.value}}">
          <text class="owner-opt__icon">{{item.icon}}</text>
          <text class="owner-opt__label">{{item.label}}</text>
          <view class="owner-opt__check" wx:if="{{ownerType === item.value}}">✓</view>
        </view>
      </view>
      <input wx:if="{{ownerType === 'child'}}" 
             class="owner-name-input" 
             value="{{ownerName}}" 
             bindinput="onOwnerNameInput"
             placeholder="输入子女姓名（如：小明）" />
    </view>

    <!-- 分类选择 -->
    <view class="category-grid">
      <view class="category-card {{docCategory === item.value ? 'selected' : ''}}"
            wx:for="{{categories}}" wx:key="value"
            bindtap="selectCategory" data-value="{{item.value}}">
        <text class="category-icon">{{item.icon}}</text>
        <text class="category-label">{{item.label}}</text>
        <text class="category-desc">{{item.desc}}</text>
        <view class="category-check" wx:if="{{docCategory === item.value}}">✓</view>
      </view>
    </view>

    <!-- 手动录入表单（手动模式时显示） -->
    <view class="card" wx:if="{{inputMode === 'manual'}}" style="margin-top:20rpx">
      <view class="section-header" style="padding:0 0 16rpx">📝 证件信息</view>
      <view class="field-row">
        <text class="field-label">证件名称</text>
        <input class="field-input" value="{{manualForm.name}}" bindinput="onManualChange" data-field="name" placeholder="例如: 中华人民共和国身份证" />
      </view>
      <view class="field-row">
        <text class="field-label">证件号码</text>
        <input class="field-input" value="{{manualForm.docNumber}}" bindinput="onManualChange" data-field="docNumber" placeholder="证件编号" />
      </view>
      <view class="field-row">
        <text class="field-label">有效期起</text>
        <input class="field-input" value="{{manualForm.validFrom}}" bindinput="onManualChange" data-field="validFrom" placeholder="YYYY-MM-DD" />
      </view>
      <view class="field-row">
        <text class="field-label">有效期至</text>
        <input class="field-input" value="{{manualForm.validTo}}" bindinput="onManualChange" data-field="validTo" placeholder="YYYY-MM-DD" />
      </view>
      <view class="field-row">
        <text class="field-label">签发机关</text>
        <input class="field-input" value="{{manualForm.issuingAuthority}}" bindinput="onManualChange" data-field="issuingAuthority" placeholder="签发单位" />
      </view>
      <view class="field-row" style="border-bottom:none">
        <text class="field-label">备注</text>
        <input class="field-input" value="{{manualForm.notes}}" bindinput="onManualChange" data-field="notes" placeholder="补充说明（可选）" />
      </view>
    </view>

    <!-- OCR预填信息（OCR模式时显示） -->
    <view class="card" wx:if="{{inputMode !== 'manual' && ocrFieldList.length > 0}}" style="margin-top:20rpx">
      <view class="card-title">📋 已识别信息</view>
      <view class="card-row" wx:for="{{ocrFieldList}}" wx:key="key" wx:if="{{item.value}}">
        <text class="card-row-label">{{item.label}}</text>
        <text class="card-row-value">{{item.value}}</text>
      </view>
    </view>
    <!-- 无识别结果提示 -->
    <view class="ocr-empty-hint" wx:if="{{inputMode !== 'manual' && ocrFieldList.length === 0}}">
      <text>📷 AI未能识别到字段，请手动填写下方信息</text>
    </view>

    <!-- 保存按钮 -->
    <view style="padding:0 24rpx;margin-top:24rpx">
      <button class="btn btn-primary btn-lg {{saving ? 'btn-disabled' : ''}}" bindtap="confirmSave" disabled="{{saving || !docCategory}}">
        {{saving ? '保存中...' : '💾 保存证件'}}
      </button>
    </view>
  </block>

  <view class="safe-bottom"></view>

  <floating-ai visible="{{true}}" />
</view>
