<!-- 住港伴 v3 — 添加证件页 -->
<view class="container">

  <!-- ===== Step 1: 选择输入方式 ===== -->
  <block wx:if="{{step === 1}}">
    <view class="page-header">
      <text class="page-header-title">{{slotContext ? slotDocName : '添加证件'}}</text>
      <text class="page-header-sub">{{slotContext ? '按下方要求拍摄，系统自动质检' : '拍照前请阅读下方指引'}}</text>
    </view>

    <!-- 卡槽专属指引（从卡槽进入时） -->
    <view class="slot-guide-card" wx:if="{{slotContext && slotGuide}}">
      <view class="slot-guide__head">
        <text class="slot-guide__icon">{{slotGuide.icon}}</text>
        <text class="slot-guide__title">{{slotGuide.title}}</text>
      </view>
      <view class="slot-guide__items">
        <view class="slot-guide__item" wx:for="{{slotGuide.items}}" wx:key="*this">
          <text class="slot-guide__dot">●</text>
          <text>{{item}}</text>
        </view>
      </view>
      <view class="slot-guide__pii" wx:if="{{slotGuide.piiFields}}">
        <text class="pii-label">🔒 拍摄后将自动脱敏：</text>
        <text class="pii-fields">{{slotGuide.piiFields}}</text>
      </view>
      <view class="slot-guide__specimen" wx:if="{{slotGuide.specimen}}">
        <text class="specimen-icon">📋</text>
        <text class="specimen-text">标本参照：{{slotGuide.specimen}}</text>
      </view>

      <!-- R4+Bug#24: 卡槽专属动态线框示意图 — 脱敏案例库驱动 -->
      <view class="doc-wireframe" wx:if="{{slotContext && slotGuide}}">
        <view class="wf-card">
          <view class="wf-header">
            <view class="wf-logo-line"></view>
            <text class="wf-title">{{slotGuide.wfTitle || slotDocName || '证件参照'}}</text>
          </view>
          <view class="wf-body">
            <!-- 照片/图章区 (左侧，按需显示) -->
            <view class="wf-photo" wx:if="{{slotGuide.showPhoto !== false}}">
              <view class="wf-photo__frame"></view>
              <text class="wf-photo__tag">照片</text>
            </view>
            <!-- PII字段线框区 (动态，按 slotGuide.wfFields 渲染) -->
            <view class="wf-fields">
              <block wx:if="{{slotGuide.wfFields && slotGuide.wfFields.length > 0}}">
                <view class="wf-field" wx:for="{{slotGuide.wfFields}}" wx:key="label">
                  <view class="wf-line wf-line--{{item.width || 'mid'}}"></view>
                  <text class="wf-label">{{item.label}}</text>
                  <text class="wf-pii-tag" wx:if="{{item.pii}}">脱敏</text>
                </view>
              </block>
              <!-- 无专属字段时用默认 -->
              <block wx:else>
                <view class="wf-field">
                  <view class="wf-line wf-line--short"></view>
                  <text class="wf-label">姓名</text>
                  <text class="wf-pii-tag">脱敏</text>
                </view>
                <view class="wf-field">
                  <view class="wf-line wf-line--long"></view>
                  <text class="wf-label">证件号码</text>
                  <text class="wf-pii-tag">脱敏</text>
                </view>
                <view class="wf-field">
                  <view class="wf-line wf-line--mid"></view>
                  <text class="wf-label">有效期限</text>
                </view>
              </block>
            </view>
          </view>
          <!-- 底部印章区 (按需显示) -->
          <view class="wf-footer" wx:if="{{slotGuide.showSeal !== false}}">
            <view class="wf-seal"></view>
            <text class="wf-footer-label">发证机关印章</text>
          </view>
        </view>
        <view class="wf-ruler-tl"></view>
        <view class="wf-ruler-tr"></view>
        <view class="wf-ruler-bl"></view>
        <view class="wf-ruler-br"></view>
        <text class="wf-hint">请将证件对准四角标尺，确保边框完整、无裁切</text>
      </view>
    </view>

    <!-- 三模式按钮 -->
    <view class="input-modes">
      <view class="input-mode-card" bindtap="onTapCamera">
        <text class="input-mode-icon">📷</text>
        <text class="input-mode-title">拍照</text>
        <text class="input-mode-desc">拍摄证件照片</text>
      </view>
      <view class="input-mode-card" bindtap="onTapAlbum">
        <text class="input-mode-icon">🖼️</text>
        <text class="input-mode-title">相册</text>
        <text class="input-mode-desc">从相册中选择</text>
      </view>
      <view class="input-mode-card" bindtap="onTapManual">
        <text class="input-mode-icon">✍️</text>
        <text class="input-mode-title">手动录入</text>
        <text class="input-mode-desc">直接填写信息</text>
      </view>
    </view>

    <!-- Bug #2: 自由模式证件类型选择 (非卡槽入口) -->
    <view class="capture-guide" wx:if="{{!slotContext}}">
      <view class="capture-guide__title">📐 选择证件类型查看拍摄要求</view>
      <scroll-view class="doc-type-scroll" scroll-x enhanced show-scrollbar="{{false}}">
        <view class="doc-type-chip {{freeDocType === item.value ? 'active' : ''}}"
              wx:for="{{freeDocTypeOptions}}" wx:key="value"
              bindtap="onSelectFreeDocType" data-value="{{item.value}}">
          <text class="doc-type-chip__icon">{{item.icon}}</text>
          <text class="doc-type-chip__label">{{item.label}}</text>
        </view>
      </scroll-view>
    </view>

    <!-- Bug #2: 自由模式选中证件类型后的线框图+拍摄指引 -->
    <view class="doc-wireframe" wx:if="{{!slotContext && freeDocGuide}}">
      <view class="wf-card">
        <view class="wf-header">
          <view class="wf-logo-line"></view>
          <text class="wf-title">{{freeDocGuide.wfTitle || '证件参照'}}</text>
        </view>
        <view class="wf-body">
          <view class="wf-photo" wx:if="{{freeDocGuide.showPhoto !== false}}">
            <view class="wf-photo__frame"></view>
            <text class="wf-photo__tag">照片</text>
          </view>
          <view class="wf-fields">
            <view class="wf-field" wx:for="{{freeDocGuide.wfFields}}" wx:key="label">
              <view class="wf-line wf-line--{{item.width || 'mid'}}"></view>
              <text class="wf-label">{{item.label}}</text>
              <text class="wf-pii-tag" wx:if="{{item.pii}}">脱敏</text>
            </view>
          </view>
        </view>
        <view class="wf-footer" wx:if="{{freeDocGuide.showSeal !== false}}">
          <view class="wf-seal"></view>
          <text class="wf-footer-label">发证机关印章</text>
        </view>
      </view>
      <view class="wf-ruler-tl"></view>
      <view class="wf-ruler-tr"></view>
      <view class="wf-ruler-bl"></view>
      <view class="wf-ruler-br"></view>
      <!-- 自由模式拍摄要求列表 -->
      <view class="free-guide-items" wx:if="{{freeDocGuide.items && freeDocGuide.items.length > 0}}">
        <view class="free-guide-item" wx:for="{{freeDocGuide.items}}" wx:key="*this">
          <text class="free-guide-dot">●</text>
          <text>{{item}}</text>
        </view>
      </view>
      <text class="wf-hint">📐 请将证件对准四角标尺，确保边框完整、无裁切</text>
    </view>

    <!-- 通用拍摄要求（未选择证件类型时显示） -->
    <view class="capture-guide" wx:if="{{!slotContext && !freeDocGuide}}">
      <view class="capture-guide__title">📐 拍摄要求</view>
      <view class="capture-guide__list">
        <view class="capture-guide__item">
          <text class="capture-guide__icon">✅</text>
          <text>证件四角完整可见，无裁切</text>
        </view>
        <view class="capture-guide__item">
          <text class="capture-guide__icon">✅</text>
          <text>平放在深色桌面，正对拍摄</text>
        </view>
        <view class="capture-guide__item">
          <text class="capture-guide__icon">✅</text>
          <text>光线均匀，避免反光和阴影</text>
        </view>
        <view class="capture-guide__item">
          <text class="capture-guide__icon">✅</text>
          <text>文字清晰可读，不模糊</text>
        </view>
        <view class="capture-guide__item">
          <text class="capture-guide__icon">✅</text>
          <text>分辨率≥800×600，彩色拍摄</text>
        </view>
        <view class="capture-guide__item">
          <text class="capture-guide__icon">❌</text>
          <text>不要手持证件拍摄</text>
        </view>
        <view class="capture-guide__item">
          <text class="capture-guide__icon">❌</text>
          <text>不要使用复印件或屏幕截图</text>
        </view>
      </view>
      <text class="capture-guide__note">💡 点击上方证件类型查看专属拍摄要求。拍照后系统将自动检测照片质量。</text>
    </view>

    <view class="privacy-notice">
      <text>🔒 证件照片仅存储在您的设备本地，不上传服务器。该小程序帮助您做隐私预览、整理留存相册文档，避免照片误删。</text>
    </view>
  </block>

  <!-- ===== Step 2: 图片预览 + 质量检测 ===== -->
  <block wx:if="{{step === 2}}">
    <view class="page-header">
      <text class="page-header-title">图片预览</text>
      <text class="page-header-sub">确认照片清晰可用</text>
    </view>

    <!-- 证件面选择 (国徽面/人像面) -->
    <view class="side-selector" wx:if="{{imagePath}}">
      <view class="side-tab {{photoSide==='front'?'active':''}}" bindtap="onSwitchSide" data-side="front">
        <text>📷 人像面</text>
      </view>
      <view class="side-tab {{photoSide==='back'?'active':''}}" bindtap="onSwitchSide" data-side="back">
        <text>🏛 国徽面</text>
      </view>
    </view>

    <!-- 图片预览 + 脱敏遮罩 + 旋转样式 -->
    <view class="image-preview" wx:if="{{imagePath}}">
      <image src="{{imagePath}}" mode="aspectFit" class="preview-img" style="transform: rotate({{imageRotated}}deg)" aria-label="证件图片预览" />
      <view class="photo-side-tag">{{photoSide==='front'?'人像面':'国徽面'}}</view>
    </view>

    <!-- 双面状态指示 -->
    <view class="both-sides-status" wx:if="{{frontPhotoPath || backPhotoPath}}">
      <text class="{{frontPhotoPath?'done':''}}">{{frontPhotoPath?'✅ 人像面已拍':'☐ 人像面'}}</text>
      <text class="{{backPhotoPath?'done':''}}">{{backPhotoPath?'✅ 国徽面已拍':'☐ 国徽面'}}</text>
    </view>

    <!-- Bug #5: 旋转+扫描件工具栏 -->
    <view class="img-toolbar">
      <view class="img-tool" bindtap="onRotateImage">
        <text class="img-tool__icon">🔄</text>
        <text class="img-tool__label">旋转</text>
      </view>
      <view class="img-tool {{scanProcessing ? 'disabled' : ''}}" bindtap="onToggleScanMode">
        <text class="img-tool__icon">{{scanMode ? '📄' : '📋'}}</text>
        <text class="img-tool__label">{{scanMode ? '已增强' : '扫描件'}}</text>
      </view>
    </view>

    <!-- Bug #6: 质量检测结果 — 增强可见性 -->
    <view class="quality-card" wx:if="{{qualityResult}}">
      <view class="quality-header">
        <text class="quality-header__title">📊 照片质量检测</text>
        <text class="quality-header__status {{qualityResult.pass ? 'pass' : 'fail'}}">{{qualityResult.pass ? '✅ 通过' : '⚠️ 不通过'}}</text>
      </view>
      <view class="quality-score-row">
        <text class="quality-score-label">综合评分</text>
        <text class="quality-score quality-score--{{qualityResult.summary}}">{{qualityResult.summary}}</text>
      </view>
      <view class="quality-bar">
        <view class="quality-bar__fill quality-bar__fill--{{qualityResult.summary}}" style="width:{{qualityResult.score}}%"></view>
      </view>
      <text class="quality-score-hint">{{qualityResult.score}}/100 分 · {{qualityResult.dimensions.width}}×{{qualityResult.dimensions.height}}</text>
      <view class="quality-issue" wx:for="{{qualityResult.issues}}" wx:key="type">
        <text class="quality-issue__icon">{{item.severity === 'warning' ? '⚠️' : 'ℹ️'}}</text>
        <text class="quality-issue__msg">{{item.message}}</text>
      </view>
      <view class="quality-action" wx:if="{{!qualityResult.pass}}">
        <text class="quality-action__text">⬆️ 建议重新拍摄以获得更好的识别效果</text>
      </view>
    </view>

    <!-- Bug #6: 质量检测加载中/无结果时的提示 -->
    <view class="quality-card quality-card--pending" wx:if="{{!qualityResult}}">
      <text class="quality-pending__icon">⏳</text>
      <text class="quality-pending__text">正在检测照片质量...</text>
    </view>

    <!-- 操作按钮 -->
    <view class="action-row">
      <button class="btn btn-outline flex-1" bindtap="retakePhoto">🔄 重拍</button>
      <button class="btn btn-primary flex-1" bindtap="confirmImage">✓ 确认，下一步</button>
    </view>
    <view class="step-hint" wx:if="{{qualityResult && !qualityResult.pass}}">
      <text class="step-hint-txt">质量不通过时点击确认将弹出提醒</text>
    </view>
  </block>

  <!-- ===== Step 2.5: 证件对齐裁切 ===== -->
  <block wx:if="{{step === 2.5}}">
    <view class="page-header">
      <text class="page-header-title">对齐证件</text>
      <text class="page-header-sub">拖动/缩放图片，使证件边缘对齐框线</text>
    </view>

    <view class="crop-container">
      <!-- 半透明遮罩+框线 -->
      <view class="crop-mask crop-mask--top"></view>
      <view class="crop-mask crop-mask--bottom"></view>
      <view class="crop-mask crop-mask--left"></view>
      <view class="crop-mask crop-mask--right"></view>
      <!-- 证件框 -->
      <view class="crop-frame">
        <view class="crop-corner crop-corner--tl"></view>
        <view class="crop-corner crop-corner--tr"></view>
        <view class="crop-corner crop-corner--bl"></view>
        <view class="crop-corner crop-corner--br"></view>
      </view>

      <!-- 可移动缩放的图片区域 -->
      <movable-area class="crop-movable" scale-area="true">
        <movable-view class="crop-view" direction="all" scale="true" scale-min="0.5" scale-max="3"
          x="{{cropX}}" y="{{cropY}}" bindchange="onCropChange" bindscale="onCropScale">
          <image class="crop-img" src="{{imagePath}}" mode="widthFix" style="{{_rotateStyle}}" />
        </movable-view>
      </movable-area>
    </view>

    <!-- #7: 旋转+对齐操作按钮 -->
    <view class="crop-tools">
      <button class="crop-tool-btn" bindtap="rotateImage">↻ 旋转90°</button>
      <button class="crop-tool-btn" bindtap="retakePhoto">🔄 重拍</button>
      <button class="crop-tool-btn crop-tool-btn--primary" bindtap="confirmCrop">✓ 完成</button>
    </view>
    <text class="crop-hint">💡 旋转至正向 → 双指缩放 → 拖动对齐框线 → 确认</text>
  </block>

  <!-- ===== Step 3: 手动填写信息 ===== -->
  <block wx:if="{{step === 3}}">

    <!-- 操作按钮 -->
    <view style="display:flex;gap:16rpx;padding:0 24rpx;margin-top:20rpx">
      <button class="btn btn-outline btn-flex" bindtap="retakePhoto">🔄 重拍</button>
      <button class="btn btn-outline btn-flex" bindtap="switchToManual">✍️ 手动填写</button>
    </view>
    <view style="display:flex;gap:16rpx;padding:0 24rpx;margin-top:12rpx">
      <button class="btn btn-outline btn-flex" style="border-color:#DC2626;color:#DC2626" bindtap="cancelAdd">✕ 取消</button>
      <button class="btn btn-primary btn-flex" bindtap="confirmAndProceed">✅ 确认无误</button>
    </view>
  </block>

  <!-- ===== Step 4: 选择分类 + 确认保存 ===== -->
  <block wx:if="{{step === 4}}">
    <view class="page-header">
      <text class="page-header-title">{{inputMode === 'manual' ? '手动录入' : '选择分类'}}</text>
      <text class="page-header-sub">请选择证件所属分类</text>
    </view>

    <!-- 所属人选择 -->
    <view class="owner-select">
      <text class="owner-select__label">所属人</text>
      <view class="owner-select__options">
        <view class="owner-opt {{ownerType === item.value ? 'owner-opt--active' : ''}}"
              wx:for="{{ownerOptions}}" wx:key="value"
              bindtap="selectOwner" data-value="{{item.value}}">
          <text class="owner-opt__icon">{{item.icon}}</text>
          <text class="owner-opt__label">{{item.label}}</text>
          <view class="owner-opt__check" wx:if="{{ownerType === item.value}}">✓</view>
        </view>
      </view>
      <input wx:if="{{ownerType === 'child'}}" 
             class="owner-name-input" 
             value="{{ownerName}}" 
             bindinput="onOwnerNameInput"
             placeholder="输入子女姓名（如：小明）" />
    </view>

    <!-- 分类选择 -->
    <view class="category-grid">
      <view class="category-card {{docCategory === item.value ? 'selected' : ''}}"
            wx:for="{{categories}}" wx:key="value"
            bindtap="selectCategory" data-value="{{item.value}}">
        <text class="category-icon">{{item.icon}}</text>
        <text class="category-label">{{item.label}}</text>
        <text class="category-desc">{{item.desc}}</text>
        <view class="category-check" wx:if="{{docCategory === item.value}}">✓</view>
      </view>
    </view>

    <!-- 手动录入表单（手动模式时显示） -->
    <view class="card" wx:if="{{inputMode === 'manual'}}" style="margin-top:20rpx">
      <view class="section-header" style="padding:0 0 16rpx">📝 证件信息</view>
      <view class="field-row">
        <text class="field-label">证件名称</text>
        <input class="field-input" value="{{manualForm.name}}" bindinput="onManualChange" data-field="name" placeholder="例如: 中华人民共和国身份证" />
      </view>
      <view class="field-row">
        <text class="field-label">证件号码</text>
        <input class="field-input" value="{{manualForm.docNumber}}" bindinput="onManualChange" data-field="docNumber" placeholder="证件编号" />
      </view>
      <view class="field-row">
        <text class="field-label">有效期起</text>
        <input class="field-input" value="{{manualForm.validFrom}}" bindinput="onManualChange" data-field="validFrom" placeholder="YYYY-MM-DD" />
      </view>
      <view class="field-row">
        <text class="field-label">有效期至</text>
        <input class="field-input" value="{{manualForm.validTo}}" bindinput="onManualChange" data-field="validTo" placeholder="YYYY-MM-DD" />
      </view>
      <view class="field-row">
        <text class="field-label">签发机关</text>
        <input class="field-input" value="{{manualForm.issuingAuthority}}" bindinput="onManualChange" data-field="issuingAuthority" placeholder="签发单位" />
      </view>
      <view class="field-row" style="border-bottom:none">
        <text class="field-label">备注</text>
        <input class="field-input" value="{{manualForm.notes}}" bindinput="onManualChange" data-field="notes" placeholder="补充说明（可选）" />
      </view>
    </view>

    <!-- OCR预填信息（OCR模式时显示） -->
    <view class="card" wx:if="{{inputMode !== 'manual' && ocrFieldList.length > 0}}" style="margin-top:20rpx">
      <view class="card-title">📋 已识别信息</view>
      <view class="card-row" wx:for="{{ocrFieldList}}" wx:key="key" wx:if="{{item.value}}">
        <text class="card-row-label">{{item.label}}</text>
        <text class="card-row-value">{{item.value}}</text>
      </view>
    </view>
    <!-- 无识别结果提示 -->
    <view class="ocr-empty-hint" wx:if="{{inputMode !== 'manual' && ocrFieldList.length === 0}}">
      <text>📷 AI未能识别到字段，请手动填写下方信息</text>
    </view>

    <!-- 保存按钮 -->
    <view style="padding:0 24rpx;margin-top:24rpx">
      <button class="btn btn-primary btn-lg {{saving ? 'btn-disabled' : ''}}" bindtap="confirmSave" disabled="{{saving || !docCategory}}">
        {{saving ? '保存中...' : '💾 保存证件'}}
      </button>
    </view>
  </block>

  <view class="safe-bottom"></view>

  <!-- Canvas 2D: 图片旋转/缩放/裁剪/增强 (Bug #8: 合理默认尺寸确保selector可发现) -->
  <canvas type="2d" id="img-process" style="position:fixed;left:-9999px;top:0;width:300px;height:300px"></canvas>
  <!-- Old Canvas API 降级用 (Bug #8: wx.createCanvasContext 备用画布) -->
  <canvas canvas-id="img-fallback" style="position:fixed;left:-9999px;top:310px;width:300px;height:300px"></canvas>
  <!-- Bug #2修复: 扫描增强所需 Old API 画布 -->
  <canvas canvas-id="scan-canvas" style="position:fixed;left:-9999px;top:620px;width:300px;height:300px"></canvas>
  <canvas canvas-id="crop-canvas" style="position:fixed;left:-9999px;top:930px;width:300px;height:300px"></canvas>

  <floating-ai visible="{{true}}" />
</view>
