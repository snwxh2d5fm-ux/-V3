<!--
  住港伴 — 证件夹主页 (Tab2) · 统一UI v2 · CLAUDE-LOCKED 2026-05-13
  配色: 浅色主题, 文本用 var(--color-text-primary), 白色卡片 var(--color-bg-card)
  ⚠️ 禁止回复为深色hero/金色标题/白色文字。修改前请读本文档。
-->
<view class="container">
  <stage-indicator stages="{{stageSteps}}" progress="{{stageProgress}}" />
  <status-badge />

  <view class="page-header">
    <view class="header-left">
      <text class="page-header__title">证件夹</text>
      <text class="page-header__subtitle">{{hasSelectedPath ? selectedPathName + ' · 材料准备' : '按路径管理你的申请材料'}}</text>
    </view>
    <privacy-toggle mode="{{privacyMode}}" bind:change="onPrivacyModeChange" />
  </view>

  <!-- gate-sheet: Phase 2 准入闸 -->

  <!-- 无路径引导 -->
  <view class="empty-path" wx:if="{{pageState === 'no_path' && !isSkipped}}">
    <text class="empty-path__icon">📁</text>
    <text class="empty-path__title">请先选择你的身份申请路径</text>
    <text class="empty-path__desc">系统将根据你的路径自动匹配所需证件清单</text>
    <button class="btn--primary btn-block" bindtap="goSelectPath">前往选择路径</button>
  </view>

  <!-- 进度总览卡 — 统一风格 -->
  <view class="progress-card" wx:if="{{pageState === 'index_loaded' && slotCategories.length > 0}}">
    <view class="progress-card__ring">
      <view class="p-ring">
        <view class="p-ring__center">
          <text class="p-ring__value">{{slotProgress.filled}}</text>
          <text class="p-ring__sep">/</text>
          <text class="p-ring__total">{{slotProgress.total}}</text>
        </view>
        <text class="p-ring__label">材料完整度</text>
      </view>
    </view>
    <view class="progress-card__info">
      <text class="progress-card__stat" wx:if="{{slotProgress.filled === slotProgress.total}}">🎉 全部就绪</text>
      <text class="progress-card__stat" wx:else>📋 {{slotProgress.total - slotProgress.filled}} 项缺失</text>
      <text class="progress-card__hint">点击下方空槽位逐项上传</text>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-bar">
    <button class="btn--primary btn-flex" bindtap="navigateToAdd">+</button>
    <button class="btn--outline btn-flex" bindtap="onSmartCombine">📦 组合</button>
  </view>

  <!-- ═══════════════════ 卡槽系统 ═══════════════════ -->
  <view class="slot-section" wx:if="{{pageState === 'index_loaded' && slotCategories.length > 0}}">
    <view class="cat-section" wx:for="{{slotCategories}}" wx:key="categoryKey" wx:for-item="cat">
      <!-- 分类头 -->
      <view class="cat-head" bindtap="toggleCategory" data-key="{{cat.categoryKey}}">
        <text class="cat-head__name">{{cat.categoryName}}</text>
        <text class="cat-head__count {{cat.categoryProgress.filled === cat.categoryProgress.total ? 'done' : ''}}">{{cat.categoryProgress.filled}}/{{cat.categoryProgress.total}}</text>
        <text class="cat-head__arrow {{collapsedCategories[cat.categoryKey] ? '' : 'open'}}">›</text>
      </view>

      <!-- 所属人切换 (仅身份证明) -->
      <view wx:if="{{cat.categoryKey === 'identity'}}" class="owner-tabs">
        <block wx:for="{{ownerOptions}}" wx:key="value">
          <view class="owner-tab {{identityOwner === item.value ? 'active' : ''}}"
                bindtap="switchIdentityOwner" data-value="{{item.value}}">
            <text>{{item.label}}</text>
          </view>
        </block>
        <view class="owner-tab owner-tab--add" bindtap="onAddChildTap">
          <text>+</text>
        </view>
      </view>

      <!-- 添加子女弹窗 -->
      <view wx:if="{{showAddChild}}" class="overlay">
        <view class="add-child-dialog">
          <text class="add-child-title">添加子女</text>
          <input class="add-child-input" placeholder="请输入子女姓名（如：小明）" value="{{newChildName}}" bindinput="onAddChildInput" maxlength="10"/>
          <view class="add-child-actions">
            <button class="add-child-cancel" bindtap="onAddChildCancel">取消</button>
            <button class="add-child-confirm" bindtap="onAddChildConfirm">确认添加</button>
          </view>
        </view>
      </view>

      <view class="slot-list {{collapsedCategories[cat.categoryKey] ? 'hide' : ''}}">
        <!-- 单行槽位：主体预览区 + 独立+按钮 -->
        <view class="slot {{slot.fillStatus === 'filled' ? 'done' : slot.fillStatus === 'partial' ? 'partial' : slot.fillStatus === 'expiring_soon' ? 'expiring' : slot.fillStatus === 'expired' ? 'expired' : 'empty'}}"
              wx:for="{{cat.slots}}" wx:key="slotKey" wx:for-item="slot">
          <!-- 左侧预览区 → 点击查看详情 -->
          <view class="slot__previews" wx:if="{{slot.uploadedDocs && slot.uploadedDocs.length > 0}}"
                bindtap="{{slot.uploadedDocs.length > 1 ? 'previewSlotDocs' : 'navigateToDetail'}}"
                data-slot-key="{{slot.slotKey}}" data-id="{{slot.uploadedDocs[0] ? slot.uploadedDocs[0].id : ''}}">
            <image class="slot__pthumb" wx:for="{{slot.uploadedDocs}}" wx:key="id" wx:for-item="doc" wx:if="{{index < 3}}" src="{{doc.filePath}}" mode="aspectFill" />
            <text class="slot__pcount" wx:if="{{slot.uploadedDocs.length > 3}}">+{{slot.uploadedDocs.length - 3}}</text>
          </view>
          <!-- 中间名称区 → 点击查看/添加 -->
          <!-- 配偶视图：名称区不可交互 -->
          <view class="slot__info" wx:if="{{isSpouseView}}">
            <text class="slot__name">{{slot.docName}}</text>
            <text class="slot__count slot__count--remote" wx:if="{{slot._spouseFilled}}">✅ 对方已上传</text>
            <text class="slot__count slot__count--empty" wx:else>⬜ 对方未上传</text>
          </view>
          <!-- 本人视图：原有交互 -->
          <view class="slot__info" wx:else
                bindtap="{{slot.fillStatus === 'empty' ? 'uploadToSlot' : (slot.uploadedDocs.length > 1 ? 'previewSlotDocs' : 'navigateToDetail')}}"
                data-slot-key="{{slot.slotKey}}" data-id="{{slot.uploadedDocs[0] ? slot.uploadedDocs[0].id : ''}}">
            <text class="slot__name">{{slot.docName}}{{slot.uploadedCount === 1 && slot.uploadedDocs[0].sideLabel ? '·'+slot.uploadedDocs[0].sideLabel : ''}}</text>
            <text class="slot__count" wx:if="{{slot.uploadedCount > 0}}">{{slot.uploadedCount}}份</text>
          </view>
          <!-- Bug #18 修复: 右侧按钮 → 配偶视图隐藏所有操作按钮 -->
          <block wx:if="{{!isSpouseView}}">
            <text class="slot__btn add"
                  bindtap="uploadToSlot" data-slot-key="{{slot.slotKey}}"
                  wx:if="{{slot.fillStatus === 'empty'}}">+</text>
            <text class="slot__btn continue"
                  bindtap="uploadToSlot" data-slot-key="{{slot.slotKey}}"
                  wx:elif="{{slot.uploadedCount < slot.maxCount || slot.maxCount === -1}}">+</text>
            <text class="slot__btn slot__btn--full"
                  wx:else>✓</text>
            <text class="slot__btn pdf"
                  wx:if="{{slot.uploadedCount > 0}}"
                  bindtap="generateSlotPDF" data-slot-key="{{slot.slotKey}}" data-name="{{slot.docName}}">📄</text>
          </block>
          <!-- 配偶视图：仅显示状态 -->
          <block wx:else>
            <text class="slot__btn slot__btn--remote-done" wx:if="{{slot._spouseFilled}}">✅</text>
            <text class="slot__btn slot__btn--remote-empty" wx:else>⬜</text>
          </block>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && showEmptyGuide && pageState !== 'no_path'}}">
    <text class="empty-state__icon">📁</text>
    <text class="empty-state__title">证件夹还是空的</text>
    <text class="empty-state__desc">拍照添加你的第一份证件，AI将检测照片质量</text>
    <button class="btn--primary btn-block" bindtap="navigateToAdd">拍照添加</button>
  </view>

  <!-- 全局图片预览 -->
  <view class="image-viewer" wx:if="{{showImageViewer}}" bindtap="closeImageViewer">
    <swiper class="image-viewer__swiper" current="{{previewIndex}}" bindchange="onSwiperChange" catchtap="catchStop">
      <swiper-item wx:for="{{filteredDocsWithImage}}" wx:key="id">
        <image class="image-viewer__img" src="{{item.filePath}}" mode="aspectFit" />
      </swiper-item>
    </swiper>
    <view class="image-viewer__info">
      <text>{{previewIndex + 1}} / {{filteredDocsWithImage.length}}</text>
    </view>
    <view class="image-viewer__close" bindtap="closeImageViewer">✕</view>
  </view>

  <view class="guest-guide" wx:if="{{!isLoggedIn && !isSkipped}}">
    <view class="guest-guide__divider"></view>
    <text class="guest-guide__text">登录后开始管理证件、卡槽分类和AI增强</text>
    <button class="btn btn--primary btn--sm" bindtap="goToLogin">立即登录</button>
  </view>

  <view class="safe-bottom"></view>
  <floating-ai visible="{{true}}" context="{{ {page: 'documents', pageContext: '用户在证件夹页面管理申请材料'} }}" />
</view>
