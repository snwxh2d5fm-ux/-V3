/* ═══════════════════════════════════════════════════════════
   住港伴 证件夹主页 (Tab2) · PRD v4.1 UX 优化版
   Design: Navy Blue — 与主UI统一
   ═══════════════════════════════════════════════════════════ */

/* === DESIGN TOKENS === */
page {
  --navy:        #1a73e8;
  --navy-light:  #1557b0;
  --navy-lighter: #e8f0fe;
  --gold:        #1a73e8;
  --gold-light:  #4A90D9;
  --gold-bg:     #e8f0fe;
  --parchment:   #F9FAFB;
  --parchment-dk:#F3F4F6;
  --green:       #059669;
  --green-bg:    #ECFDF5;
  --amber:       #1a73e8;
  --amber-bg:    #e8f0fe;
  --red:         #DC2626;
  --red-bg:      #FEF2F2;
  --gray-100:    #F3F4F6;
  --gray-200:    #E5E7EB;
  --gray-300:    #D1D5DB;
  --gray-400:    #757F8C;
  --gray-500:    #5E6773;
  --gray-700:    #374151;
  --white:       #FFFFFF;
  --radius:      12rpx;
  --radius-lg:   20rpx;
  --shadow-sm:   0 2rpx 12rpx rgba(0,0,0,0.06);
  --shadow-md:   0 4rpx 24rpx rgba(0,0,0,0.08);
  --font-xs:     22rpx;
  --font-sm:     26rpx;
  --font-md:     30rpx;
  --font-lg:     34rpx;
  --font-xl:     40rpx;
  --font-xxl:    56rpx;
  --font-mono:   'Courier New', monospace;
  background: var(--gray-100);
}

/* ═══ PAGE HEAD (统一深色头图区) ═══ */
.page-head {
  background: var(--navy);
  padding-top: 24rpx;
  border-radius: 0 0 var(--radius-lg) var(--radius-lg);
  overflow: hidden;
}
.page-head__top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 28rpx 12rpx;
}
.page-head__title {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
  padding: 0 28rpx 12rpx;
  font-size: var(--font-md);
  color: var(--parchment);
  font-weight: 600;
  letter-spacing: 0.5rpx;
}
.page-head__path {
  font-family: var(--font-mono);
  text-transform: uppercase;
  color: var(--gold-light);
  letter-spacing: 1rpx;
}
.page-head__stage {
  color: var(--gray-300);
  font-size: var(--font-xs);
  font-weight: 400;
}
.page-head__title--plain {
  color: var(--parchment);
}
/* Override stage-indicator white bg → transparent */
.page-head .stage-indicator {
  background: transparent;
  border-bottom: none;
  padding: 8rpx 12rpx 16rpx;
}
.page-head .stage-dot.pending {
  background: rgba(255,255,255,0.12);
  color: rgba(255,255,255,0.45);
}
.page-head .stage-label.pending {
  color: rgba(255,255,255,0.45);
}
.page-head .stage-label.active {
  color: var(--gold-light);
}
.page-head .stage-dot.active {
  background: var(--gold);
  color: var(--navy);
  box-shadow: 0 0 0 6rpx rgba(201,169,110,0.2);
}
.page-head .stage-connector.pending {
  background: rgba(255,255,255,0.1);
}
.page-head .stage-progress-bar {
  background: rgba(255,255,255,0.1);
}
.page-head .stage-progress-fill {
  background: var(--gold);
}

/* ═══ OWNER TABS (身份切换摁钮) ═══ */
.owner-tabs {
  display: flex;
  gap: 12rpx;
  padding: 16rpx 28rpx;
  background: var(--white);
  border-bottom: 1rpx solid var(--gray-200);
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}
.owner-tab {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 24rpx;
  border-radius: 40rpx;
  background: var(--gray-100);
  font-size: var(--font-sm);
  color: var(--gray-500);
  white-space: nowrap;
  transition: all 0.2s;
}
.owner-tab--active {
  background: var(--navy);
  color: var(--gold-light);
  font-weight: 600;
}
.owner-tab__label {}
.owner-tab__count {
  font-size: var(--font-xs);
  padding: 2rpx 10rpx;
  border-radius: 20rpx;
  background: rgba(0,0,0,0.08);
}
.owner-tab--active .owner-tab__count {
  background: rgba(255,255,255,0.15);
}

/* ═══ CONTAINER ═══ */
.vault {
  min-height: 100vh;
  padding-bottom: env(safe-area-inset-bottom);
}

/* ═══ SKIP BANNER ═══ */
.skip-banner {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin: 16rpx 24rpx;
  padding: 20rpx 22rpx;
  background: var(--amber-bg);
  border-left: 6rpx solid var(--amber);
  border-radius: var(--radius);
}
.skip-banner__icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: var(--amber);
  color: var(--white);
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.skip-banner__body { flex: 1; min-width: 0; }
.skip-banner__title { font-size: var(--font-sm); font-weight: 700; color: var(--amber); display: block; margin-bottom: 4rpx; }
.skip-banner__desc { font-size: var(--font-xs); color: var(--gray-500); display: block; line-height: 1.5; }

/* ═══ EMPTY PATH STATE ═══ */
.empty-path {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 48rpx 48rpx;
  text-align: center;
}
.empty-path__hero { margin-bottom: 32rpx; }
.empty-path__ring {
  width: 120rpx; height: 120rpx;
  border-radius: 50%;
  border: 4rpx dashed var(--gold);
  display: flex;
  align-items: center;
  justify-content: center;
}
.empty-path__ring-icon { font-size: 48rpx; color: var(--gold); font-weight: 300; }
.empty-path__title { font-size: var(--font-lg); font-weight: 700; color: var(--gray-700); margin-bottom: 12rpx; }
.empty-path__desc { font-size: var(--font-sm); color: var(--gray-400); line-height: 1.7; margin-bottom: 36rpx; }

/* ═══ BUTTONS ═══ */
.btn-gold {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #1a73e8, #1557b0);
  color: var(--white);
  font-size: var(--font-sm);
  font-weight: 600;
  border-radius: var(--radius);
  padding: 20rpx 36rpx;
  border: none;
  letter-spacing: 0.5rpx;
  line-height: 1.4;
  overflow: visible;
}
.btn-gold::after {
  border: none;
}
.btn-outline {
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  color: var(--gray-500);
  font-size: var(--font-sm);
  font-weight: 500;
  border-radius: var(--radius);
  padding: 20rpx 36rpx;
  border: 2rpx solid var(--gray-300);
  line-height: 1.4;
  overflow: visible;
}
.btn-outline::after {
  border: none;
}
.btn-sm {
  font-size: var(--font-xs);
  padding: 14rpx 28rpx;
  border-radius: 8rpx;
  border: none;
  line-height: 1.3;
  overflow: visible;
}
.btn-sm::after {
  border: none;
}
.btn-block { width: 100%; max-width: 500rpx; }
.btn-flex { flex: 1; }
.btn-gold.btn-flex { text-align: center; }
.btn-outline.btn-flex { text-align: center; }

/* ═══ PROGRESS HERO ═══ */
.progress-hero {
  display: flex;
  align-items: center;
  gap: 32rpx;
  margin: 20rpx 24rpx;
  padding: 32rpx;
  background: var(--navy);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md);
}
.progress-hero__ring {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}
.progress-hero__ring-label {
  font-size: var(--font-xs);
  color: var(--gray-300);
  letter-spacing: 0.5rpx;
}
.progress-hero__info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.progress-hero__stat {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--amber);
}
.progress-hero__stat--done {
  color: var(--green);
}
.progress-hero__hint {
  font-size: var(--font-xs);
  color: var(--gray-300);
  line-height: 1.6;
}
.progress-hero__hint--done {
  color: #6B9E85;
}

/* === RING PROGRESS (CSS-only) === */
.p-ring {
  position: relative;
  width: 128rpx; height: 128rpx;
}
.p-ring__track {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 8rpx solid rgba(255,255,255,0.08);
}
.p-ring__clip {
  position: absolute;
  inset: 0;
  clip: rect(0, 128rpx, 128rpx, 64rpx);
}
.p-ring__clip--left {
  clip: rect(0, 64rpx, 128rpx, 0);
}
.p-ring__fill {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 8rpx solid var(--gold);
  clip: rect(0, 64rpx, 128rpx, 0);
}
.p-ring__fill--right {
  clip: rect(0, 128rpx, 128rpx, 64rpx);
}
.p-ring__center {
  position: absolute;
  inset: 12rpx;
  border-radius: 50%;
  background: var(--navy-light);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 2rpx;
}
.p-ring__value {
  font-size: 38rpx;
  font-weight: 700;
  color: var(--gold-light);
  font-family: var(--font-mono);
}
.p-ring__sep {
  font-size: 24rpx;
  color: var(--gray-400);
  margin: 0 2rpx;
}
.p-ring__total {
  font-size: 24rpx;
  color: var(--gray-400);
  font-family: var(--font-mono);
}

/* ═══ CATEGORY SECTIONS ═══ */
.cat-list {
  margin: 16rpx 24rpx;
}
.cat-section {
  margin-bottom: 16rpx;
  background: var(--white);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}

/* --- Category Header --- */
.cat-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 24rpx;
  background: var(--gray-100);
  border-bottom: 1rpx solid var(--gray-200);
}
.cat-head__left {
  display: flex;
  align-items: center;
  gap: 14rpx;
}
.cat-head__icon {
  width: 44rpx; height: 44rpx;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}
/* CSS icon ::after content — category icons */
.cat-head__icon--identity   { background: rgba(201,169,110,0.15); }
.cat-head__icon--identity::after   { content: '\1F6AA'; font-size: 28rpx; }
.cat-head__icon--education  { background: rgba(45,106,79,0.12); }
.cat-head__icon--education::after  { content: '\1F393'; font-size: 28rpx; }
.cat-head__icon--employment { background: rgba(75,85,99,0.12); }
.cat-head__icon--employment::after { content: '\1F4BC'; font-size: 28rpx; }
.cat-head__icon--financial  { background: rgba(180,83,9,0.12); }
.cat-head__icon--financial::after  { content: '\1F4B0'; font-size: 28rpx; }
.cat-head__icon--application{ background: rgba(26,26,46,0.08); }
.cat-head__icon--application::after{ content: '\1F4C4'; font-size: 28rpx; }

.cat-head__name {
  font-size: var(--font-md);
  font-weight: 700;
  color: var(--gray-700);
}
.cat-head__count {
  font-size: var(--font-xs);
  font-weight: 600;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  background: var(--gray-200);
  color: var(--gray-500);
  font-family: var(--font-mono);
}
.cat-head__count--done { background: var(--green-bg); color: var(--green); }
.cat-head__count--partial { background: var(--amber-bg); color: var(--amber); }

.cat-head__right {
  display: flex;
  align-items: center;
  gap: 10rpx;
}
.cat-head__status {
  font-size: var(--font-xs);
  color: var(--green);
  font-weight: 500;
}
.cat-head__status--warn { color: var(--amber); }
.cat-head__status--muted{ color: var(--gray-400); }

.cat-head__arrow {
  width: 28rpx; height: 28rpx;
  position: relative;
  transition: transform 0.25s;
}
.cat-head__arrow::after {
  content: '';
  position: absolute;
  top: 50%; left: 50%;
  width: 12rpx; height: 12rpx;
  border-right: 2.5rpx solid var(--gray-400);
  border-bottom: 2.5rpx solid var(--gray-400);
  transform: translate(-50%, -60%) rotate(45deg);
}
.cat-head__arrow--open { transform: rotate(180deg); }

/* --- Slot List --- */
.slot-list {
  transition: max-height 0.3s ease;
  overflow: hidden;
}
.slot-list--hide {
  max-height: 0 !important;
  opacity: 0;
}

/* ═══ SLOT CARDS ═══ */
.slot {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid var(--gray-100);
  transition: background 0.2s;
}
.slot:last-child { border-bottom: none; }

/* Slot indicator (left colored bar) */
.slot__indicator {
  width: 6rpx;
  height: 56rpx;
  border-radius: 3rpx;
  flex-shrink: 0;
}
.slot__indicator--empty      { background: var(--gray-300); }
.slot__indicator--filled     { background: var(--green); }
.slot__indicator--partial    { background: var(--amber); }
.slot__indicator--expired    { background: var(--red); }
.slot__indicator--muted      { background: var(--gray-300); }

/* Thumbnail */
.slot__thumb {
  width: 72rpx; height: 72rpx;
  border-radius: 10rpx;
  flex-shrink: 0;
  position: relative;
  background: var(--gray-100);
  display: flex;
  align-items: center;
  justify-content: center;
}
.slot__thumb-inner {
  width: 56rpx; height: 56rpx;
  border-radius: 8rpx;
  background: var(--gray-200);
}
.slot__thumb-inner--done {
  background: var(--green-bg);
  border: 2rpx solid var(--green);
}
.slot__thumb-inner--multi {
  background: rgba(201,169,110,0.1);
  border: 2rpx dashed var(--gold-light);
}
.slot__thumb-count {
  position: absolute;
  bottom: -4rpx;
  right: -4rpx;
  background: var(--gray-700);
  color: var(--white);
  font-size: 18rpx;
  font-weight: 700;
  padding: 1rpx 8rpx;
  border-radius: 10rpx;
  font-family: var(--font-mono);
}

/* Slot body */
.slot__body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.slot__name {
  font-size: var(--font-sm);
  font-weight: 600;
  color: var(--gray-700);
  line-height: 1.4;
}
.slot__name--muted { color: var(--gray-400); }
.slot__desc {
  font-size: var(--font-xs);
  color: var(--gray-400);
  line-height: 1.4;
}
.slot__meta {
  font-size: var(--font-xs);
  color: var(--gray-400);
  font-family: var(--font-mono);
}
.slot__meta--warn { color: var(--red); font-weight: 500; }
.slot__meta--muted { color: var(--gray-300); }

/* Requirement badge */
.slot__tag {
  font-size: 18rpx;
  font-weight: 600;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  align-self: flex-start;
  letter-spacing: 0.3rpx;
}
.slot__tag--required    { background: var(--red-bg); color: var(--red); }
.slot__tag--recommended { background: rgba(201,169,110,0.15); color: #B8934F; }
.slot__tag--optional    { background: var(--gray-200); color: var(--gray-400); }

/* Slot action (right side) */
.slot__action {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
}
.slot__action--add {
  width: 56rpx; height: 56rpx;
  border-radius: 50%;
  background: var(--gold);
  color: var(--white);
  font-size: 36rpx;
  line-height: 1;
  box-shadow: 0 2rpx 12rpx rgba(201,169,110,0.3);
}
.slot__action--done {
  color: var(--green);
  font-size: var(--font-xl);
}
.slot__action--more {
  color: var(--gold);
  font-size: var(--font-xxl);
}
.slot__action--warn {
  width: 48rpx; height: 48rpx;
  border-radius: 50%;
  background: var(--red-bg);
  color: var(--red);
  font-size: 28rpx;
  font-weight: 700;
}
.slot__action--muted {
  color: var(--gray-300);
  font-size: var(--font-xl);
}

/* Slot states */
.slot--empty { background: var(--white); }
.slot--filled { background: var(--white); }
.slot--warn { background: rgba(153,27,27,0.03); }
.slot--archived { background: var(--gray-100); opacity: 0.65; }

/* ═══ OVERFLOW SECTION ═══ */
.overflow {
  margin: 16rpx 24rpx;
  background: var(--white);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  padding: 24rpx;
  border: 2rpx dashed var(--gray-300);
}
.overflow__head {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 8rpx;
}
.overflow__icon {
  width: 36rpx; height: 36rpx;
  background: var(--gray-100);
  border-radius: 8rpx;
}
.overflow__icon::after {
  content: '\1F4CE';
  display: flex;
  width: 36rpx; height: 36rpx;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}
.overflow__title {
  font-size: var(--font-sm);
  font-weight: 700;
  color: var(--gray-500);
}
.overflow__hint {
  font-size: var(--font-xs);
  color: var(--gray-400);
}
.overflow__desc {
  font-size: var(--font-xs);
  color: var(--gray-400);
  display: block;
  margin-bottom: 16rpx;
}
.overflow__list {
  border-top: 1rpx solid var(--gray-200);
}
.overflow__add {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 20rpx;
  margin-top: 16rpx;
  border: 2rpx dashed var(--gold-light);
  border-radius: var(--radius);
  color: var(--gold);
  font-size: var(--font-sm);
  font-weight: 600;
  background: var(--gold-bg);
}
.overflow__add-icon {
  font-size: 32rpx;
  font-weight: 300;
  color: var(--gold);
}

/* ═══ ARCHIVED SECTION ═══ */
.archive {
  margin: 16rpx 24rpx;
  background: var(--gray-100);
  border-radius: var(--radius-lg);
  overflow: hidden;
}
.archive__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: var(--gray-200);
}
.archive__head-left {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.archive__icon { font-size: var(--font-sm); }
.archive__label {
  font-size: var(--font-sm);
  font-weight: 600;
  color: var(--gray-400);
}
.archive__count {
  font-size: var(--font-xs);
  color: var(--gray-400);
}
.archive__arrow {
  width: 24rpx; height: 24rpx;
  position: relative;
  transition: transform 0.25s;
}
.archive__arrow::after {
  content: '';
  position: absolute;
  top: 50%; left: 50%;
  width: 10rpx; height: 10rpx;
  border-right: 2.5rpx solid var(--gray-400);
  border-bottom: 2.5rpx solid var(--gray-400);
  transform: translate(-50%, -60%) rotate(45deg);
}
.archive__arrow--open { transform: rotate(180deg); }

/* ═══ STORAGE NOTICE BAR ═══ */
.storage-notice {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin: 24rpx 24rpx;
  padding: 20rpx 24rpx;
  background: var(--navy);
  border-radius: var(--radius);
}
.storage-notice__icon { font-size: 32rpx; flex-shrink: 0; }
.storage-notice__text {
  font-size: var(--font-xs);
  color: var(--gray-300);
  line-height: 1.6;
}

/* ═══ CLOUD STORAGE BAR ═══ */
.cloud-bar {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin: 12rpx 24rpx;
  padding: 18rpx 24rpx;
  background: var(--white);
  border-radius: var(--radius);
  box-shadow: var(--shadow-sm);
}
.cloud-bar__icon { font-size: 36rpx; flex-shrink: 0; }
.cloud-bar__body { flex: 1; min-width: 0; }
.cloud-bar__label {
  font-size: var(--font-xs);
  color: var(--gray-500);
  font-weight: 500;
  display: block;
  margin-bottom: 8rpx;
}
.cloud-bar__track {
  height: 6rpx;
  background: var(--gray-200);
  border-radius: 3rpx;
  overflow: hidden;
}
.cloud-bar__fill {
  height: 100%;
  background: var(--gold);
  border-radius: 3rpx;
  transition: width 0.4s ease;
}

/* ═══ SMART UPLOAD BAR ═══ */
.smart-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin: 20rpx 24rpx;
  padding: 24rpx;
  background: var(--white);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  border: 2rpx solid var(--gold-bg);
}
.smart-bar__icon {
  width: 52rpx; height: 52rpx;
  border-radius: 12rpx;
  background: var(--gold-bg);
  flex-shrink: 0;
}
.smart-bar__icon::after {
  content: '\2728';
  display: flex;
  width: 52rpx; height: 52rpx;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}
.smart-bar__body { flex: 1; min-width: 0; }
.smart-bar__title { font-size: var(--font-sm); font-weight: 600; color: var(--gray-700); display: block; }
.smart-bar__hint { font-size: var(--font-xs); color: var(--gold); font-weight: 500; display: block; margin-top: 4rpx; }
.smart-bar__btn {
  width: 48rpx; height: 48rpx;
  border-radius: 50%;
  background: var(--gold);
  flex-shrink: 0;
}
.smart-bar__btn::after {
  content: '\2192';
  display: flex;
  width: 48rpx; height: 48rpx;
  align-items: center;
  justify-content: center;
  color: var(--white);
  font-size: 24rpx;
  font-weight: 700;
}

/* ═══ SEARCH BAR ═══ */
.search-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin: 20rpx 24rpx 12rpx;
  padding: 16rpx 24rpx;
  background: var(--white);
  border-radius: var(--radius);
  box-shadow: var(--shadow-sm);
}
.search-bar__icon {
  width: 32rpx; height: 32rpx;
  flex-shrink: 0;
}
.search-bar__icon::after {
  content: '\1F50D';
  display: flex;
  width: 32rpx; height: 32rpx;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  opacity: 0.5;
}
.search-bar__input {
  flex: 1;
  font-size: var(--font-sm);
  color: var(--gray-700);
  background: transparent;
  border: none;
  outline: none;
}
.search-bar__input::placeholder { color: var(--gray-300); }
.search-bar__clear {
  font-size: var(--font-lg);
  color: var(--gray-400);
  padding: 0 8rpx;
  flex-shrink: 0;
}

/* ═══ LIMIT TIP ═══ */
.limit-tip {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin: 12rpx 24rpx;
  padding: 18rpx 22rpx;
  background: linear-gradient(135deg, #FFF7ED, #FFEDD5);
  border: 1rpx solid rgba(180,83,9,0.2);
  border-radius: var(--radius);
}
.limit-tip__icon {
  width: 44rpx; height: 44rpx;
  border-radius: 50%;
  background: var(--amber);
  color: var(--white);
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.limit-tip__body { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 4rpx; }
.limit-tip__title { font-size: var(--font-sm); font-weight: 700; color: var(--amber); }
.limit-tip__desc { font-size: var(--font-xs); color: #C2410C; line-height: 1.5; }

/* ═══ ACTION ROW ═══ */
.action-row {
  display: flex;
  gap: 16rpx;
  padding: 0 24rpx;
  margin: 12rpx 0;
}

/* ═══ CATEGORY TABS (SCROLL) ═══ */
.cat-tabs {
  white-space: nowrap;
  padding: 12rpx 20rpx;
  margin: 8rpx 0;
}
.cat-tab {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx 22rpx;
  margin-right: 10rpx;
  border-radius: 24rpx;
  font-size: var(--font-xs);
  font-weight: 600;
  color: var(--gray-500);
  background: var(--white);
  border: 1rpx solid var(--gray-200);
  transition: all 0.2s;
}
.cat-tab--active {
  color: var(--white);
  background: var(--navy);
  border-color: var(--navy);
  box-shadow: 0 2rpx 12rpx rgba(26,26,46,0.3);
}
.cat-tab__icon {
  width: 28rpx; height: 28rpx;
  border-radius: 6rpx;
}

/* ═══ DOCUMENT LIST ═══ */
.doc-list__head {
  padding: 16rpx 28rpx 8rpx;
  font-size: var(--font-xs);
  color: var(--gray-400);
}
.doc-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  margin: 4rpx 24rpx;
  background: var(--white);
  border-radius: var(--radius);
  box-shadow: var(--shadow-sm);
}
.doc-item--archived { opacity: 0.55; }
.doc-item__thumb {
  width: 80rpx; height: 80rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  object-fit: cover;
}
.doc-item__icon {
  width: 52rpx; height: 52rpx;
  border-radius: 12rpx;
  background: var(--gray-100);
  flex-shrink: 0;
}
.doc-item__body { flex: 1; min-width: 0; }
.doc-item__title { font-size: var(--font-sm); font-weight: 600; color: var(--gray-700); display: block; }
.doc-item__desc { font-size: var(--font-xs); color: var(--gray-400); display: block; margin-top: 4rpx; }
.doc-item__tag {
  font-size: 20rpx;
  font-weight: 600;
  padding: 4rpx 14rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}
.doc-item__tag--tag-verified { background: var(--green-bg); color: var(--green); }
.doc-item__tag--tag-expiring{ background: var(--amber-bg); color: var(--amber); }
.doc-item__tag--tag-expired { background: var(--red-bg); color: var(--red); }
.doc-item__tag--tag-pending { background: var(--gray-200); color: var(--gray-400); }
.doc-item__tag--tag-archived{ background: var(--gray-200); color: var(--gray-400); }
.doc-item__arrow { font-size: var(--font-xl); color: var(--gray-300); flex-shrink: 0; }

/* ═══ EMPTY STATE ═══ */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 48rpx;
  text-align: center;
}
.empty-state__hero { margin-bottom: 28rpx; }
.empty-state__hero--sm { margin-bottom: 16rpx; }
.empty-state__ring {
  width: 140rpx; height: 140rpx;
  border-radius: 50%;
  border: 4rpx dashed var(--gray-300);
  display: flex;
  align-items: center;
  justify-content: center;
}
.empty-state__ring-icon { font-size: 52rpx; color: var(--gray-400); font-weight: 300; }
.empty-state__ring-icon--sm { font-size: 40rpx; }
.empty-state__title { font-size: var(--font-lg); font-weight: 700; color: var(--gray-700); margin-bottom: 10rpx; }
.empty-state__desc { font-size: var(--font-sm); color: var(--gray-400); line-height: 1.6; margin-bottom: 24rpx; }
.empty-state__actions {
  margin-top: 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  max-width: 440rpx;
  gap: 16rpx;
}
.empty-state__tips {
  margin-top: 40rpx;
  padding: 28rpx;
  background: var(--white);
  border-radius: var(--radius-lg);
  width: 100%;
  max-width: 560rpx;
  box-shadow: var(--shadow-sm);
}
.empty-state__tips-title {
  font-size: var(--font-sm);
  font-weight: 700;
  color: var(--gray-500);
  display: block;
  margin-bottom: 14rpx;
}
.empty-state__tips-item {
  font-size: var(--font-xs);
  color: var(--gray-400);
  display: block;
  line-height: 2;
}

/* ═══ LOADING ═══ */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}
.loading__dots {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}
.loading__dot {
  width: 12rpx; height: 12rpx;
  border-radius: 50%;
  background: var(--gray-300);
  animation: dotPulse 1.4s ease-in-out infinite;
}
.loading__dot:nth-child(2) { animation-delay: 0.2s; }
.loading__dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes dotPulse {
  0%, 80%, 100% { opacity: 0.3; transform: scale(0.8); }
  40% { opacity: 1; transform: scale(1.2); }
}
.loading__text {
  font-size: var(--font-sm);
  color: var(--gray-400);
}

/* ═══ SAFE BOTTOM ═══ */
.safe-bottom { height: 120rpx; }
