/* 订单详情样式 */

page {
background: var(--gray-100);
}

.page {
  padding-bottom: 60rpx;
}

.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 200rpx 0;
}
.loading-text { font-size: 28rpx; color: var(--gray-400); }

.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 40rpx;
}
.empty-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 32rpx; color: var(--gray-700); font-weight: 600; margin-bottom: 40rpx; }

.detail-card {
  margin: 24rpx 32rpx;
  background: var(--white);
  border-radius: 20rpx;
  overflow: hidden;
}

/* 头部 */
.detail-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 36rpx 32rpx;
  background: linear-gradient(135deg, var(--color-info-bg), #F8FAFC);
  border-bottom: 1rpx solid var(--gray-200);
}

.header-icon { font-size: 52rpx; }

.header-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
  display: block;
}

.header-status {
  font-size: 24rpx;
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
  font-weight: 500;
  display: inline-block;
  margin-top: 6rpx;
}

.header-status.completed { background: #D1FAE5; color: var(--color-success); }
.header-status.pending { background: var(--color-warning-bg); color: #92400E; }
.header-status.failed { background: #FEE2E2; color: var(--color-error); }
.header-status.cancelled { background: var(--gray-100); color: var(--gray-500); }

/* 金额 */
.amount-block {
  text-align: center;
  padding: 36rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.amount-value {
  font-size: 68rpx;
  font-weight: 800;
  color: var(--color-error);
  display: block;
}

.amount-label {
  font-size: 24rpx;
  color: var(--gray-400);
  display: block;
  margin-top: 4rpx;
}

/* 订单信息 */
.info-section {
  padding: 28rpx 32rpx;
}

.info-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--gray-700);
  margin-bottom: 16rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}

.info-label {
  font-size: 26rpx;
  color: var(--gray-400);
}

.info-value {
  font-size: 26rpx;
  color: var(--gray-700);
}

.info-value.mono {
  font-family: 'Courier New', monospace;
  font-size: 22rpx;
  color: var(--gray-500);
  max-width: 360rpx;
  word-break: break-all;
  text-align: right;
}

.info-value.success {
  color: var(--color-success);
  font-weight: 600;
}

/* 操作 */
.actions {
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.btn-primary {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, var(--color-primary), var(--color-info));
  color: #fff;
  border: none;
  border-radius: 14rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
}

.btn-primary::after { border: none; }

.btn-ghost {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: var(--white);
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
  border-radius: 14rpx;
  font-size: 28rpx;
  text-align: center;
}

.btn-ghost::after { border: none; }

/* 已申请发票 */
.invoice-done {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 20rpx;
  background: var(--color-success-bg);
  border-radius: 14rpx;
  font-size: 28rpx;
  color: var(--color-success);
}

.invoice-status-tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-weight: 500;
}

.invoice-status-tag.pending { background: var(--color-warning-bg); color: #92400E; }
.invoice-status-tag.issued { background: #D1FAE5; color: var(--color-success); }
