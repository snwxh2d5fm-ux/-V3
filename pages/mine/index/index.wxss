/* 住港伴 v4 — 我的页面样式 */

.user-section{display:flex;align-items:center;gap:16rpx}
.user-name{font-size:var(--font-lg);font-weight:600;color:#FFF;display:block}
.user-status{font-size:var(--font-xs);color:rgba(255,255,255,.7);display:block}
.membership-card{background:linear-gradient(135deg,#1E40AF,#2563EB);color:#FFF;text-align:left;padding:28rpx}

/* ===== 商务后台卡片 ===== */
.biz-backend-card {
  border: 2rpx dashed var(--blue);
  background: linear-gradient(180deg, var(--blue-light), var(--white));
  margin-top: 24rpx;
}
.biz-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}
.biz-icon { font-size: 36rpx; }
.biz-title { font-size: var(--font-md); font-weight: 700; color: var(--blue); }
.biz-desc {
  font-size: var(--font-xs);
  color: var(--gray-500);
  line-height: 2;
  display: block;
  margin-bottom: 16rpx;
  white-space: pre-line;
}
.biz-url {
  background: var(--gray-100);
  border-radius: var(--radius-sm);
  padding: 14rpx 20rpx;
}
.biz-url-text {
  font-size: var(--font-xs);
  color: var(--gray-600);
  font-weight: 500;
}

/* ===== 个人数据保险箱 ===== */
.data-vault-card {
  background: linear-gradient(135deg, #7C3AED, #A855F7);
  padding: 0;
  margin-top: 24rpx;
  border-radius: var(--radius);
  overflow: hidden;
}
.vault-content {
  display: flex;
  align-items: center;
  padding: 28rpx;
  gap: 20rpx;
}
.vault-icon-large {
  font-size: 56rpx;
  flex-shrink: 0;
}
.vault-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
.vault-title {
  font-size: var(--font-md);
  font-weight: 700;
  color: #FFF;
}
.vault-desc {
  font-size: var(--font-xs);
  color: rgba(255,255,255,0.8);
  line-height: 1.5;
}
.vault-arrow {
  font-size: 36rpx;
  color: rgba(255,255,255,0.6);
  flex-shrink: 0;
}

/* ===== 设置分组间距 ===== */
.settings-group {
  margin-top: 16rpx;
}

/* ===== 页脚 ===== */
.version-footer {
  text-align: center;
  padding: 20rpx;
  font-size: var(--font-xs);
  color: var(--gray-400);
}
