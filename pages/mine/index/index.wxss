/* 我的页面 */

/* 头部 */
.user-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.user-avatar {
  font-size: 52rpx;
}

.user-text {
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: var(--font-lg);
  font-weight: 700;
  color: #fff;
}

.user-status-label {
  font-size: var(--font-xs);
  color: rgba(255,255,255,0.75);
  margin-top: 4rpx;
}

/* 会员卡片 */
.member-card {
  margin: 16rpx 24rpx;
  padding: 28rpx;
  border-radius: var(--radius);
  background: linear-gradient(135deg, var(--color-primary-dark), var(--color-info));
  color: #fff;
}

.member-top {
  margin-bottom: 20rpx;
}

.member-level-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.member-level {
  font-size: var(--font-xl);
  font-weight: 800;
}

.member-badge {
  font-size: var(--font-xs);
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  background: rgba(255,255,255,0.25);
  font-weight: 700;
  letter-spacing: 1rpx;
}

.member-days {
  font-size: var(--font-xs);
  opacity: 0.8;
  display: block;
  margin-top: 8rpx;
}

.member-expired {
  font-size: var(--font-xs);
  display: block;
  margin-top: 8rpx;
}

.member-usage {
  margin-bottom: 20rpx;
}

.usage-bar {
  height: 8rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 4rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.usage-fill {
  height: 100%;
  background: #fff;
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.usage-text {
  font-size: var(--font-xs);
  opacity: 0.8;
}

.btn-member {
  background: #fff;
  color: var(--color-primary);
  font-weight: 700;
  border-radius: var(--radius-sm);
  width: 100%;
  display: flex;
}

/* 菜单 */
.menu-section {
  margin: 0 24rpx;
  border-radius: var(--radius);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  background: #fff;
}

.menu-section + .menu-section {
  margin-top: 16rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  gap: 16rpx;
  border-bottom: 1rpx solid var(--gray-100);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: var(--gray-50);
}

.menu-icon {
  font-size: 36rpx;
  flex-shrink: 0;
  width: 52rpx;
  text-align: center;
}

.menu-body {
  flex: 1;
  min-width: 0;
}

.menu-title {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--color-text-primary);
}

.menu-desc {
  font-size: var(--font-xs);
  color: var(--color-text-secondary);
  margin-top: 4rpx;
  display: block;
}

.menu-arrow {
  font-size: 32rpx;
  color: var(--gray-400);
  flex-shrink: 0;
}

/* 退出 */
.logout-wrap {
  text-align: center;
  padding: 32rpx;
}

.btn-logout {
  color: var(--color-error);
  font-size: var(--font-sm);
}

/* 页脚 */
.version-footer {
  text-align: center;
  padding: 16rpx;
  font-size: var(--font-xs);
  color: var(--gray-400);
}
