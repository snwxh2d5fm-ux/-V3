<view class="container">
  <!-- 头部 -->
  <view class="page-header">
    <view class="user-info">
      <text class="user-avatar">{{isLoggedIn ? '👤' : '👋'}}</text>
      <view class="user-text">
        <text class="user-name">{{isLoggedIn ? userInfo.nickName : '未登录'}}</text>
        <text class="user-status-label" wx:if="{{isLoggedIn}}">{{userStatusLabel}}</text>
      </view>
    </view>
  </view>

  <!-- 阶段指示器 -->
  <stage-indicator stages="{{stageSteps}}" progress="{{stageProgress}}" />

  <!-- 会员卡片 -->
  <view class="member-card">
    <view class="member-top">
      <view class="member-level-row">
        <text class="member-level">{{membershipName}}</text>
        <text class="member-badge" wx:if="{{isPayingUser}}">PRO</text>
      </view>
      <text class="member-days" wx:if="{{membershipDays > 0 && !isLocked}}">剩余 {{membershipDays}} 天</text>
      <text class="member-expired" wx:if="{{isLocked}}">🔒 已过期</text>
    </view>

    <view class="member-usage">
      <view class="usage-bar">
        <view class="usage-fill" style="width:{{usagePercent}}%"></view>
      </view>
      <text class="usage-text">已使用 {{documentCount}}/{{documentLimitDisplay}} 证件位</text>
    </view>

    <button class="btn btn-block btn-member" bindtap="navigateTo" data-url="membership">
      {{isLocked ? '🔓 解锁全部功能' : (isPayingUser ? '✨ 管理会员' : '🚀 升级会员')}}
    </button>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="menu-item" wx:for="{{menuItems}}" wx:key="id" bindtap="navigateTo" data-url="{{item.url}}" data-tab="{{item.tab}}">
      <text class="menu-icon">{{item.icon}}</text>
      <view class="menu-body">
        <text class="menu-title">{{item.title}}</text>
        <text class="menu-desc" wx:if="{{item.id === 'documents'}}">{{documentCount}} 份材料已存档</text>
        <text class="menu-desc" wx:elif="{{item.id === 'privacy'}}">{{authorizedFields}} 个标签已授权</text>
        <text class="menu-desc" wx:elif="{{item.desc}}">{{item.desc}}</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 设置 -->
  <view class="menu-section">
    <view class="menu-item" wx:for="{{settingsItems}}" wx:key="id" bindtap="navigateTo" data-url="{{item.url}}">
      <text class="menu-icon">{{item.icon}}</text>
      <view class="menu-body">
        <text class="menu-title">{{item.title}}</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 退出 -->
  <view class="logout-wrap" wx:if="{{isLoggedIn}}">
    <button class="btn btn-ghost btn-logout" bindtap="logout">退出登录</button>
  </view>

  <view class="version-footer">
    住港伴 v4.0 · 隐私优先
  </view>

  <floating-ai visible="{{true}}" context="{{ {page: 'mine'} }}" />
  <view class="safe-bottom"></view>
</view>
