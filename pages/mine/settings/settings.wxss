/* pages/mine/settings/settings.wxss */
.page { min-height:100vh; background:#f5f5f5; padding-bottom:40rpx; }
.section { margin:24rpx; background:#fff; border-radius:20rpx; overflow:hidden; }
.section-label { font-size:24rpx; color:#999; padding:24rpx 24rpx 8rpx; display:block; }
.cell { display:flex; justify-content:space-between; align-items:center; padding:24rpx; border-bottom:1rpx solid #f5f5f5; }
.cell:last-child { border-bottom:none; }
.cell.arrow::after { content:'→'; font-size:28rpx; color:#ccc; }
.cell-label { font-size:30rpx; color:#202124; }
.cell-value { font-size:26rpx; color:#5f6368; }
.cell-label.danger { color:#d93025; }
.switch-cell { padding-right:16rpx; }
.danger-zone { border:1rpx solid #ffcdd2; }
