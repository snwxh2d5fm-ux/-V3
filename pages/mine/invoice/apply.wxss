/* 发票申请页样式 */

page {
  background: #f5f7fa;
}

.page {
  padding-bottom: 60rpx;
}

.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 200rpx 0;
}
.loading-text { font-size: 28rpx; color: #999; }

/* 成功页 */
.success-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 48rpx;
  text-align: center;
}

.success-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.success-title { font-size: 36rpx; font-weight: 700; color: #059669; margin-bottom: 12rpx; }
.success-msg { font-size: 28rpx; color: #666; margin-bottom: 48rpx; }

/* 订单摘要 */
.order-summary {
  margin: 24rpx 32rpx;
  padding: 28rpx 32rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.summary-label { font-size: 24rpx; color: #999; display: block; margin-bottom: 8rpx; }
.summary-name { font-size: 30rpx; font-weight: 600; color: #333; display: block; }
.summary-amount { font-size: 40rpx; font-weight: 800; color: #DC2626; display: block; margin-top: 8rpx; }

/* 类型切换 */
.type-switch {
  display: flex;
  margin: 0 32rpx 24rpx;
  background: #E5E7EB;
  border-radius: 12rpx;
  padding: 6rpx;
}

.type-option {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 28rpx;
  color: #666;
  border-radius: 10rpx;
}

.type-option.active {
  background: #fff;
  color: #1a73e8;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
}

/* 表单 */
.form-fields {
  margin: 0 32rpx;
}

.field-group {
  background: #fff;
  border-radius: 14rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 16rpx;
}

.field-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  display: block;
  margin-bottom: 12rpx;
}

.required {
  color: #DC2626;
}

.field-input {
  width: 100%;
  height: 72rpx;
  font-size: 28rpx;
  border-bottom: 2rpx solid #f0f0f0;
  color: #333;
  padding: 0 4rpx;
}

.field-input:focus {
  border-bottom-color: #1a73e8;
}

.field-hint {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-top: 8rpx;
}

/* 隐私说明 */
.privacy-notice {
  margin: 24rpx 32rpx;
  padding: 28rpx;
  background: linear-gradient(135deg, #059669, #10B981);
  border-radius: 16rpx;
  color: #fff;
}

.privacy-icon { font-size: 36rpx; display: block; margin-bottom: 8rpx; }
.privacy-title { font-size: 28rpx; font-weight: 700; display: block; margin-bottom: 8rpx; }
.privacy-text { font-size: 24rpx; opacity: 0.9; line-height: 1.6; display: block; }

/* 提交按钮 */
.submit-btn {
  width: calc(100% - 64rpx);
  margin: 24rpx 32rpx 16rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #1a73e8, #2563EB);
  color: #fff;
  border: none;
  border-radius: 14rpx;
  font-size: 32rpx;
  font-weight: 700;
  text-align: center;
}

.submit-btn::after { border: none; }

.btn-primary {
  width: calc(100% - 64rpx);
  margin: 16rpx 32rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #1a73e8, #2563EB);
  color: #fff;
  border: none;
  border-radius: 14rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.btn-primary::after { border: none; }

.btn-ghost {
  width: calc(100% - 64rpx);
  margin: 16rpx 32rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: #fff;
  color: #1a73e8;
  border: 2rpx solid #1a73e8;
  border-radius: 14rpx;
  font-size: 28rpx;
  text-align: center;
}

.btn-ghost::after { border: none; }

.safe-bottom { height: 40rpx; }
