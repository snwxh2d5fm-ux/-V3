<!-- 发票开具申请 -->
<view class="page">

  <!-- 加载中 -->
  <view class="loading-wrap" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 提交成功 -->
  <view class="success-card" wx:elif="{{submitted}}">
    <text class="success-icon">✅</text>
    <text class="success-title">申请已提交</text>
    <text class="success-msg">{{resultMsg}}</text>
    <button class="btn-primary" bindtap="viewInvoices">查看我的发票</button>
    <button class="btn-ghost" bindtap="goBack">返回</button>
  </view>

  <!-- 申请表单 -->
  <view class="form-wrap" wx:else>
    <!-- 订单摘要 -->
    <view class="order-summary">
      <text class="summary-label">开票订单</text>
      <text class="summary-name">{{order.productName}}</text>
      <text class="summary-amount">¥{{order.amountYuan}}</text>
    </view>

    <!-- 发票类型切换 -->
    <view class="type-switch">
      <view
        class="type-option {{invoiceType === 'personal' ? 'active' : ''}}"
        bindtap="switchType"
        data-type="personal"
      >
        <text>🧑 个人</text>
      </view>
      <view
        class="type-option {{invoiceType === 'company' ? 'active' : ''}}"
        bindtap="switchType"
        data-type="company"
      >
        <text>🏢 企业</text>
      </view>
    </view>

    <!-- 表单字段 -->
    <view class="form-fields">

      <!-- 个人发票 -->
      <block wx:if="{{invoiceType === 'personal'}}">
        <view class="field-group">
          <text class="field-label">发票抬头</text>
          <input
            class="field-input"
            placeholder="个人（默认）"
            value="{{form.title}}"
            bindinput="onInput"
            data-field="title"
          />
          <text class="field-hint">不填则默认"个人"</text>
        </view>
      </block>

      <!-- 企业发票 -->
      <block wx:else>
        <view class="field-group">
          <text class="field-label">公司名称 <text class="required">*</text></text>
          <input
            class="field-input"
            placeholder="请输入公司全称"
            value="{{form.title}}"
            bindinput="onInput"
            data-field="title"
          />
        </view>

        <view class="field-group">
          <text class="field-label">纳税人识别号 <text class="required">*</text></text>
          <input
            class="field-input"
            placeholder="请输入税号（统一社会信用代码）"
            value="{{form.taxNumber}}"
            bindinput="onInput"
            data-field="taxNumber"
          />
        </view>

        <view class="field-group">
          <text class="field-label">开户行及账号</text>
          <input
            class="field-input"
            placeholder="选填"
            value="{{form.bankInfo}}"
            bindinput="onInput"
            data-field="bankInfo"
          />
        </view>

        <view class="field-group">
          <text class="field-label">注册地址</text>
          <input
            class="field-input"
            placeholder="选填"
            value="{{form.address}}"
            bindinput="onInput"
            data-field="address"
          />
        </view>

        <view class="field-group">
          <text class="field-label">注册电话</text>
          <input
            class="field-input"
            type="number"
            placeholder="选填"
            value="{{form.phone}}"
            bindinput="onInput"
            data-field="phone"
          />
        </view>
      </block>

      <!-- 公共字段 -->
      <view class="field-group">
        <text class="field-label">接收邮箱 <text class="required">*</text></text>
        <input
          class="field-input"
          type="text"
          placeholder="电子发票将发送至此邮箱"
          value="{{form.email}}"
          bindinput="onInput"
          data-field="email"
        />
        <text class="field-hint">我们会在3个工作日内将电子发票发送至您的邮箱</text>
      </view>
    </view>

    <!-- ★ 隐私说明 -->
    <view class="privacy-notice">
      <text class="privacy-icon">🔒</text>
      <text class="privacy-title">你的隐私，我们守护</text>
      <text class="privacy-text">发票信息仅用于开票处理，提交后加密存储，完成后工单信息自动归档。我们不会将你的信息用于任何其他用途。</text>
    </view>

    <!-- 提交 -->
    <button
      class="submit-btn"
      bindtap="submitInvoice"
      loading="{{submitting}}"
      disabled="{{submitting}}"
    >
      {{submitting ? '提交中...' : '提交申请'}}
    </button>

    <button class="btn-ghost" bindtap="goBack">取消</button>
  </view>

  <floating-ai visible="{{true}}" />
  <view class="safe-bottom"></view>
</view>
