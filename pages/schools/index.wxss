.page { background: #f5f5f5; min-height: 100vh; }
.search-bar { padding: 16rpx 24rpx; background: #fff; }
.search-input { background: #f0f0f0; border-radius: 32rpx; padding: 14rpx 28rpx; font-size: 28rpx; height: 64rpx; }
.filter-row { white-space: nowrap; padding: 16rpx 24rpx; background: #fff; border-bottom: 1rpx solid #eee; }
.filter-tag { display: inline-block; padding: 10rpx 24rpx; margin-right: 12rpx; background: #f0f0f0; border-radius: 32rpx; font-size: 26rpx; color: #666; }
.filter-tag.active { background: #1a73e8; color: #fff; font-weight: 600; }
.count-bar { padding: 12rpx 28rpx; font-size: 24rpx; color: #999; }
.school-list { height: calc(100vh - 220rpx); padding: 0 16rpx; }
.school-card { background: #fff; border-radius: 12rpx; padding: 24rpx; margin-bottom: 12rpx; }
.card-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.school-name { font-size: 30rpx; font-weight: 600; flex: 1; }
.school-type { font-size: 22rpx; padding: 4rpx 14rpx; border-radius: 16rpx; font-weight: 600; }
.type-gov { background: #e8f5e9; color: #2e7d32; }
.type-aid { background: #e3f2fd; color: #1565c0; }
.type-dss { background: #fff8e1; color: #e65100; }
.type-private { background: #fce4ec; color: #c2185b; }
.type-intl { background: #f3e5f5; color: #7b1fa2; }
.card-info { }
.info-line { font-size: 24rpx; color: #666; display: block; margin-bottom: 6rpx; line-height: 1.5; }
.empty { text-align: center; padding: 80rpx; color: #999; font-size: 28rpx; }

.dropdown-bar { display: flex; gap: 12rpx; padding: 12rpx 24rpx; background: #fff; border-bottom: 1rpx solid #eee; }
.dropdown { flex: 1; background: #f0f0f0; border-radius: 12rpx; padding: 14rpx 16rpx; font-size: 24rpx; color: #333; text-align: center; }
.dropdown-panel { background: #fff; padding: 8rpx 24rpx 16rpx; border-bottom: 1rpx solid #eee; display: flex; flex-wrap: wrap; gap: 8rpx; }
.dd-option { padding: 8rpx 18rpx; background: #f5f5f5; border-radius: 20rpx; font-size: 24rpx; color: #666; }
.dd-option.active { background: #1a73e8; color: #fff; font-weight: 600; }
.dd-subtitle { width: 100%; font-size: 22rpx; color: #aaa; padding: 4rpx 0; background: none; }
