<!-- 攻略书 v6 — 港漂通关手册 三Tab框架 -->
<view class="container">
  <view class="tab-bar">
    <view wx:for="{{tabs}}" wx:key="id" class="tab-item {{activeTab===item.id?'active':''}}"
          data-tab="{{item.id}}" bindtap="switchTab">
      <text>{{item.label}}</text>
      <view wx:if="{{activeTab===item.id}}" class="tab-indicator"></view>
    </view>
  </view>

  <view wx:if="{{loading}}" class="loading-wrap">
    <view class="skeleton-line" wx:for="{{[1,2,3,4,5]}}" wx:key="*this"></view>
  </view>

  <view wx:elif="{{loadError}}" class="error-wrap">
    <text class="error-icon">📡</text>
    <text class="error-text">加载失败，请检查网络</text>
    <view class="btn-retry" bindtap="onRetry">重试</view>
  </view>

  <!-- Tab 0: 生活指南 -->
  <view wx:elif="{{activeTab===0}}" class="tab-content">
    <!-- 当前进度指示 -->
    <view class="current-phase-bar" wx:if="{{phases.length}}">
      <text class="cp-label">📍 当前: 关卡{{currentPhase}}</text>
      <view class="cp-progress">
        <view class="cp-dots">
          <block wx:for="{{phases}}" wx:key="phase">
            <view class="cp-dot {{item.phase < currentPhase ? 'done' : (item.phase === currentPhase ? 'active' : '')}}"></view>
          </block>
        </view>
      </view>
    </view>
    <view class="dossier-bar" wx:if="{{renewalDossier}}" bindtap="switchTab" data-tab="2">
      <text class="dossier-label">📋 续签档案</text>
      <text class="dossier-stat"><text>🏠{{renewalDossier.address.completeness||0}}</text>/4</text>
      <text class="dossier-stat"><text>💼{{renewalDossier.employment.completeness||0}}</text>/3</text>
      <text class="dossier-stat"><text>👨‍👩‍👧{{renewalDossier.family.applicable===false?'N/A':''+((renewalDossier.family.completeness||0))}}</text></text>
      <text class="dossier-arrow">›</text>
    </view>

    <scroll-view scroll-y class="phase-list">
      <view wx:for="{{phases}}" wx:key="phase"
            class="phase-card {{item.unlocked===false?'locked':''}} {{item.expanded?'expanded':''}}">
        <view class="phase-header" data-phase="{{item.phase}}" bindtap="onPhaseTap">
          <view class="phase-left">
            <text class="phase-icon">{{item.unlocked===false?'🔒':(item.requiredCompleted>=item.totalRequired?'✅':'●')}}</text>
            <view class="phase-info">
              <text class="phase-name">关卡{{item.phase}}: {{item.name}}</text>
              <text class="phase-progress">{{item.requiredCompleted}}/{{item.totalRequired}} 必修</text>
            </view>
          </view>
          <text wx:if="{{item.unlocked!==false}}" class="phase-toggle">{{item.expanded?'▲':'▼'}}</text>
        </view>

        <view wx:if="{{item.unlocked!==false && item.expanded}}" class="task-list">
          <!-- 找房向导入口 — 关卡3内部，始终可进入 -->
          <view wx:if="{{item.phase===3}}" class="housing-banner" bindtap="onHousingBannerTap">
            <text>🏠 不确定住哪个区？先做找房向导（30秒）</text>
          </view>
          <!-- 校网向导入口 — 关卡5内部 -->
          <view wx:if="{{item.phase===5}}" class="housing-banner school-net-banner" bindtap="onSchoolNetBannerTap">
            <text>📚 不知道选哪个校网？先做校网速查（30秒）</text>
          </view>
          <block wx:for="{{tasks}}" wx:key="_id" wx:for-item="task">
            <view wx:if="{{task.phase===item.phase}}" class="task-card {{task._completed?(task._materialCollected?'done-full':'done-steps'):(task._skipped?'skipped':'')}}">
              <view wx:if="{{!task._expanded}}" class="task-collapsed" data-id="{{task._id}}" catchtap="onTaskExpand">
                <view class="task-status">
                  <text wx:if="{{task._completed && task._materialCollected}}">✓✓</text>
                  <text wx:elif="{{task._completed}}">✓</text>
                  <text wx:elif="{{task._skipped}}">⊘</text>
                  <text wx:else>○</text>
                </view>
                <view class="task-body">
                  <text class="task-title">{{task.title}}</text>
                  <text class="task-subtitle">{{task.subtitle}}</text>
                </view>
                <view class="task-meta">
                  <text class="task-urgency urgency-{{task._urgencyClass}}">{{task.urgency}}</text>
                  <text class="task-time">{{task.time_estimate}}</text>
                </view>
              </view>

              <view wx:if="{{task._expanded}}" class="task-expanded">
                <view class="expanded-header" data-id="{{task._id}}" catchtap="onTaskExpand">
                  <text class="expanded-title">{{task.title}}</text>
                  <text class="expand-close">收起 ▲</text>
                </view>
                <view class="steps-list">
                  <view wx:for="{{task.steps}}" wx:key="seq" wx:for-item="step" class="step-item">
                    <view class="step-check {{task['_step'+step.seq]?'checked':''}}"
                          data-task-id="{{task._id}}" data-step="{{step.seq}}" catchtap="onStepCheck">
                      <text>{{task['_step'+step.seq]?'✓':'○'}}</text>
                    </view>
                    <view class="step-info">
                      <text class="step-title">{{step.title}}</text>
                      <view class="step-content">{{step.content}}</view>
                    </view>
                  </view>
                </view>
                <view wx:if="{{task.renewal_evidence && task.renewal_evidence.produces && !task._materialCollected}}"
                      class="material-prompt" data-id="{{task._id}}" catchtap="onMaterialPrompt">
                  <text>📎 收集: {{task.renewal_evidence.doc_type}}</text>
                </view>
              </view>
            </view>
          </block>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- Tab 1: 场景速查 — PRD v6.2 §4.3: 结构化卡片+搜索+加入指南 -->
  <view wx:elif="{{activeTab===1}}" class="tab-content">
    <view class="browse-search-bar">
      <input class="browse-search-input" placeholder="🔍 搜索攻略..." value="{{browseKeyword}}" bindinput="onBrowseSearch" confirm-type="search"/>
    </view>
    <scroll-view scroll-x class="category-scroll">
      <view wx:for="{{['全部','银行','通讯','交通','住房','医疗','教育','税务','证件','运动','搬家','保险','社区']}}"
            wx:key="*this" class="category-tag {{activeCategory===item?'active':''}}"
            data-category="{{item}}" bindtap="onCategoryTap"><text>{{item}}</text></view>
    </scroll-view>
    <scroll-view scroll-y class="browse-list">
      <view wx:for="{{browseTasks}}" wx:key="_id" class="browse-card">
        <view class="browse-card-main" bindtap="onBrowseTaskTap" data-id="{{item._id}}">
          <view class="browse-card-left">
            <text class="browse-title">{{item.title}}</text>
            <text class="browse-sub">{{item.subtitle}}</text>
          </view>
          <view class="browse-card-right">
            <text class="tag-sm urgency-{{item._urgencyClass}}">{{item.urgency}}</text>
            <text class="tag-sm">{{item.time_estimate}}</text>
            <text wx:if="{{item._completed && item._materialCollected}}" class="browse-done-icon">✓✓</text>
            <text wx:elif="{{item._completed}}" class="browse-warn-icon">⚠️</text>
            <text wx:else class="browse-expand-icon">{{expandedBrowseTaskId===item._id?'▲':'▼'}}</text>
          </view>
        </view>
        <!-- 结构化详情面板 -->
        <view wx:if="{{expandedBrowseTaskId===item._id}}" class="browse-detail">
          <!-- 步骤 -->
          <view wx:if="{{item.steps && item.steps.length}}" class="browse-section">
            <text class="browse-section-title">📋 步骤指引</text>
            <view wx:for="{{item.steps}}" wx:key="seq" wx:for-item="step" class="browse-step">
              <text class="browse-step-num">{{step.seq}}.</text>
              <view class="browse-step-body">
                <text class="browse-step-title">{{step.title}}</text>
                <view class="browse-step-content">{{step.content}}</view>
              </view>
            </view>
          </view>
          <!-- 材料 -->
          <view wx:if="{{item.required_items && item.required_items.length}}" class="browse-section">
            <text class="browse-section-title">📎 所需材料</text>
            <view wx:for="{{item.required_items}}" wx:key="*this" wx:for-item="mat" class="browse-item-row">
              <view>• {{mat}}</view>
            </view>
          </view>
          <!-- 贴士 -->
          <view wx:if="{{item.tips && item.tips.length}}" class="browse-section">
            <text class="browse-section-title">💡 小贴士</text>
            <view wx:for="{{item.tips}}" wx:key="*this" wx:for-item="tip" class="browse-item-row">
              <view>💡 {{tip}}</view>
            </view>
          </view>
          <!-- 坑点 -->
          <view wx:if="{{item.pitfalls && item.pitfalls.length}}" class="browse-section">
            <text class="browse-section-title">⚠️ 常见坑点</text>
            <view wx:for="{{item.pitfalls}}" wx:key="*this" wx:for-item="pit" class="browse-item-row">
              <view>⚠️ {{pit}}</view>
            </view>
          </view>
          <!-- 链接 -->
          <view wx:if="{{item.official_links && item.official_links.length}}" class="browse-section">
            <text class="browse-section-title">🔗 参考链接</text>
            <view wx:for="{{item.official_links}}" wx:key="label" wx:for-item="link" class="browse-item-row">
              <view>• {{link.label}}</view>
            </view>
          </view>
          <!-- 操作按钮 -->
          <view class="browse-actions">
            <view wx:if="{{item._completed}}" class="browse-done-tag">
              <text>{{item._materialCollected?'✓✓ 已完成(含材料)':'✓ 步骤已完成'}}</text>
            </view>
            <view wx:else class="browse-detail-btn" bindtap="onBrowseViewDetail" data-id="{{item._id}}">
              <text>了解详情 →</text>
            </view>
          </view>
        </view>
      </view>
      <view wx:if="{{browseTasks.length===0 && !loading}}" class="empty-hint">
        <text>{{browseKeyword?'未找到匹配的攻略':'选择分类标签开始浏览'}}</text>
      </view>
    </scroll-view>
  </view>

  <!-- Tab 2: 我的进度 -->
  <view wx:elif="{{activeTab===2}}" class="tab-content">
    <scroll-view scroll-y class="progress-scroll">
      <view class="stats-panel">
        <text class="stats-title">📊 通关进度</text>
        <view class="phase-bars">
          <view wx:for="{{phases}}" wx:key="phase" class="phase-row">
            <text class="phase-row-name">{{item.phase}}. {{item.name}}</text>
            <view class="phase-bar-bg"><view class="phase-bar-fill" style="width:{{item.totalRequired?(item.requiredCompleted/item.totalRequired*100):0}}%"></view></view>
            <text class="phase-row-num">{{item.requiredCompleted}}/{{item.totalRequired}}</text>
          </view>
        </view>
      </view>

      <view class="dossier-panel" wx:if="{{renewalDossier}}">
        <view class="dossier-header">
          <text class="dossier-title">📋 续签档案</text>
          <text class="dossier-btn" bindtap="onExportDossier">📄 导出</text>
        </view>
        <block wx:for="{{['address','employment','family','visa']}}" wx:key="*this" wx:for-item="cat">
          <view class="dossier-section" wx:if="{{renewalDossier[cat]}}">
            <text class="dossier-cat">
              <text wx:if="{{cat==='address'}}">🏠 居住证明</text>
              <text wx:elif="{{cat==='employment'}}">💼 工作证明</text>
              <text wx:elif="{{cat==='family'}}">👨‍👩‍👧 家庭证明</text>
              <text wx:else>📄 签证记录</text>
              <text wx:if="{{renewalDossier[cat].applicable===false}}"> (N/A)</text>
            </text>
            <view wx:if="{{renewalDossier[cat].items}}" class="dossier-items">
              <view wx:for="{{renewalDossier[cat].items}}" wx:key="taskId" wx:for-item="ditem" class="dossier-item">
                <text>✅ {{ditem.docType||ditem.doc_type||'材料'}}</text>
              </view>
            </view>
            <text wx:else class="dossier-empty">暂无材料</text>
          </view>
        </block>
      </view>
    </scroll-view>
  </view>

  <!-- Tab 3: 攻略精选 -->
  <view wx:elif="{{activeTab===3}}" class="tab-content">
    <scroll-view scroll-x class="category-scroll">
      <view wx:for="{{['全部','优才','高才通','IANG','专才','生活','税务','教育']}}"
            wx:key="*this" class="category-tag {{articleCategory===item?'active':''}}"
            data-category="{{item}}" bindtap="onArticleCategory"><text>{{item}}</text></view>
    </scroll-view>
    <view wx:if="{{articleLoading}}" class="loading-wrap">
      <view class="skeleton-line" wx:for="{{[1,2,3,4,5]}}" wx:key="*this"></view>
    </view>
    <view wx:else>
      <scroll-view scroll-y class="article-list">
        <view wx:for="{{articles}}" wx:key="id" class="article-card" bindtap="onArticleTap" data-id="{{item.id}}">
          <image wx:if="{{item.cover}}" src="{{item.cover}}" class="article-cover" mode="aspectFill"/>
          <view class="article-info">
            <text class="article-title">{{item.title}}</text>
            <text class="article-summary">{{item.summary || item.excerpt}}</text>
            <text class="article-date">{{item.publishDate || item.date}}</text>
          </view>
        </view>
        <view wx:if="{{articles.length===0}}" class="empty-hint">
          <text>暂无攻略文章</text>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 路径设置弹窗(首次使用) -->
  <view wx:if="{{showPathSetup}}" class="overlay">
    <view class="setup-dialog">
      <text class="setup-title">🏁 定制你的通关路线</text>

      <!-- Step 0: Visa type -->
      <view wx:if="{{setupStep===0}}" class="setup-step">
        <text class="setup-q">Q1: 你的签证类型？</text>
        <view wx:for="{{[{v:'qmas',l:'优才'},{v:'ttps-a',l:'高才通A类'},{v:'ttps-bc',l:'高才通BC类'},{v:'asmpt',l:'专才'},{v:'iang',l:'IANG/学生'},{v:'dependent',l:'受养人'}]}}" wx:key="v"
              class="setup-option {{setupData.visaType===item.v?'selected':''}}" data-value="{{item.v}}" bindtap="onSetupNext">
          <text>{{setupData.visaType===item.v?'☑️ ':''}}{{item.l}}</text>
        </view>
      </view>

      <!-- Step 1: Family -->
      <view wx:if="{{setupStep===1}}" class="setup-step">
        <text class="setup-q">Q2: 你的家庭状态？</text>
        <view wx:for="{{[{v:'single',l:'单身'},{v:'couple',l:'情侣'},{v:'preschool',l:'带娃(学龄前)'},{v:'school-age',l:'带娃(中小学)'},{v:'teen',l:'带娃(中学以上)'}]}}" wx:key="v"
              class="setup-option {{setupData.familyStatus===item.v?'selected':''}}" data-value="{{item.v}}" bindtap="onSetupNext">
          <text>{{setupData.familyStatus===item.v?'☑️ ':''}}{{item.l}}</text>
        </view>
        <view class="setup-back" bindtap="onSetupBack"><text>← 返回上一步</text></view>
      </view>

      <!-- Step 2: Arrival -->
      <view wx:if="{{setupStep===2}}" class="setup-step">
        <text class="setup-q">Q3: 你目前的状态？</text>
        <view wx:for="{{[{v:'pre-arrival',l:'还未抵港'},{v:'fresh',l:'刚抵港(1周内)'},{v:'delayed',l:'已抵港一段时间'}]}}" wx:key="v"
              class="setup-option {{setupData.arrivalScenario===item.v?'selected':''}}" data-value="{{item.v}}" bindtap="onSetupNext">
          <text>{{setupData.arrivalScenario===item.v?'☑️ ':''}}{{item.l}}</text>
        </view>
        <view class="setup-back" bindtap="onSetupBack"><text>← 返回上一步</text></view>
      </view>

      <!-- Step 3: Housing intent -->
      <view wx:if="{{setupStep===3}}" class="setup-step">
        <text class="setup-q">Q4: 你打算租房还是买房？</text>
        <view wx:for="{{[{v:'rent',l:'租房'},{v:'buy',l:'买房'},{v:'undecided',l:'还没想好'}]}}" wx:key="v"
              class="setup-option {{setupData.housingIntent===item.v?'selected':''}}" data-value="{{item.v}}" bindtap="onSetupNext">
          <text>{{setupData.housingIntent===item.v?'☑️ ':''}}{{item.l}}</text>
        </view>
        <view class="setup-back" bindtap="onSetupBack"><text>← 返回上一步</text></view>
      </view>

      <!-- Step 4: Existing assets + Confirm -->
      <view wx:if="{{setupStep===4}}" class="setup-step">
        <text class="setup-q">Q5: 你已经有？(可多选，没有就跳过)</text>
        <view wx:for="{{assetOptions}}" wx:key="v"
              class="setup-option setup-check {{selectedAssets[item.v]?'selected':''}}"
              data-value="{{item.v}}" bindtap="onSetupAssetToggle">
          <text>{{selectedAssets[item.v]?'☑':'☐'}} {{item.l}}</text>
        </view>
        <view class="setup-back" bindtap="onSetupBack"><text>← 返回上一步</text></view>
        <view class="btn-primary setup-confirm" bindtap="onSetupConfirm">
          <text>开始通关之旅 →</text>
        </view>
      </view>

      <!-- Quick start (always visible at bottom) -->
      <view wx:if="{{setupStep===0}}" class="setup-quick">
        <text class="setup-quick-text" bindtap="onSetupQuick">跳过定制，快速开始 →</text>
      </view>
    </view>
  </view>

  <!-- 里程碑弹窗 -->
  <view wx:if="{{showMilestone}}" class="milestone-overlay">
    <view class="milestone-card">
      <text class="milestone-icon">🎉</text>
      <text class="milestone-text">{{milestoneMsg}}</text>
      <text class="milestone-sub">续签材料 {{progress?progress.renewalDossier.address.items.length||0:0}} 份已收集</text>
    </view>
  </view>

  <!-- 找房向导入口 (关卡3) -->
  <view wx:if="{{showHousingWizard}}" class="overlay">
    <view class="wizard-dialog">
      <text class="wizard-title">🏠 找房向导</text>
      <view wx:if="{{wizardStep===0}}">
        <text class="wizard-q">每月租房预算？</text>
        <view wx:for="{{[{v:'b1',l:'$10,000-15,000'},{v:'b2',l:'$15,000-25,000'},{v:'b3',l:'$25,000-40,000'},{v:'b4',l:'$40,000-60,000'},{v:'b5',l:'$60,000+'}]}}" wx:key="v"
              class="wizard-opt" data-value="{{item.v}}" bindtap="onWizardNext">{{item.l}}</view>
      </view>
      <view wx:if="{{wizardStep===1}}">
        <text class="wizard-q">主要工作/上学在哪一区？</text>
        <view wx:for="{{[{v:'hong-kong-island',l:'港岛'},{v:'kowloon',l:'九龙'},{v:'new-territories',l:'新界'},{v:'remote',l:'远程/不固定'}]}}" wx:key="v"
              class="wizard-opt" data-value="{{item.v}}" bindtap="onWizardNext">{{item.l}}</view>
      </view>
      <!-- 区域下钻：具体片区 -->
      <view wx:if="{{wizardStep===2}}">
        <text class="wizard-q">具体哪个片区？</text>
        <view wx:for="{{wizardSubRegions}}" wx:key="v"
              class="wizard-opt" data-value="{{item.v}}" bindtap="onWizardNext">{{item.l}}</view>
      </view>
      <view wx:if="{{wizardStep===3}}">
        <text class="wizard-q">有学龄孩子？</text>
        <view class="wizard-opt" data-value="yes" bindtap="onWizardNext">有</view>
        <view class="wizard-opt" data-value="no" bindtap="onWizardNext">无</view>
      </view>
      <view wx:if="{{wizardStep===4}}">
        <text class="wizard-q">推荐区域 Top {{wizardResults.length}}</text>
        <scroll-view scroll-y class="wizard-results">
          <view wx:for="{{wizardResults}}" wx:key="district" class="wizard-result-card">
            <text class="result-name">{{item.district}}</text>
            <text class="result-stat">呎租: HK${{item.avgRentPsf}}/ft² · {{item.vibe}}</text>
            <text class="result-stat">通勤: {{item._commuteLabel}}</text>
            <text wx:if="{{item._hasSchoolNet}}" class="result-stat">校网: {{item.schoolNet.primary}} · 家庭友好: {{item.stars}}</text>
          </view>
        </scroll-view>
        <view wx:if="{{wizardResults.length===0}}" class="wizard-empty">
          <text>没有匹配的区域，请调整筛选条件</text>
        </view>
        <view class="wizard-done" bindtap="onWizardDone">完成向导 ✓</view>
      </view>
      <view wx:if="{{wizardStep<4}}" class="wizard-close" bindtap="onWizardClose">跳过</view>
    </view>
  </view>

  <!-- 校网向导 -->
  <view wx:if="{{showSchoolNetWizard}}" class="overlay">
    <view class="wizard-dialog">
      <text class="wizard-title">📚 校网速查</text>
      <view wx:if="{{snWizardStep===0}}">
        <text class="wizard-q">孩子就读阶段？</text>
        <view wx:for="{{[{v:'幼儿园',l:'幼儿园'},{v:'小学',l:'小学'},{v:'中学',l:'中学'}]}}" wx:key="v"
              class="wizard-opt" data-value="{{item.v}}" bindtap="onSNWizardNext">{{item.l}}</view>
      </view>
      <view wx:if="{{snWizardStep===1}}">
        <text class="wizard-q">偏好地区？</text>
        <view wx:for="{{[{v:'港岛',l:'港岛'},{v:'九龙',l:'九龙'},{v:'新界',l:'新界'},{v:'all',l:'不限'}]}}" wx:key="v"
              class="wizard-opt" data-value="{{item.v}}" bindtap="onSNWizardNext">{{item.l}}</view>
      </view>
      <view wx:if="{{snWizardStep===2}}">
        <text class="wizard-q">房租预算水平？</text>
        <view wx:for="{{[{v:'高',l:'高预算（$40K+）'},{v:'中',l:'中预算（$25-40K）'},{v:'低',l:'低预算（<$25K）'}]}}" wx:key="v"
              class="wizard-opt" data-value="{{item.v}}" bindtap="onSNWizardNext">{{item.l}}</view>
      </view>
      <view wx:if="{{snWizardStep===3}}">
        <text class="wizard-q">推荐校网 Top {{snWizardResults.length}}</text>
        <scroll-view scroll-y class="wizard-results">
          <view wx:for="{{snWizardResults}}" wx:key="net" class="wizard-result-card">
            <text class="result-name">{{item.name}}（校网{{item.net}}）</text>
            <text class="result-stat">{{item.tier}} · {{item.vibe}}</text>
            <text class="result-stat">代表性学校: {{item.schools}}</text>
            <text class="result-stat">预算: {{item.budgetHint}} · 家庭友好: {{item.stars}}</text>
          </view>
        </scroll-view>
        <view wx:if="{{snWizardResults.length===0}}" class="wizard-empty">
          <text>没有匹配的校网，请调整筛选条件</text>
        </view>
        <view class="wizard-done" bindtap="onSNWizardDone">完成 ✓</view>
        <view class="wizard-school-link" bindtap="onSNOpenSchools">📋 查看该区域全部学校 →</view>
      </view>
      <view wx:if="{{snWizardStep<3}}" class="wizard-close" bindtap="onSNWizardClose">跳过</view>
    </view>
  </view>

  <!-- 任务详情全屏弹窗 (Tab 1 "了解详情") -->
  <view wx:if="{{showTaskDetail}}" class="overlay task-detail-overlay">
    <view class="task-detail-sheet">
      <view class="task-detail-header">
        <text class="task-detail-title">{{taskDetail.title}}</text>
        <view class="task-detail-meta">
          <text class="tag-sm urgency-{{taskDetail._urgencyClass}}">{{taskDetail.urgency}}</text>
          <text class="tag-sm">{{taskDetail.time_estimate}}</text>
        </view>
        <view class="task-detail-close" bindtap="onTaskDetailClose"><text>✕</text></view>
      </view>
      <scroll-view scroll-y class="task-detail-body">
        <!-- 概览 -->
        <view wx:if="{{taskDetail.subtitle}}" class="td-section">
          <view class="td-text">{{taskDetail.subtitle}}</view>
        </view>
        <!-- 步骤 -->
        <view wx:if="{{taskDetail.steps && taskDetail.steps.length}}" class="td-section">
          <text class="td-section-title">📋 步骤指引</text>
          <view wx:for="{{taskDetail.steps}}" wx:key="seq" wx:for-item="step" class="td-step">
            <text class="td-step-num">{{step.seq}}</text>
            <view class="td-step-body">
              <text class="td-step-title">{{step.title}}</text>
              <view class="td-step-content">{{step.content}}</view>
            </view>
          </view>
        </view>
        <!-- 材料 -->
        <view wx:if="{{taskDetail.required_items && taskDetail.required_items.length}}" class="td-section">
          <text class="td-section-title">📎 所需材料</text>
          <view wx:for="{{taskDetail.required_items}}" wx:key="*this" wx:for-item="mat" class="td-item">
            <view>• {{mat}}</view>
          </view>
        </view>
        <!-- 贴士 -->
        <view wx:if="{{taskDetail.tips && taskDetail.tips.length}}" class="td-section">
          <text class="td-section-title">💡 小贴士</text>
          <view wx:for="{{taskDetail.tips}}" wx:key="*this" wx:for-item="tip" class="td-item">
            <view>💡 {{tip}}</view>
          </view>
        </view>
        <!-- 坑点 -->
        <view wx:if="{{taskDetail.pitfalls && taskDetail.pitfalls.length}}" class="td-section">
          <text class="td-section-title">⚠️ 常见坑点</text>
          <view wx:for="{{taskDetail.pitfalls}}" wx:key="*this" wx:for-item="pit" class="td-item">
            <view>⚠️ {{pit}}</view>
          </view>
        </view>
        <!-- 链接 -->
        <view wx:if="{{taskDetail.official_links && taskDetail.official_links.length}}" class="td-section">
          <text class="td-section-title">🔗 参考链接</text>
          <view wx:for="{{taskDetail.official_links}}" wx:key="label" wx:for-item="link" class="td-item">
            <view>• {{link.label}}: {{link.url}}</view>
          </view>
        </view>
        <!-- 续签提示 -->
        <view wx:if="{{taskDetail.renewal_evidence && taskDetail.renewal_evidence.produces}}" class="td-section td-renewal-hint">
          <text class="td-section-title">📋 续签材料</text>
          <view class="td-text">完成此任务后记得收集: {{taskDetail.renewal_evidence.doc_type}}</view>
        </view>
      </scroll-view>
      <view class="task-detail-footer">
        <view wx:if="{{taskDetail._completed}}" class="browse-done-tag">
          <text>{{taskDetail._materialCollected?'✓✓ 已完成(含材料)':'✓ 步骤已完成'}}</text>
        </view>
        <view wx:else class="browse-add-btn" bindtap="onBrowseAddToGuide" data-id="{{taskDetail._id}}">
          <text>+ 加入我的生活指南</text>
        </view>
      </view>
    </view>
  </view>
</view>
