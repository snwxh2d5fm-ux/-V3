/* 攻略书 v7 — 港漂通关手册 (DSG-3 令牌迁移) */

/* ===== Tab Bar ===== */
.tab-bar {
  display: flex;
  background: var(--white);
  border-bottom: 1rpx solid var(--gray-200);
  position: sticky;
  top: 0;
  z-index: var(--z-sticky);
}
.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0 16rpx;
  font-size: var(--font-md);
  color: var(--gray-400);
  position: relative;
  transition: color var(--duration-fast) var(--easing);
}
.tab-item.active {
  color: var(--blue);
  font-weight: 600;
}
.tab-indicator {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: var(--blue);
  border-radius: 3rpx;
}

/* ===== Loading & Error ===== */
.loading-wrap { padding: 40rpx; }
.error-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 60rpx;
}
.error-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.error-text { font-size: var(--font-md); color: var(--gray-400); margin-bottom: 32rpx; }
.btn-retry {
  padding: 16rpx 48rpx;
  background: var(--blue);
  color: var(--white);
  border-radius: 40rpx;
  font-size: var(--font-md);
  font-weight: 600;
}

/* ===== Dossier Bar (Tab 0 top) ===== */
.dossier-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 32rpx;
  background: linear-gradient(135deg, var(--blue-light), #e0ecff);
  margin: 16rpx;
  border-radius: var(--radius);
  transition: transform var(--duration-fast);
}
.dossier-bar:active { transform: scale(0.98); }
.dossier-label {
  font-size: var(--font-sm);
  font-weight: 600;
  color: var(--blue);
  margin-right: 24rpx;
}
.dossier-stat { font-size: var(--font-xs); color: var(--gray-500); margin-right: 16rpx; }
.dossier-arrow { font-size: 32rpx; color: var(--gray-400); margin-left: auto; }

/* ===== Phase List ===== */
.phase-list { height: calc(100vh - 200rpx); padding: 0 16rpx; }
.phase-card {
  margin-bottom: 12rpx;
  background: var(--white);
  border-radius: var(--radius);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  transition: opacity var(--duration-fast);
}
.phase-card.locked { opacity: 0.5; }
.phase-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  transition: background var(--duration-fast);
}
.phase-header:active { background: var(--gray-50); }
.phase-left { display: flex; align-items: center; gap: 16rpx; }
.phase-icon { font-size: 36rpx; }
.phase-name { font-size: var(--font-md); font-weight: 600; color: var(--color-text); }
.phase-progress { font-size: var(--font-xs); color: var(--gray-400); }
.phase-toggle { font-size: var(--font-xs); color: var(--gray-300); }

/* ===== Task Cards ===== */
.task-list { border-top: 1rpx solid var(--gray-100); }
.task-card { border-bottom: 1rpx solid var(--gray-50); }
.task-card.done-full { background: var(--color-success-bg); }
.task-card.done-steps { background: var(--color-warning-bg); }
.task-card.skipped { opacity: 0.4; }
.task-collapsed {
  display: flex;
  align-items: center;
  padding: 20rpx 28rpx;
  gap: 16rpx;
  transition: background var(--duration-fast);
}
.task-collapsed:active { background: var(--gray-50); }
.task-status { font-size: 34rpx; color: var(--blue); width: 50rpx; text-align: center; }
.task-body { flex: 1; overflow: hidden; }
.task-title {
  font-size: var(--font-md);
  color: var(--gray-700);
  display: block;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.task-subtitle {
  font-size: var(--font-xs);
  color: var(--gray-400);
  display: block;
  margin-top: 4rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.task-meta { display: flex; flex-direction: column; align-items: flex-end; gap: 4rpx; }
.task-urgency { font-size: 20rpx; padding: 2rpx 10rpx; border-radius: 8rpx; }
.urgency-required { background: var(--color-error-bg); color: var(--color-error); }
.urgency-suggest { background: var(--color-warning-bg); color: var(--color-warning); }
.urgency-optional { background: var(--gray-100); color: var(--gray-500); }
.task-time { font-size: var(--font-xs); color: var(--gray-300); }

/* ===== Task Expanded ===== */
.task-expanded { padding: 0 28rpx 20rpx; }
.expanded-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0 16rpx;
  border-bottom: 1rpx solid var(--gray-100);
}
.expanded-title { font-size: var(--font-md); font-weight: 600; color: var(--color-text); }
.expand-close { font-size: var(--font-xs); color: var(--blue); }
.steps-list { padding: 16rpx 0; }
.step-item { display: flex; align-items: flex-start; padding: 12rpx 0; gap: 16rpx; }
.step-check {
  width: 44rpx;
  height: 44rpx;
  border: 2rpx solid var(--gray-300);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-xs);
  color: var(--gray-300);
  flex-shrink: 0;
  margin-top: 2rpx;
  transition: all var(--duration-fast) var(--easing);
}
.step-check.checked {
  background: var(--blue);
  border-color: var(--blue);
  color: var(--white);
}
.step-info { flex: 1; }
.step-title { font-size: var(--font-sm); font-weight: 500; color: var(--gray-600); display: block; }
.step-content {
  font-size: var(--font-xs);
  color: var(--gray-500);
  display: block;
  margin-top: 4rpx;
  line-height: 1.6;
}
.material-prompt {
  margin-top: 16rpx;
  padding: 16rpx 20rpx;
  background: var(--color-warning-bg);
  border-radius: 12rpx;
  font-size: var(--font-sm);
  color: var(--color-warning);
  text-align: center;
  transition: background var(--duration-fast);
}
.material-prompt:active { background: #fff3cd; }

/* ===== Tab 1: Browse / 场景速查 ===== */
.category-scroll { white-space: nowrap; padding: 16rpx; }
.category-tag {
  display: inline-block;
  padding: 10rpx 24rpx;
  margin-right: 12rpx;
  background: var(--gray-100);
  border-radius: 32rpx;
  font-size: var(--font-sm);
  color: var(--gray-600);
  transition: all var(--duration-fast);
}
.category-tag.active {
  background: var(--blue);
  color: var(--white);
  font-weight: 600;
}
.browse-list { height: calc(100vh - 200rpx); padding: 0 16rpx; }
.browse-card {
  padding: 24rpx;
  margin-bottom: 12rpx;
  background: var(--white);
  border-radius: 12rpx;
  box-shadow: var(--shadow-sm);
  transition: transform var(--duration-fast);
}
.browse-card:active { transform: scale(0.98); }
.browse-title { font-size: var(--font-md); font-weight: 600; color: var(--color-text); display: block; }
.browse-sub { font-size: var(--font-xs); color: var(--gray-400); display: block; margin: 6rpx 0; }
.browse-meta { display: flex; gap: 12rpx; margin-top: 8rpx; }
.tag-sm {
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  background: var(--gray-50);
  border-radius: 6rpx;
  color: var(--gray-500);
}
.tag-sm.scene {
  background: var(--blue-light);
  color: var(--blue);
}

/* ===== Tab 2: Progress / 我的进度 ===== */
.progress-scroll { height: calc(100vh - 140rpx); padding: 16rpx; }
.stats-panel {
  background: var(--white);
  border-radius: var(--radius);
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-sm);
}
.stats-title {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--color-text);
  display: block;
  margin-bottom: 20rpx;
}
.phase-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  gap: 12rpx;
}
.phase-row-name { width: 160rpx; font-size: var(--font-xs); color: var(--gray-500); }
.phase-bar-bg {
  flex: 1;
  height: 12rpx;
  background: var(--gray-100);
  border-radius: 6rpx;
  overflow: hidden;
}
.phase-bar-fill {
  height: 100%;
  background: var(--gradient-hero);
  border-radius: 6rpx;
  transition: width var(--duration-slow) var(--easing);
}
.phase-row-num { width: 60rpx; font-size: var(--font-xs); color: var(--gray-400); text-align: right; }

.dossier-panel {
  background: var(--white);
  border-radius: var(--radius);
  padding: 28rpx;
  box-shadow: var(--shadow-sm);
}
.dossier-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.dossier-title { font-size: var(--font-lg); font-weight: 700; color: var(--color-text); }
.dossier-btn {
  font-size: var(--font-sm);
  color: var(--blue);
  padding: 8rpx 20rpx;
  border: 1rpx solid var(--blue);
  border-radius: 24rpx;
}
.dossier-section {
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--gray-100);
}
.dossier-cat {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--gray-600);
  display: block;
  margin-bottom: 10rpx;
}
.dossier-item { padding: 8rpx 0; font-size: var(--font-sm); color: var(--gray-600); }
.dossier-empty { font-size: var(--font-xs); color: var(--gray-300); padding: 8rpx 0; }

.empty-hint { padding: 80rpx 0; text-align: center; font-size: var(--font-md); color: var(--gray-300); }

/* ===== Path Setup Overlay / 路径设置弹窗 ===== */
.overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: var(--z-overlay);
}
.setup-dialog {
  width: 640rpx;
  background: var(--white);
  border-radius: var(--radius-lg);
  padding: 48rpx 40rpx;
  animation: fadeIn var(--duration-slow) var(--easing);
}
.setup-title {
  font-size: var(--font-xl);
  font-weight: 700;
  display: block;
  text-align: center;
  color: var(--color-text);
}
.setup-desc {
  font-size: var(--font-sm);
  color: var(--gray-400);
  display: block;
  text-align: center;
  margin: 12rpx 0 32rpx;
}
.setup-todo {
  font-size: var(--font-sm);
  color: var(--color-warning);
  display: block;
  text-align: center;
  padding: 32rpx 0;
}
.btn-primary {
  display: block;
  padding: 24rpx;
  background: var(--blue);
  color: var(--white);
  text-align: center;
  border-radius: 12rpx;
  font-size: var(--font-md);
  font-weight: 600;
  transition: opacity var(--duration-fast);
}
.btn-primary:active { opacity: 0.85; }

/* ===== Milestone Overlay ===== */
.milestone-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: var(--z-overlay);
  pointer-events: none;
}
.milestone-card {
  background: rgba(0,0,0,0.85);
  border-radius: var(--radius-lg);
  padding: 48rpx 56rpx;
  text-align: center;
  animation: milestoneIn var(--duration-slow) var(--easing);
}
@keyframes milestoneIn {
  from { transform: scale(0.8); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}
.milestone-icon { font-size: 80rpx; display: block; margin-bottom: 16rpx; }
.milestone-text { font-size: var(--font-lg); color: var(--white); font-weight: 600; }
.milestone-sub { font-size: var(--font-xs); color: rgba(255,255,255,0.6); margin-top: 8rpx; display: block; }

/* ===== Path Setup Steps / 路径设置步骤 ===== */
.setup-step { padding: 8rpx 0; }
.setup-q {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--color-text);
  display: block;
  margin-bottom: 24rpx;
}
.setup-option {
  padding: 24rpx 20rpx;
  margin-bottom: 12rpx;
  background: var(--gray-50);
  border-radius: 12rpx;
  font-size: var(--font-md);
  color: var(--gray-600);
  text-align: center;
  border: 2rpx solid transparent;
  transition: all var(--duration-fast) var(--easing);
}
.setup-option:active {
  background: var(--blue-light);
  border-color: var(--blue);
}
.setup-option.selected {
  background: var(--blue-light);
  border-color: var(--blue);
  color: var(--blue);
  font-weight: 600;
}
.setup-check { display: flex; align-items: center; gap: 12rpx; }
.setup-back {
  padding: 16rpx 0;
  text-align: center;
  font-size: var(--font-sm);
  color: var(--gray-400);
}
.setup-confirm { margin-top: 16rpx; }
.setup-quick {
  padding: 28rpx 0 0;
  text-align: center;
  border-top: 1rpx solid var(--gray-100);
  margin-top: 24rpx;
}
.setup-quick-text { font-size: var(--font-md); color: var(--blue); }

/* ===== Housing Wizard / 找房向导 ===== */
.housing-banner {
  margin: 16rpx;
  padding: 20rpx 28rpx;
  background: var(--gradient-warm);
  border-radius: var(--radius);
  font-size: var(--font-md);
  color: var(--color-warning);
  text-align: center;
  transition: transform var(--duration-fast);
}
.housing-banner:active { transform: scale(0.98); }
.wizard-dialog {
  width: 640rpx;
  max-height: 80vh;
  background: var(--white);
  border-radius: var(--radius-lg);
  padding: 40rpx;
  overflow-y: auto;
}
.wizard-title {
  font-size: var(--font-lg);
  font-weight: 700;
  text-align: center;
  display: block;
  margin-bottom: 24rpx;
  color: var(--color-text);
}
.wizard-q {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--gray-700);
  display: block;
  margin-bottom: 20rpx;
}
.wizard-opt {
  padding: 24rpx 20rpx;
  margin-bottom: 12rpx;
  background: var(--gray-50);
  border-radius: 12rpx;
  font-size: var(--font-md);
  text-align: center;
  border: 2rpx solid transparent;
  transition: all var(--duration-fast) var(--easing);
}
.wizard-opt:active {
  background: var(--blue-light);
  border-color: var(--blue);
}
.wizard-results { max-height: 500rpx; margin: 16rpx 0; }
.wizard-result-card {
  padding: 20rpx;
  margin-bottom: 12rpx;
  background: var(--gray-50);
  border-radius: 12rpx;
}
.result-name { font-size: var(--font-md); font-weight: 600; display: block; }
.result-stat { font-size: var(--font-xs); color: var(--gray-600); display: block; margin-top: 4rpx; }
.wizard-done {
  margin-top: 20rpx;
  padding: 20rpx;
  background: var(--blue);
  color: var(--white);
  text-align: center;
  border-radius: 12rpx;
  font-size: var(--font-md);
  font-weight: 600;
}
.wizard-close { padding: 20rpx 0 0; text-align: center; font-size: var(--font-sm); color: var(--gray-400); }
.wizard-empty { padding: 32rpx; text-align: center; font-size: var(--font-sm); color: var(--gray-400); }

/* ===== Tab 3: Articles / 攻略精选 ===== */
.article-list { height: calc(100vh - 200rpx); padding: 0 16rpx; }
.article-card {
  display: flex;
  padding: 24rpx;
  margin-bottom: 16rpx;
  background: var(--white);
  border-radius: var(--radius);
  box-shadow: var(--shadow-sm);
  transition: transform var(--duration-fast);
}
.article-card:active { transform: scale(0.98); }
.article-cover {
  width: 160rpx;
  height: 120rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  margin-right: 20rpx;
  background: var(--gray-100);
}
.article-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  overflow: hidden;
}
.article-title {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--gray-700);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.article-summary {
  font-size: var(--font-xs);
  color: var(--gray-400);
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
.article-date { font-size: var(--font-xs); color: var(--gray-300); }
