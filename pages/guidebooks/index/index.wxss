/* 住港伴 v4.2 — 攻略书主页样式 */

/* ===== 搜索栏增强 ===== */
.search-bar.focused {
  border: 2rpx solid var(--blue);
  background: var(--white);
  box-shadow: 0 0 0 4rpx var(--blue-light);
}
.search-clear {
  font-size: var(--font-sm);
  color: var(--gray-400);
  padding: 4rpx 12rpx;
  flex-shrink: 0;
}

/* ===== 热门标签 ===== */
.hot-tags {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
  padding: 8rpx 24rpx;
  margin-bottom: 4rpx;
}
.hot-tag-label { font-size: var(--font-xs); color: var(--gray-500); font-weight: 600; }
.hot-tag { font-size: var(--font-xs); color: var(--blue); background: var(--blue-light); padding: 6rpx 16rpx; border-radius: 20rpx; font-weight: 500; }
.hot-tag:active { opacity: 0.7; }

/* ===== 分类横向滚动 ===== */
.category-scroll { white-space: nowrap; padding: 16rpx 0; }
.category-list { display: inline-flex; gap: 12rpx; padding: 0 24rpx; }
.cat-item { display: inline-flex; align-items: center; gap: 6rpx; padding: 14rpx 20rpx; border-radius: 24rpx; background: var(--white); box-shadow: var(--shadow-sm); font-size: var(--font-sm); flex-shrink: 0; transition: all 0.2s; }
.cat-item.active { background: var(--blue); color: var(--white); box-shadow: var(--shadow-md); }
.cat-icon { font-size: 24rpx; }
.cat-label { font-weight: 600; }
.cat-count { font-size: var(--font-xs); opacity: 0.6; margin-left: 2rpx; }
.cat-item.active .cat-count { opacity: 0.8; }

/* ===== 排序栏 ===== */
.sort-bar { display: flex; align-items: center; justify-content: space-between; padding: 12rpx 28rpx; }
.sort-label { font-size: var(--font-xs); color: var(--gray-500); }
.sort-options { display: flex; gap: 20rpx; }
.sort-option { font-size: var(--font-xs); color: var(--gray-400); font-weight: 500; }
.sort-option.active { color: var(--blue); font-weight: 700; }

/* ===== 加载状态 ===== */
.loading-state { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 120rpx 40rpx; }
.loading-icon { font-size: 72rpx; }
.loading-text { font-size: var(--font-sm); color: var(--gray-400); margin-top: 16rpx; }

/* ===== 攻略卡片流 ===== */
.guide-flow { padding-bottom: 20rpx; }
.guide-card { position: relative; background: var(--white); border-radius: var(--radius); margin: 12rpx 24rpx; box-shadow: var(--shadow-sm); overflow: hidden; transition: transform 0.15s; }
.guide-card:active { transform: scale(0.98); }

/* 置信度角标 */
.confidence-badge { position: absolute; top: 16rpx; right: 16rpx; font-size: var(--font-xs); font-weight: 700; padding: 4rpx 12rpx; border-radius: 10rpx; z-index: 1; }
.confidence-badge.A { background: var(--green-light); color: var(--green); }
.confidence-badge.B { background: var(--blue-light); color: var(--blue); }
.confidence-badge.C { background: var(--orange-light); color: var(--orange); }

/* 卡片主体 */
.guide-card-body { display: flex; gap: 16rpx; padding: 28rpx 28rpx 12rpx; }
.guide-card-icon { font-size: 48rpx; flex-shrink: 0; margin-top: 4rpx; }
.guide-card-info { flex: 1; min-width: 0; }
.guide-card-title { font-size: var(--font-md); font-weight: 700; color: var(--color-text); display: block; margin-bottom: 6rpx; line-height: 1.4; }
.guide-card-desc { font-size: var(--font-xs); color: var(--color-text-secondary); display: block; line-height: 1.5; margin-bottom: 8rpx; }
.guide-card-meta { display: flex; gap: 16rpx; margin-bottom: 8rpx; }
.guide-card-source { font-size: var(--font-xs); color: var(--gray-400); }
.guide-card-updated { font-size: var(--font-xs); color: var(--gray-400); }

/* 标签 */
.guide-card-tags { display: flex; flex-wrap: wrap; gap: 8rpx; }
.guide-tag { font-size: 20rpx; color: var(--blue); background: var(--blue-light); padding: 2rpx 12rpx; border-radius: 10rpx; font-weight: 500; }

/* 卡片底部 */
.guide-card-footer { display: flex; align-items: center; justify-content: space-between; padding: 12rpx 28rpx 20rpx; border-top: 1rpx solid var(--gray-100); }
.guide-rating { display: flex; align-items: center; gap: 6rpx; }
.rating-stars { font-size: var(--font-xs); color: var(--orange); font-weight: 600; }
.guide-actions { display: flex; align-items: center; gap: 16rpx; }
.guide-helpful { font-size: var(--font-xs); color: var(--gray-400); }
.guide-arrow { font-size: var(--font-lg); color: var(--gray-300); font-weight: 300; }

/* ===== 页脚 ===== */
.guide-footer { text-align: center; padding: 40rpx 28rpx 20rpx; }
.guide-footer-text { display: block; font-size: var(--font-xs); color: var(--gray-400); margin-bottom: 8rpx; }
.guide-footer-hint { display: block; font-size: 20rpx; color: var(--gray-400); opacity: 0.7; }

/* ===== v4.3 新增: 身份状态横幅 ===== */
.status-banner { display: flex; align-items: center; justify-content: space-between; margin: 0 24rpx 12rpx; padding: 16rpx 20rpx; background: linear-gradient(135deg, var(--blue-light), #E8F0FE); border-radius: var(--radius); border-left: 6rpx solid var(--blue); }
.status-banner-wrap { display: flex; align-items: center; gap: 12rpx; }
.status-banner-icon { font-size: 32rpx; }
.status-banner-label { font-size: var(--font-sm); font-weight: 700; color: var(--blue); display: block; }
.status-banner-hint { font-size: 20rpx; color: var(--gray-500); display: block; margin-top: 2rpx; }
.status-banner-source { display: flex; align-items: center; gap: 6rpx; font-size: 20rpx; color: var(--green); font-weight: 500; }
.source-dot { width: 10rpx; height: 10rpx; border-radius: 50%; background: var(--green); }

/* ===== v4.3 新增: 推荐区 ===== */
.recommended-section { margin-bottom: 8rpx; }
.section-header { display: flex; align-items: baseline; gap: 12rpx; padding: 0 28rpx 12rpx; }
.section-title { font-size: var(--font-md); font-weight: 700; color: var(--color-text); }
.section-reason { font-size: var(--font-xs); color: var(--gray-400); }
.recommended-cards { padding: 0 24rpx; }
.section-divider { height: 1rpx; background: var(--gray-100); margin: 16rpx 24rpx 4rpx; }
