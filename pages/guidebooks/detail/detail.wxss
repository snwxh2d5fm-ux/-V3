/* 住港伴 v4.5 — 攻略详情页精美样式 */

/* ===== 基础 ===== */
.container { background: #F0F2F5; min-height: 100vh; }
.loading-state { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 200rpx 40rpx; }
.loading-icon { font-size: 72rpx; }
.loading-text { font-size: 28rpx; color: #9CA3AF; margin-top: 16rpx; }
.empty-state { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 200rpx 40rpx; text-align: center; }
.empty-icon { font-size: 72rpx; margin-bottom: 16rpx; }
.empty-text { font-size: 28rpx; color: #6B7280; margin-bottom: 24rpx; }

/* ===== 英雄卡片 ===== */
.hero-card { background: #fff; margin: 20rpx 24rpx; border-radius: 20rpx; padding: 28rpx; box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04); }
.hero-top { display: flex; gap: 16rpx; }
.hero-icon { font-size: 52rpx; flex-shrink: 0; margin-top: 4rpx; }
.hero-info { flex: 1; min-width: 0; }
.hero-title { font-size: 34rpx; font-weight: 800; color: #1F2937; display: block; line-height: 1.35; margin-bottom: 6rpx; }
.hero-desc { font-size: 26rpx; color: #6B7280; display: block; line-height: 1.5; margin-bottom: 10rpx; }
.hero-meta { display: flex; align-items: center; flex-wrap: wrap; gap: 12rpx; }
.hero-meta-item { font-size: 22rpx; color: #9CA3AF; }
.confidence-tag-mini { font-size: 20rpx; font-weight: 700; padding: 2rpx 10rpx; border-radius: 8rpx; }
.hero-tags { display: flex; flex-wrap: wrap; gap: 8rpx; margin-top: 14rpx; padding-top: 14rpx; border-top: 1rpx solid #F3F4F6; }
.hero-tag { font-size: 22rpx; color: #2563EB; background: #EFF6FF; padding: 4rpx 14rpx; border-radius: 20rpx; font-weight: 600; }
.hero-context { margin-top: 14rpx; padding-top: 12rpx; border-top: 1rpx solid #F3F4F6; }
.ctx-item { display: flex; gap: 8rpx; padding: 6rpx 0; align-items: flex-start; }
.ctx-icon { font-size: 22rpx; flex-shrink: 0; margin-top: 2rpx; }
.ctx-text { font-size: 24rpx; color: #6B7280; line-height: 1.6; flex: 1; }
.ctx-text.legal { font-family: monospace; color: #92400E; font-size: 22rpx; }
.ctx-legal { border-top: 1rpx dashed #E5E7EB; padding-top: 8rpx; margin-top: 4rpx; }

/* ===== 置信度横幅 ===== */
.banner-d { display: flex; gap: 10rpx; margin: 0 24rpx 16rpx; padding: 14rpx 20rpx; background: #FEF2F2; border-radius: 14rpx; border: 1rpx solid #FECACA; }
.banner-e { display: flex; gap: 10rpx; margin: 0 24rpx 16rpx; padding: 14rpx 20rpx; background: #F3F4F6; border-radius: 14rpx; border: 1rpx solid #D1D5DB; }
.banner-icon { font-size: 24rpx; flex-shrink: 0; margin-top: 2rpx; }
.banner-text { font-size: 24rpx; color: #991B1B; line-height: 1.5; }
.banner-e .banner-text { color: #6B7280; }

/* ===== 通用分区栏 ===== */
.section-bar { display: flex; align-items: center; gap: 12rpx; padding: 24rpx 28rpx 10rpx; }
.bar-accent { width: 6rpx; height: 28rpx; border-radius: 3rpx; background: #2563EB; flex-shrink: 0; }
.bar-accent.accent-green { background: #059669; }
.bar-accent.accent-orange { background: #EA580C; }
.bar-accent.accent-purple { background: #7C3AED; }
.bar-title { font-size: 30rpx; font-weight: 700; color: #1F2937; }

/* ===== FAQ 卡片 ===== */
.card { background: #fff; margin: 12rpx 24rpx; border-radius: 20rpx; overflow: hidden; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03); }
.faq-q { display: flex; gap: 14rpx; padding: 24rpx 24rpx 14rpx; border-bottom: 1rpx solid #F3F4F6; }
.faq-badge { width: 40rpx; height: 40rpx; line-height: 40rpx; text-align: center; border-radius: 12rpx; font-size: 26rpx; font-weight: 800; color: #fff; flex-shrink: 0; }
.faq-badge.q { background: #2563EB; }
.faq-badge.a { background: #059669; }
.faq-q-text { font-size: 30rpx; font-weight: 700; color: #1F2937; line-height: 1.5; }
.faq-a { display: flex; gap: 14rpx; padding: 16rpx 24rpx 24rpx; }
.faq-a-text { font-size: 28rpx; color: #374151; line-height: 1.85; }

/* ===== 步骤卡片 ===== */
.steps-wrap { padding: 0 24rpx; }
.step-card { display: flex; gap: 16rpx; background: #fff; border-radius: 16rpx; padding: 22rpx 24rpx; margin-bottom: 12rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03); position: relative; }
.step-num { width: 44rpx; height: 44rpx; line-height: 44rpx; text-align: center; background: linear-gradient(135deg, #2563EB, #1D4ED8); color: #fff; border-radius: 50%; font-size: 24rpx; font-weight: 800; flex-shrink: 0; }
.step-body { flex: 1; min-width: 0; }
.step-title { font-size: 28rpx; font-weight: 700; color: #1F2937; display: block; margin-bottom: 6rpx; }
.step-desc { font-size: 26rpx; color: #4B5563; line-height: 1.7; display: block; margin-bottom: 8rpx; }
.step-tips { margin-top: 6rpx; background: #F0FDF4; border-radius: 10rpx; padding: 10rpx 14rpx; }
.step-tip { display: block; font-size: 24rpx; color: #065F46; line-height: 1.7; }
.step-time { font-size: 22rpx; color: #9CA3AF; margin-top: 8rpx; display: block; }

/* ===== 长文卡片（结构化正文） ===== */
.article-card { background: #fff; margin: 0 24rpx 12rpx; border-radius: 16rpx; padding: 24rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03); }
/* 子标题 (type: heading) */
.seg-heading { display: block; font-size: 28rpx; font-weight: 700; color: #1F2937; padding: 10rpx 0 6rpx; margin-top: 16rpx; }
.seg-heading:first-child { margin-top: 0; }
/* 编号列表 (type: numbered) */
.seg-numbered { display: flex; gap: 10rpx; padding: 6rpx 0 6rpx 4rpx; align-items: flex-start; }
.num-dot { width: 10rpx; height: 10rpx; border-radius: 50%; background: #2563EB; flex-shrink: 0; margin-top: 10rpx; }
.num-text { font-size: 26rpx; color: #374151; line-height: 1.8; flex: 1; }
/* 要点列表 (type: bullet) */
.seg-bullet { display: flex; gap: 8rpx; padding: 4rpx 0 4rpx 8rpx; align-items: flex-start; }
.bul-mark { font-size: 28rpx; color: #2563EB; font-weight: 700; flex-shrink: 0; line-height: 1.7; }
.bul-text { font-size: 26rpx; color: #4B5563; line-height: 1.7; flex: 1; }
/* 关键信息卡 */
.seg-keypoint { display: flex; gap: 10rpx; background: #FFFBEB; border-radius: 12rpx; padding: 12rpx 16rpx; margin: 8rpx 0; border-left: 4rpx solid #F59E0B; }
.kp-icon { font-size: 24rpx; flex-shrink: 0; margin-top: 2rpx; }
.kp-text { font-size: 26rpx; color: #92400E; line-height: 1.7; flex: 1; }
/* 普通段落 */
.seg-para { display: block; font-size: 26rpx; color: #4B5563; line-height: 1.95; padding: 4rpx 0; }

/* ===== 材料清单 ===== */
.materials-card { background: #fff; margin: 0 24rpx 12rpx; border-radius: 16rpx; padding: 12rpx 0; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03); }
.mat-item { display: flex; align-items: center; gap: 14rpx; padding: 12rpx 28rpx; }
.mat-check { width: 34rpx; height: 34rpx; line-height: 34rpx; text-align: center; background: #ECFDF5; border-radius: 8rpx; font-size: 20rpx; color: #059669; flex-shrink: 0; }
.mat-name { font-size: 26rpx; color: #374151; line-height: 1.5; }

/* ===== 避坑指南 ===== */
.pit-list { padding: 0 24rpx; }
.pit-item { display: flex; gap: 14rpx; padding: 14rpx 20rpx; background: #FFFBEB; border-radius: 14rpx; margin-bottom: 10rpx; border-left: 4rpx solid #F59E0B; align-items: flex-start; }
.pit-num { width: 32rpx; height: 32rpx; line-height: 32rpx; text-align: center; background: #FEF3C7; color: #D97706; border-radius: 50%; font-size: 20rpx; font-weight: 800; flex-shrink: 0; }
.pit-text { font-size: 26rpx; color: #92400E; line-height: 1.65; flex: 1; }

/* ===== 评分卡片 ===== */
.feedback-card { display: flex; align-items: center; justify-content: space-between; background: #fff; margin: 20rpx 24rpx; border-radius: 16rpx; padding: 22rpx 24rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03); }
.fb-ask { font-size: 26rpx; color: #6B7280; }
.fb-actions { display: flex; gap: 12rpx; }
.fb-btn { display: flex; align-items: center; gap: 6rpx; padding: 10rpx 22rpx; border-radius: 22rpx; font-size: 26rpx; border: 1rpx solid #D1D5DB; color: #6B7280; background: #fff; }
.fb-btn.fb-up { background: #EFF6FF; border-color: #2563EB; color: #2563EB; }
.fb-btn.fb-down { background: #FEF2F2; border-color: #FECACA; color: #DC2626; }
.fb-count { font-weight: 700; }

/* ===== 操作行 ===== */
.action-row { display: flex; gap: 16rpx; padding: 12rpx 24rpx 20rpx; }
.act-btn { flex: 1; text-align: center; padding: 14rpx 0; font-size: 26rpx; color: #2563EB; background: #EFF6FF; border-radius: 14rpx; font-weight: 600; }
.act-share { flex: 1; text-align: center; padding: 14rpx 0; font-size: 26rpx; color: #fff; background: linear-gradient(135deg, #2563EB, #1D4ED8); border-radius: 14rpx; font-weight: 600; margin: 0; line-height: 1.5; border: none; }

/* ===== 相关攻略 ===== */
.related-card { display: flex; align-items: center; gap: 14rpx; background: #fff; margin: 8rpx 24rpx; border-radius: 16rpx; padding: 18rpx 22rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03); }
.related-card:active { opacity: 0.8; }
.rel-icon { font-size: 34rpx; flex-shrink: 0; }
.rel-info { flex: 1; min-width: 0; }
.rel-title { font-size: 26rpx; font-weight: 600; color: #1F2937; display: block; margin-bottom: 4rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.rel-meta { display: flex; gap: 12rpx; }
.rel-source, .rel-rating { font-size: 22rpx; color: #9CA3AF; }
.rel-arrow { font-size: 28rpx; color: #D1D5DB; flex-shrink: 0; }

/* ===== 页尾 ===== */
.page-end { text-align: center; padding: 40rpx 28rpx 40rpx; }
.end-line { display: block; font-size: 24rpx; color: #9CA3AF; margin-bottom: 4rpx; }
.end-id { display: block; font-size: 20rpx; color: #D1D5DB; }

/* ===== 置信度弹窗 ===== */
.popup-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 999; background: rgba(0,0,0,0.45); display: flex; align-items: center; justify-content: center; }
.popup-card { background: #fff; border-radius: 24rpx; padding: 36rpx 32rpx 24rpx; margin: 48rpx; width: 560rpx; box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.15); }
.popup-title { font-size: 32rpx; font-weight: 800; color: #1F2937; display: block; margin-bottom: 24rpx; text-align: center; }
.popup-grid { margin-bottom: 20rpx; }
.pop-row { display: flex; align-items: center; gap: 12rpx; padding: 10rpx 0; }
.pop-badge { font-size: 22rpx; font-weight: 700; padding: 4rpx 12rpx; border-radius: 8rpx; white-space: nowrap; flex-shrink: 0; }
.pop-desc { font-size: 24rpx; color: #6B7280; line-height: 1.5; flex: 1; }
.pop-close { width: 100%; text-align: center; padding: 14rpx 0; font-size: 28rpx; color: #2563EB; background: #EFF6FF; border-radius: 14rpx; font-weight: 600; margin-top: 8rpx; border: none; }
