/* pages/home/home.wxss — v5令牌重构 (DSG-1 P0-03) */
.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.loading-screen {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}
.logo-text {
  font-size: 48rpx;
  font-weight: 800;
  color: var(--blue);
}
.loading-dot {
  font-size: var(--font-md);
  color: var(--gray-400);
}

/* 欢迎页 */
.welcome {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 48rpx 60rpx;
  width: 100%;
  box-sizing: border-box;
}
.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}
.app-icon { font-size: 100rpx; }
.app-name {
  font-size: 48rpx;
  font-weight: 800;
  color: var(--color-text);
  margin-top: 16rpx;
}
.tagline {
  font-size: var(--font-md);
  color: var(--gray-500);
  margin-top: 8rpx;
}

.features {
  display: flex;
  gap: 24rpx;
  margin-bottom: 60rpx;
  width: 100%;
}
.feature {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 24rpx 12rpx;
  background: var(--gray-50);
  border-radius: var(--radius-pill, 20rpx);
}
.feat-icon { font-size: 40rpx; }
.feat-title {
  font-size: var(--font-sm);
  font-weight: 600;
  color: var(--color-text);
}
.feat-desc {
  font-size: var(--font-xs);
  color: var(--gray-400);
  text-align: center;
}

.login-area {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}
.login-btn {
  width: 100%;
  background: var(--blue);
  color: var(--white);
  border-radius: var(--radius);
  font-size: var(--font-lg);
  font-weight: 600;
  padding: 28rpx;
  text-align: center;
}
.login-btn::after { border: none; }
.privacy-check {
  font-size: var(--font-xs);
  color: var(--gray-400);
  text-align: center;
  line-height: 1.4;
}
.footer-links {
  margin-top: 40rpx;
  font-size: var(--font-sm);
  color: var(--blue);
}

/* 锁定页 */
.locked-screen {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 48rpx;
  text-align: center;
}
.lock-icon { font-size: 100rpx; margin-bottom: 24rpx; }
.lock-title {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 12rpx;
}
.lock-desc {
  font-size: var(--font-md);
  color: var(--gray-500);
  margin-bottom: 40rpx;
  line-height: 1.6;
}
.upgrade-btn {
  width: 80%;
  background: var(--blue);
  color: var(--white);
  border-radius: var(--radius);
  font-size: var(--font-lg);
  padding: 24rpx;
}
.upgrade-btn::after { border: none; }
