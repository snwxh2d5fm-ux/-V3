<!-- pages/home/home.wxml - 首页引导页 -->
<view class="page">
  <!-- 加载中 -->
  <view class="loading-screen" wx:if="{{loading}}">
    <text class="logo-text">住港伴</text>
    <text class="loading-dot">加载中...</text>
  </view>

  <!-- 审核整改: 首页内容优先 — 用户首先看到功能介绍而非登录要求 -->
  <view class="welcome" wx:elif="{{unauthenticated}}">
    <view class="hero">
      <text class="app-icon">🏠</text>
      <text class="app-name">住港伴</text>
      <text class="tagline">香港身份全流程陪伴工具</text>
    </view>

    <!-- 核心功能展示 — 主体内容，无需登录即可浏览 -->
    <view class="features">
      <view class="feature">
        <text class="feat-icon">🔒</text>
        <text class="feat-title">隐私至上</text>
        <text class="feat-desc">AES-256加密 本地存储</text>
      </view>
      <view class="feature">
        <text class="feat-icon">✅</text>
        <text class="feat-title">合规准确</text>
        <text class="feat-desc">Cap.115法源 五级置信度</text>
      </view>
      <view class="feature">
        <text class="feat-icon">🚀</text>
        <text class="feat-title">好用高效</text>
        <text class="feat-desc">7大模块 12条路径</text>
      </view>
    </view>

    <!-- 主体操作: 先浏览体验 -->
    <view class="guest-area">
      <button class="guest-btn" bindtap="enterAsGuest">
        开始体验 · 无需登录
      </button>
    </view>

    <!-- 分隔 -->
    <view class="section-divider">
      <text class="divider-text">登录解锁全部功能</text>
    </view>

    <!-- 登录区 — 次要入口，用户浏览后主动选择 -->
    <!-- 审核整改: 用户必须主动勾选同意，不可默认强制同意 -->
    <view class="consent-area">
      <view class="consent-row" bindtap="toggleConsent">
        <view class="consent-checkbox {{consentChecked ? 'checked' : ''}}">
          <text wx:if="{{consentChecked}}">✓</text>
        </view>
        <text class="consent-text">
          我已阅读并同意
          <text class="consent-link" catchtap="openPrivacyPolicy">《隐私政策》</text>
          和
          <text class="consent-link" catchtap="openUserAgreement">《用户服务协议》</text>
        </text>
      </view>
    </view>

    <view class="login-area">
      <button class="login-btn {{consentChecked ? '' : 'disabled'}}" open-type="getPhoneNumber" bindgetphonenumber="handleLogin" disabled="{{!consentChecked}}">
        手机号快捷登录
      </button>
    </view>

    <view class="footer-links">
      <text bindtap="goLogin">其他方式登录</text>
    </view>
  </view>

  <!-- 已锁定 - 付费引导 -->
  <view class="locked-screen" wx:elif="{{locked}}">
    <text class="lock-icon">🔒</text>
    <text class="lock-title">试用已到期</text>
    <text class="lock-desc">免费试用期已结束，升级会员继续使用全部功能</text>
    <button class="upgrade-btn" bindtap="goPaywall">查看会员方案</button>
  </view>

  <floating-ai visible="{{true}}" />
</view>
