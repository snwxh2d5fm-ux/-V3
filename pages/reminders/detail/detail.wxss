/* 住港伴 v4.1 — 提醒详情页样式 */

.page-header { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 28rpx; }
.page-title { font-size: 34rpx; font-weight: 700; color: #111827; }
.page-back { font-size: 28rpx; color: var(--blue); }

/* 详情卡片 */
.detail-card { margin: 16rpx 24rpx; }
.detail-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 20rpx; }
.detail-title { font-size: 32rpx; font-weight: 700; color: #111827; flex: 1; }
.detail-tags { display: flex; gap: 8rpx; flex-shrink: 0; }
.detail-row { display: flex; justify-content: space-between; align-items: center; padding: 14rpx 0; border-bottom: 1rpx solid #F3F4F6; }
.detail-row:last-child { border-bottom: none; }
.detail-label { font-size: 26rpx; color: #6B7280; }
.detail-value { font-size: 26rpx; color: #111827; font-weight: 500; }
.detail-value.urgent { color: #DC2626; }

.tag { display: inline-block; padding: 4rpx 12rpx; border-radius: 8rpx; font-size: 22rpx; font-weight: 500; }
.tag-blue { background: #EFF6FF; color: #2563EB; }
.tag-purple { background: #F5F3FF; color: #7C3AED; }
.tag-gray { background: #F3F4F6; color: #6B7280; }
.tag-xs { font-size: 18rpx; padding: 2rpx 8rpx; }

/* 倒计时 */
.countdown-badge { display: inline-block; padding: 6rpx 16rpx; border-radius: 20rpx; font-size: 24rpx; font-weight: 600; }
.countdown-badge.urgent { background: #FEF2F2; color: #DC2626; }
.countdown-badge.warning { background: #FFF7ED; color: #EA580C; }
.countdown-badge.normal { background: #ECFDF5; color: #059669; }

/* 分区标题 */
.section-title { font-size: 28rpx; font-weight: 700; color: #111827; margin-bottom: 16rpx; display: block; }
.mode-desc { font-size: 26rpx; color: #6B7280; line-height: 1.6; margin-bottom: 24rpx; display: block; }

/* 关联证件 */
.linked-doc-item { display: flex; align-items: center; gap: 12rpx; padding: 16rpx 0; border-bottom: 1rpx solid #F3F4F6; }
.linked-doc-item:last-child { border-bottom: none; }
.doc-icon { font-size: 36rpx; }
.doc-name { flex: 1; font-size: 26rpx; color: #374151; }
.doc-arrow { font-size: 24rpx; color: #9CA3AF; }

/* 依赖链 */
.dep-item { display: flex; align-items: center; gap: 12rpx; padding: 12rpx 0; border-bottom: 1rpx solid #F9FAFB; }
.dep-status { font-size: 24rpx; }
.dep-name { flex: 1; font-size: 26rpx; color: #374151; }
.dep-deadline { font-size: 22rpx; color: #9CA3AF; }

/* 操作按钮行 */
.action-row { display: flex; gap: 16rpx; padding: 24rpx; }
.flex-1 { flex: 1; }
.completed-banner { display: block; text-align: center; padding: 24rpx; font-size: 28rpx; color: #059669; background: #ECFDF5; border-radius: 12rpx; margin: 0 24rpx; }

/* ===== OCR 流程示意图 ===== */
.ocr-demo-card { padding: 28rpx 24rpx 16rpx; }
.demo-flow { margin-top: 24rpx; }

.demo-step { text-align: center; margin-bottom: 0; }
.demo-step-num {
  display: inline-flex; align-items: center; justify-content: center;
  width: 44rpx; height: 44rpx; border-radius: 50%;
  background: var(--blue); color: #FFF; font-size: 24rpx; font-weight: 800;
  margin-bottom: 8rpx;
}
.demo-step-title { display: block; font-size: 26rpx; font-weight: 700; color: #111827; margin-bottom: 14rpx; }

/* 模拟证件卡片 */
.demo-doc-mock {
  margin: 0 12rpx; padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #F8FAFC, #F0F4F8);
  border: 2rpx solid #D1D5DB; border-radius: 16rpx;
  text-align: left; position: relative;
}
.demo-doc-header { border-bottom: 1rpx solid #D1D5DB; padding-bottom: 10rpx; margin-bottom: 12rpx; }
.demo-doc-title { font-size: 28rpx; font-weight: 800; color: #1A1A2E; display: block; }
.demo-doc-sub { font-size: 18rpx; color: #9CA3AF; text-transform: uppercase; letter-spacing: 2rpx; }
.demo-doc-body {}
.demo-doc-row { display: flex; align-items: center; padding: 10rpx 0; position: relative; }
.demo-doc-label { font-size: 22rpx; color: #9CA3AF; width: 100rpx; flex-shrink: 0; }
.demo-doc-val { font-size: 24rpx; color: #374151; font-weight: 500; }
.demo-doc-row--masked .demo-doc-val { color: #9CA3AF; letter-spacing: 2rpx; }

/* 高亮日期行 */
.demo-doc-row--highlight {
  background: #FEF2F2; border-radius: 10rpx;
  padding: 10rpx 12rpx; margin: 4rpx -8rpx; position: relative;
}
.demo-doc-val--date { color: #DC2626 !important; font-weight: 800 !important; font-size: 28rpx !important; letter-spacing: 1rpx; }
.demo-date-box {
  position: absolute; top: 2rpx; left: -2rpx; right: -2rpx; bottom: 2rpx;
  border: 3rpx dashed #DC2626; border-radius: 12rpx; pointer-events: none;
}
.demo-lock-badge {
  display: block; text-align: center; margin-top: 14rpx;
  font-size: 20rpx; color: #9CA3AF;
}

/* 箭头 */
.demo-arrow { text-align: center; padding: 4rpx 0; }
.demo-arrow-line { display: block; font-size: 16rpx; color: #D1D5DB; line-height: 1; }
.demo-arrow-icon { display: block; font-size: 36rpx; color: var(--blue); font-weight: 800; line-height: 1.2; }

/* AI识别盒子 */
.demo-ai-box {
  margin: 0 40rpx; padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #EFF6FF, #F5F3FF);
  border: 2rpx solid #C7D2FE; border-radius: 16rpx;
  text-align: center;
}
.demo-ai-icon { font-size: 44rpx; display: block; margin-bottom: 8rpx; }
.demo-ai-text { font-size: 24rpx; color: #374151; font-weight: 600; display: block; margin-bottom: 14rpx; }
.demo-date-tag {
  display: inline-flex; align-items: center; gap: 8rpx;
  padding: 10rpx 20rpx; background: #FFF; border-radius: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
}
.demo-date-tag-icon { font-size: 28rpx; }
.demo-date-tag-val { font-size: 28rpx; font-weight: 800; color: #DC2626; }
.demo-date-tag-label { font-size: 20rpx; color: #6B7280; }

/* 模拟提醒卡片 */
.demo-reminder-card {
  margin: 0 24rpx; padding: 20rpx 24rpx;
  background: #FFF; border: 2rpx solid #E5E7EB;
  border-radius: 16rpx; text-align: left;
}
.demo-reminder-row { display: flex; align-items: center; padding: 10rpx 0; border-bottom: 1rpx solid #F3F4F6; }
.demo-reminder-row:last-of-type { border-bottom: none; }
.demo-reminder-label { font-size: 24rpx; color: #9CA3AF; width: 90rpx; flex-shrink: 0; }
.demo-reminder-val { font-size: 24rpx; color: #374151; font-weight: 500; }
.demo-reminder-val--date { color: var(--blue); font-weight: 700; }
.demo-save-btn {
  margin-top: 16rpx; padding: 14rpx; text-align: center;
  background: var(--blue); color: #FFF; font-size: 26rpx; font-weight: 700;
  border-radius: 12rpx;
}

/* ===== OCR 模式 (实际) ===== */
.ocr-image-area { margin-bottom: 20rpx; border-radius: 16rpx; overflow: hidden; background: #F3F4F6; text-align: center; }
.ocr-preview { width: 100%; max-height: 600rpx; }
.ocr-loading { text-align: center; padding: 48rpx; font-size: 28rpx; color: #6B7280; }
.ocr-results { margin-top: 24rpx; }
.ocr-date-item { display: flex; align-items: center; gap: 14rpx; padding: 20rpx 16rpx; background: #F9FAFB; border-radius: 12rpx; margin-bottom: 12rpx; }
.ocr-date-item:active { background: #F3F4F6; }
.ocr-date-icon { font-size: 32rpx; }
.ocr-date-info { flex: 1; }
.ocr-date-value { font-size: 28rpx; font-weight: 600; color: #111827; display: block; }
.ocr-date-label { font-size: 22rpx; color: #6B7280; display: block; margin-top: 4rpx; }
.ocr-date-use { font-size: 24rpx; color: var(--blue); font-weight: 600; }
.ocr-no-result { text-align: center; padding: 32rpx; font-size: 26rpx; color: #9CA3AF; }

/* ===== 表单 ===== */
.form-input { width: 100%; padding: 20rpx 16rpx; margin-bottom: 16rpx; border: 1rpx solid #E5E7EB; border-radius: 12rpx; font-size: 28rpx; background: #FFF; box-sizing: border-box; }
.form-textarea { width: 100%; min-height: 160rpx; padding: 20rpx 16rpx; margin-bottom: 16rpx; border: 1rpx solid #E5E7EB; border-radius: 12rpx; font-size: 28rpx; background: #FFF; box-sizing: border-box; }

/* ===== 规则引擎 ===== */
.rule-list { margin-bottom: 20rpx; }
.rule-item { display: flex; align-items: center; gap: 14rpx; padding: 18rpx 16rpx; margin-bottom: 10rpx; border: 2rpx solid #E5E7EB; border-radius: 14rpx; }
.rule-item.active { border-color: var(--blue); background: #EFF6FF; }
.rule-item-icon { font-size: 32rpx; }
.rule-item-info { flex: 1; }
.rule-item-title { font-size: 28rpx; font-weight: 600; color: #111827; display: block; }
.rule-item-desc { font-size: 22rpx; color: #9CA3AF; display: block; margin-top: 4rpx; }
.rule-item-check { font-size: 28rpx; color: var(--blue); font-weight: 700; }
.empty-hint { text-align: center; padding: 40rpx; font-size: 26rpx; color: #9CA3AF; }

/* ===== 延期弹窗 ===== */
.modal-overlay { position: fixed; inset: 0; z-index: 999; background: rgba(0,0,0,0.4); display: flex; align-items: flex-end; }
.modal-sheet { width: 100%; background: #FFF; border-radius: 32rpx 32rpx 0 0; padding: 24rpx 28rpx 48rpx; }
.modal-handle { width: 60rpx; height: 6rpx; background: #D1D5DB; border-radius: 3rpx; margin: 0 auto 24rpx; }
.modal-title { font-size: 32rpx; font-weight: 700; color: #111827; text-align: center; margin-bottom: 24rpx; display: block; }
.defer-control { margin-bottom: 16rpx; }
.defer-label { font-size: 26rpx; color: #6B7280; display: block; margin-bottom: 8rpx; }
.defer-preview { display: block; text-align: center; padding: 16rpx; font-size: 26rpx; color: var(--blue); font-weight: 600; background: #EFF6FF; border-radius: 12rpx; margin-bottom: 24rpx; }
.modal-actions { display: flex; gap: 16rpx; }

/* ===== 编辑覆盖层 ===== */
.edit-overlay { position: fixed; inset: 0; z-index: 998; background: rgba(0,0,0,0.4); display: flex; align-items: center; justify-content: center; }
.edit-card { width: 640rpx; background: #FFF; border-radius: 24rpx; padding: 32rpx 28rpx; }

/* ===== 底部安全区 ===== */
.safe-bottom { height: 120rpx; }

.card { background: #FFF; border-radius: 16rpx; padding: 24rpx; margin: 16rpx 24rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }
.btn-block { display: block; width: 100%; margin-top: 16rpx; }
