<!-- 住港伴 v4.2 — 提醒器主页 (设计系统对齐) -->
<view class="reminders-page">
  <stage-indicator stages="{{stageSteps}}" progress="{{stageProgress}}" />
  <status-badge />

  <!-- Header — VI对齐蓝色渐变 -->
  <view class="page-header">
    <view class="page-header-bg"></view>
    <view class="page-header-content">
      <view class="page-header-row">
        <view class="page-header-left">
          <text class="page-header-title">提醒器</text>
          <text class="page-header-sub">关键时间不遗漏 · {{stats.active}} 项待办</text>
        </view>
        <view class="page-header-actions">
          <view class="page-header-btn" bindtap="manualGenerateTimeline" wx:if="{{hasPath}}">
            <view class="page-header-icon page-header-icon--calendar"></view>
          </view>
          <view class="page-header-btn" bindtap="navigateToList">
            <view class="page-header-icon page-header-icon--list"></view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- Stats + Filter 合并工具栏 -->
  <view class="toolbar-card">
    <view class="toolbar-stats">
      <view class="toolbar-stat {{filterStatus==='all'?'active':''}}" bindtap="onFilterStatus" data-status="all">
        <text class="toolbar-stat-num">{{stats.total}}</text>
        <text class="toolbar-stat-label">全部</text>
      </view>
      <view class="toolbar-stat {{filterStatus==='active'?'active':''}}" bindtap="onFilterStatus" data-status="active">
        <text class="toolbar-stat-num toolbar-stat-num--blue">{{stats.active}}</text>
        <text class="toolbar-stat-label">进行中</text>
      </view>
      <view class="toolbar-stat urgent" bindtap="onFilterStatus" data-status="active">
        <text class="toolbar-stat-num toolbar-stat-num--red">{{stats.urgent}}</text>
        <text class="toolbar-stat-label">紧急</text>
      </view>
      <view class="toolbar-stat {{filterStatus==='completed'?'active':''}}" bindtap="onFilterStatus" data-status="completed">
        <text class="toolbar-stat-num toolbar-stat-num--green">{{stats.completed}}</text>
        <text class="toolbar-stat-label">已完成</text>
      </view>
    </view>
    <view class="toolbar-divider"></view>
    <scroll-view class="toolbar-filters" scroll-x>
      <view class="filter-tag {{filterStatus==='all'&&filterType==='all'?'active':''}}" bindtap="onFilterType" data-type="all">全部</view>
      <view class="filter-tag {{filterType==='rule_engine'?'active':''}}" bindtap="onFilterType" data-type="rule_engine">规则引擎</view>
      <view class="filter-tag {{filterType==='ocr'?'active':''}}" bindtap="onFilterType" data-type="ocr">OCR识别</view>
      <view class="filter-tag {{filterType==='manual'?'active':''}}" bindtap="onFilterType" data-type="manual">手动添加</view>
    </scroll-view>
  </view>

  <!-- 资料准备时间轴入口 -->
  <view class="banner" wx:if="{{!hasPath || stats.total === 0}}">
    <view class="banner-body">
      <text class="banner-title">资料准备时间轴</text>
      <text class="banner-desc">基于项目管理逻辑，从今天开始推算每个准备步骤的预估完成日期</text>
    </view>
    <view class="btn banner-btn" bindtap="generatePrepTimeline">
      <text>生成时间轴</text>
    </view>
  </view>

  <!-- 提醒卡片列表 -->
  <view class="card-list" wx:if="{{stats.total > 0}}">
    <block wx:for="{{displayChainGroups}}" wx:key="chainId" wx:for-item="group">

      <!-- Chain group header -->
      <view class="chain-bar" wx:if="{{group.chainId}}" bindtap="toggleChain" data-chain-id="{{group.chainId}}">
        <view class="chain-bar-left">
          <view class="chain-chevron {{collapsedChains[group.chainId]?'collapsed':''}}"></view>
          <text class="chain-name">{{group.chainLabel}}</text>
          <text class="chain-meta">{{group.items.length}} 项</text>
        </view>
        <view class="chain-bar-right" catchtap="viewChain" data-chain-id="{{group.chainId}}">
          <view class="chain-progress">
            <view class="chain-progress-fill" style="width:{{group.progress}}%"></view>
          </view>
          <text class="chain-progress-num">{{group.progress}}%</text>
        </view>
      </view>

      <!-- Cards -->
      <block wx:if="{{!collapsedChains[group.chainId] || !group.chainId}}" wx:for="{{group.items}}" wx:key="id" wx:for-item="item">
        <view class="reminder-card {{item.priorityCls}}" bindtap="viewReminder" data-id="{{item.id}}">
          <view class="card-top">
            <view class="card-badges">
              <view class="badge badge--type">{{item.typeLabel}}</view>
              <view class="badge badge--conf {{item.confidenceColor}}" style="color:{{item.confidenceColor}}">{{item.confidenceLabel}}</view>
              <view class="badge badge--urgent" wx:if="{{item.priority === 'urgent'}}">紧急</view>
              <view class="badge badge--warn" wx:elif="{{item.priority === 'warning'}}">注意</view>
            </view>
            <text class="card-deadline">{{item.deadlineFormatted}}</text>
          </view>

          <text class="card-title">{{item.title || item.label}}</text>
          <text class="card-desc" wx:if="{{item.description}}">{{item.description}}</text>

          <view class="card-bottom">
            <view class="countdown {{item.priority}}">
              <text>{{item.countdownDisplay}}</text>
            </view>
            <view class="card-actions" catchtap="stop">
              <view class="card-btn card-btn--complete" wx:if="{{item.status !== 'completed'}}" bindtap="markComplete" data-id="{{item.id}}">完成</view>
              <view class="card-btn card-btn--done" wx:else disabled>已办</view>
              <view class="card-btn card-btn--detail" bindtap="viewReminder" data-id="{{item.id}}">详情</view>
            </view>
          </view>
        </view>
      </block>
    </block>
  </view>

  <!-- 空状态 -->
  <view class="empty-block" wx:if="{{stats.total === 0 && !loading}}">
    <view class="empty-icon">
      <view class="empty-icon-ring"></view>
      <view class="empty-icon-dot"></view>
    </view>
    <text class="empty-title">暂无提醒</text>
    <text class="empty-desc">点击下方按钮添加第一个提醒</text>
  </view>

  <!-- 免费用户提示 -->
  <view class="banner banner--upgrade" wx:if="{{!isPro && stats.active > 0}}">
    <view class="banner-body">
      <text class="banner-title">免费用户 · 基础提醒</text>
      <text class="banner-desc">{{freeLimitReached ? '已达流程线上限。' : ''}}升级专业会员解锁 100+ 规则链式提醒</text>
    </view>
    <view class="btn banner-btn banner-btn--gold" bindtap="viewPremium">
      <text>升级</text>
    </view>
  </view>

  <!-- Floating AI -->
  <floating-ai visible="{{true}}" context="{{ {page: 'reminders', pageContext: '用户在提醒器页面管理证件到期和续签日期'} }}" />

  <!-- FAB -->
  <view class="fab" bindtap="toggleAddMenu">
    <view class="fab-icon {{showAddMenu?'open':''}}"></view>
  </view>

  <!-- Add menu sheet -->
  <view class="sheet-overlay {{showAddMenu?'visible':''}}" bindtap="toggleAddMenu"></view>
  <view class="sheet {{showAddMenu?'visible':''}}">
    <view class="sheet-handle"></view>
    <text class="sheet-title">添加提醒</text>

    <view class="sheet-item" bindtap="navigateToOCR">
      <view class="sheet-item-icon sheet-item-icon--camera"></view>
      <view class="sheet-item-body">
        <text class="sheet-item-title">拍照识别日期</text>
        <text class="sheet-item-desc">拍摄证件或文件，自动识别关键日期</text>
      </view>
      <view class="sheet-item-arrow"></view>
    </view>

    <view class="sheet-item" bindtap="navigateToPaste">
      <view class="sheet-item-icon sheet-item-icon--paste"></view>
      <view class="sheet-item-body">
        <text class="sheet-item-title">粘贴文本识别</text>
        <text class="sheet-item-desc">粘贴通知或邮件内容，自动提取日期</text>
      </view>
      <view class="sheet-item-arrow"></view>
    </view>

    <view class="sheet-item" bindtap="navigateToRuleEngine">
      <view class="sheet-item-icon sheet-item-icon--engine"></view>
      <view class="sheet-item-body">
        <text class="sheet-item-title">规则引擎生成</text>
        <text class="sheet-item-desc">{{freeLimitReached ? '免费用户已达上限' : '根据流程自动生成提醒链'}}</text>
      </view>
      <view class="sheet-item-arrow"></view>
      <view class="sheet-badge" wx:if="{{!isPro}}">PRO</view>
    </view>

    <view class="sheet-item" bindtap="navigateToManual">
      <view class="sheet-item-icon sheet-item-icon--manual"></view>
      <view class="sheet-item-body">
        <text class="sheet-item-title">手动添加</text>
        <text class="sheet-item-desc">自行输入标题、截止日期和备注</text>
      </view>
      <view class="sheet-item-arrow"></view>
    </view>
  </view>

  <view class="safe-bottom"></view>
</view>
