<view class="container">
  <view class="page-header">
    <text class="page-header__title">材料预审</text>
    <text class="page-header__subtitle">完整性检查 · 本地运行</text>
  </view>
  <view class="card">
    <view class="score-circle"><text class="score-num">{{score}}%</text><text class="score-label">完整度</text></view>
  </view>
  <view class="card">
    <text class="card__title">逐项检查</text>
    <view class="checklist">
      <view class="check-row {{item.status}}" wx:for="{{items}}" wx:key="id">
        <text>{{item.status === 'ready' ? '✅' : item.status === 'missing' ? '❌' : item.status === 'expired' ? '⚠️' : '⏳'}}</text>
        <text class="check-name">{{item.name}}</text>
        <text class="check-detail" wx:if="{{item.detail}}">{{item.detail}}</text>
      </view>
    </view>
    <button class="btn btn--primary btn--block" bindtap="viewReport">查看完整报告</button>
  </view>

  <floating-ai visible="{{true}}" />
</view>
