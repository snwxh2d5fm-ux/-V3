.process-option { padding: 16rpx; border-radius: var(--radius-sm); margin-bottom: 8rpx; border: 1rpx solid var(--color-border); }
.process-option.selected { border-color: var(--color-primary); background: #F0FAF4; }
.po-name { font-size: var(--font-md); font-weight: 500; display: block; }
.po-meta { font-size: var(--font-xs); color: var(--color-text-muted); }
.confirm-btn { margin: 24rpx 32rpx; }
.precheck-intro { margin-top: 24rpx; }
.intro-title { font-size: var(--font-md); font-weight: 600; display: block; margin-bottom: 12rpx; }
.intro-text { font-size: var(--font-xs); color: var(--color-text-secondary); line-height: 1.8; white-space: pre-line; }

/* 预审进度面板 */
.progress-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5);z-index: 999; display: flex; align-items: center; justify-content: center; }
.progress-card { width: 600rpx; padding: 48rpx 40rpx; background: #FFF; border-radius: 24rpx; text-align: center; }
.progress-card__title { font-size: 32rpx; font-weight: 700; color: #1F2937; display: block; margin-bottom: 12rpx; }
.progress-card__step { font-size: 24rpx; color: var(--color-primary); font-weight: 600; display: block; margin-bottom: 8rpx; }
.progress-card__text { font-size: 26rpx; color: #6B7280; display: block; margin-bottom: 24rpx; }
.progress-bar { height: 12rpx; background: #F3F4F6; border-radius: 6rpx; margin: 0 0 12rpx; overflow: hidden; }
.progress-bar__fill { height: 100%; background: linear-gradient(90deg, var(--color-primary), #3B82F6); border-radius: 6rpx; transition: width 0.3s; }
.progress-card__estimate { font-size: 24rpx; color: #9CA3AF; display: block; margin-bottom: 16rpx; }
.progress-card__note { font-size: 20rpx; color: #D1D5DB; display: block; }
