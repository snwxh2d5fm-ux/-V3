/**
 * 住港伴 v4.1 — AI 对话页样式
 */
.chat-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--gray-100);
}

/* 顶部标题栏 */
.chat-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background: var(--color-bg-card)FFF;
  border-bottom: 1rpx solid var(--gray-200);
}

.chat-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--gray-800);
}

.chat-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.action-btn {
  font-size: 24rpx;
  color: var(--color-info);
  padding: 4rpx 12rpx;
}

.mode-badge {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background: var(--color-info-bg);
  color: var(--color-info);
}

/* 消息列表 */
.chat-messages {
  flex: 1;
  overflow-y: auto;
  padding: 16rpx 0;
}

.message-list {
  padding: 0 16rpx;
}

.message-wrapper {
  display: flex;
  margin-bottom: 24rpx;
  align-items: flex-start;
}

.message-wrapper.assistant {
  flex-direction: row;
}

.message-wrapper.user {
  flex-direction: row-reverse;
}

.avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  flex-shrink: 0;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar image {
  width: 100%;
  height: 100%;
}

.assistant-avatar {
  background: var(--color-info-bg);
  margin-right: 12rpx;
}

.user-avatar {
  background: #DBEAFE;
  margin-left: 12rpx;
  font-size: 28rpx;
}

/* 气泡 */
.bubble {
  max-width: 75%;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-all;
}

.bubble.assistant {
  background: var(--color-bg-card)FFF;
  color: var(--gray-800);
  border-top-left-radius: 4rpx;
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.05);
}

.bubble.user {
  background: var(--color-info);
  color: var(--color-bg-card)FFF;
  border-top-right-radius: 4rpx;
}

.bubble-text {
  white-space: pre-wrap;
}

/* 打字动画 */
.bubble.typing {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 20rpx 24rpx;
}

.typing-dot {
  font-size: 16rpx;
  color: var(--gray-400);
  animation: typing 1.4s infinite;
}

.typing-dot:nth-child(2) {
  animation-delay: 0.2s;
}

.typing-dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes typing {
  0%, 60%, 100% { opacity: 0.3; }
  30% { opacity: 1; }
}

/* 快捷回复 */
.quick-replies {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.quick-reply-btn {
  padding: 8rpx 20rpx;
  background: var(--color-info-bg);
  border: 1rpx solid #BFDBFE;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: var(--color-info);
  white-space: nowrap;
}

.quick-reply-btn:active {
  background: #DBEAFE;
}

/* 快捷入口栏 */
.quick-entries {
  display: flex;
  padding: 12rpx 16rpx;
  gap: 12rpx;
  background: var(--color-bg-card)FFF;
  border-top: 1rpx solid var(--gray-200);
  overflow-x: auto;
}

.quick-entry-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 18rpx;
  background: var(--gray-100);
  border-radius: 20rpx;
  font-size: 24rpx;
  color: var(--gray-600);
  white-space: nowrap;
  flex-shrink: 0;
}

.quick-entry-item:active {
  background: var(--gray-200);
}

.entry-icon {
  font-size: 24rpx;
}

/* 输入框 */
.chat-input-area {
  display: flex;
  align-items: center;
  padding: 12rpx 16rpx;
  padding-bottom: calc(12rpx + env(safe-area-inset-bottom));
  background: var(--color-bg-card)FFF;
  border-top: 1rpx solid var(--gray-200);
  gap: 12rpx;
}

.chat-input {
  flex: 1;
  height: 72rpx;
  padding: 0 20rpx;
  background: var(--gray-100);
  border-radius: 36rpx;
  font-size: 28rpx;
  color: var(--gray-800);
}

.send-btn {
  padding: 12rpx 28rpx;
  background: var(--gray-300);
  border-radius: 36rpx;
  font-size: 28rpx;
  color: var(--color-bg-card)FFF;
  flex-shrink: 0;
}

.send-btn.active {
  background: var(--color-info);
}

/* ========== V7: 安全护栏样式 ========== */

/* 永久安全提示 */
.permanent-notice {
  margin: 12rpx 16rpx;
  padding: 12rpx 16rpx;
  background: var(--color-info-bg);
  border-left: 6rpx solid var(--color-info);
  border-radius: 4rpx;
  font-size: 22rpx;
  color: var(--color-primary-dark);
  line-height: 1.5;
}

/* 安全横幅 */
.safety-banners {
  padding: 8rpx 24rpx;
}

.safety-banner {
  background: var(--color-bg-card)3CD;
  border-left: 6rpx solid #FFC107;
  padding: 12rpx 16rpx;
  margin-bottom: 8rpx;
  border-radius: 4rpx;
  font-size: 24rpx;
  color: #856404;
  line-height: 1.4;
}

/* 反馈按钮 */
.feedback-row {
  display: flex;
  gap: 16rpx;
  padding: 8rpx 0;
  opacity: 0.6;
}

.feedback-btn {
  font-size: 22rpx;
  color: #999;
}

.feedback-btn:active {
  color: #666;
}
