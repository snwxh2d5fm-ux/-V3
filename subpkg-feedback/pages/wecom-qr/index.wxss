/* 意见反馈 - 扫码咨询客服 V1.2 */
.page { min-height:100vh; background:var(--gray-100); padding-bottom:60rpx; }

.loading-box, .error-box { padding:200rpx 48rpx; text-align:center; display:flex; flex-direction:column; align-items:center; }
.loading-text { font-size:26rpx; color:#999; }
.error-icon { font-size:72rpx; margin-bottom:24rpx; }
.error-text { font-size:30rpx; font-weight:600; color:#202124; display:block; margin-bottom:8rpx; }
.error-hint { font-size:24rpx; color:#999; display:block; }

.content { padding:32rpx 24rpx; }

/* 标题 */
.header { text-align:center; padding:40rpx 0 32rpx; }
.header-title { font-size:36rpx; font-weight:700; color:#202124; display:block; }
.header-desc { font-size:26rpx; color:#999; margin-top:8rpx; display:block; }

/* 二维码 */
.qr-wrap {
  display:flex; justify-content:center; padding:32rpx;
  background:var(--white); border-radius:24rpx; margin-bottom:32rpx;
}
.qr-img { width:440rpx; height:440rpx; }

/* 步骤 */
.steps { background:var(--white); border-radius:24rpx; padding:32rpx; margin-bottom:24rpx; }
.step { display:flex; align-items:flex-start; margin-bottom:28rpx; }
.step:last-child { margin-bottom:0; }
.step-num {
  width:48rpx; height:48rpx; line-height:48rpx; border-radius:50%;
  background:var(--blue); text-align:center; flex-shrink:0; margin-top:2rpx;
  display:flex; align-items:center; justify-content:center;
}
.step-num text { color:#FFF; font-size:26rpx; font-weight:700; }
.step-text { font-size:28rpx; color:#202124; margin-left:20rpx; line-height:48rpx; flex:1; }

/* 客服信息 */
.info-note { text-align:center; padding:16rpx 0; }
.info-note text { font-size:24rpx; color:#999; }

.safe-bottom { height:60rpx; }
