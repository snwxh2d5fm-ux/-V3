/* 联系客服 — 原生客服接入 */

.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 60rpx;
}

.content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 48rpx 0;
}

.header {
  text-align: center;
  margin-bottom: 56rpx;
}

.header-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 24rpx;
}

.header-title {
  font-size: 38rpx;
  font-weight: 800;
  color: #1a1a1a;
  display: block;
  margin-bottom: 12rpx;
}

.header-desc {
  font-size: 28rpx;
  color: #888;
  display: block;
  line-height: 1.5;
}

.cs-entry {
  width: 100%;
  text-align: center;
}

.cs-btn {
  width: 100%;
  height: 100rpx;
  line-height: 100rpx;
  background: linear-gradient(135deg, #07c160, #06ad56);
  border-radius: 20rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(7, 193, 96, 0.3);
}

.cs-btn:active {
  opacity: 0.85;
}

.cs-btn-icon {
  font-size: 36rpx;
}

.cs-btn-text {
  font-size: 32rpx;
  font-weight: 700;
}

.cs-hint {
  font-size: 24rpx;
  color: #aaa;
  display: block;
  text-align: center;
}

.info-note {
  margin-top: 64rpx;
  padding: 28rpx 32rpx;
  background: #fff;
  border-radius: 16rpx;
  width: 100%;
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}

.info-line {
  font-size: 26rpx;
  color: #666;
  display: block;
  text-align: center;
  line-height: 2;
}

.safe-bottom {
  height: 48rpx;
}
