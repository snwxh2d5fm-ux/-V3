<!-- 意见反馈 - 扫码咨询客服 V1.2 -->
<view class="page">
  <view wx:if="{{isLoading}}" class="loading-box">
    <text class="loading-text">加载中...</text>
  </view>

  <view wx:elif="{{loadError}}" class="error-box">
    <text class="error-icon">😵</text>
    <text class="error-text">二维码加载失败</text>
    <text class="error-hint">请稍后重试</text>
  </view>

  <view wx:else class="content">
    <!-- 标题 -->
    <view class="header">
      <text class="header-title">扫码咨询客服</text>
      <text class="header-desc">微信扫码添加企微客服，1对1沟通</text>
    </view>

    <!-- 二维码 -->
    <view class="qr-wrap">
      <image
        class="qr-img"
        src="{{qrUrl}}"
        mode="aspectFit"
        show-menu-by-longpress="{{true}}"
        bindtap="onPreviewQR"
      />
    </view>

    <!-- 指引步骤 -->
    <view class="steps">
      <view class="step">
        <view class="step-num"><text>1</text></view>
        <text class="step-text">长按上方二维码保存至相册</text>
      </view>
      <view class="step">
        <view class="step-num"><text>2</text></view>
        <text class="step-text">打开微信扫一扫，选择相册中的二维码</text>
      </view>
      <view class="step">
        <view class="step-num"><text>3</text></view>
        <text class="step-text">添加企微后发送工单号，客服更快了解你的问题</text>
      </view>
    </view>

    <!-- 客服信息 -->
    <view class="info-note">
      <text>⏰ 工作时间：工作日 9:00-18:00</text>
    </view>
  </view>

  <view class="safe-bottom"></view>
</view>
