<!-- 添加客服微信 — 微信原生客服会话接入 -->
<view class="page">
  <view class="content">
    <view class="header">
      <text class="header-icon">💬</text>
      <text class="header-title">联系客服</text>
      <text class="header-desc">点击下方按钮，直接进入微信客服对话</text>
    </view>

    <view class="cs-entry">
      <button class="cs-btn" open-type="contact" bindcontact="onContactCallback">
        <text class="cs-btn-icon">💬</text>
        <text class="cs-btn-text">打开客服对话</text>
      </button>
      <text class="cs-hint">发送你的工单号或问题描述，客服更快了解情况</text>
    </view>

    <view class="info-note">
      <text class="info-line">⏰ 工作时间：工作日 9:00-18:00</text>
      <text class="info-line">📱 非工作时间留言，上线后会尽快回复</text>
    </view>
  </view>

  <view class="safe-bottom"></view>
</view>
