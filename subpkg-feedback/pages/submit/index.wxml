<!-- 意见反馈 - 提交页 V1 -->
<view class="page">
  <!-- 标题区 -->
  <view class="header">
    <text class="header-title">告诉我们你遇到的问题</text>
    <text class="header-desc">每条反馈我们都会认真阅读</text>
  </view>

  <!-- 类型选择 -->
  <view class="card">
    <text class="card-label">反馈类型（必选）</text>
    <view class="type-row">
      <view
        wx:for="{{types}}"
        wx:key="key"
        class="type-item {{selectedType === item.key ? 'active' : ''}}"
        data-type="{{item.key}}"
        bindtap="onTypeSelect"
      >
        <text class="type-icon">{{item.icon}}</text>
        <text class="type-label">{{item.label}}</text>
      </view>
    </view>
  </view>

  <!-- 文字输入 -->
  <view class="card">
    <text class="card-label">问题描述（必填，至少10字）</text>
    <textarea
      class="content-input"
      placeholder="{{placeholder}}"
      maxlength="500"
      value="{{content}}"
      bindinput="onContentInput"
      auto-height
    />
    <view class="count-bar">
      <text class="count-text {{contentLen > 0 && contentLen < 10 ? 'warn' : ''}}">{{contentLen}}/500</text>
      <text class="count-hint" wx:if="{{contentLen > 0 && contentLen < 10}}">至少输入10个字</text>
    </view>
  </view>

  <!-- 截图上传 -->
  <view class="card">
    <text class="card-label">截图（可选，1张）</text>
    <text class="card-note">截图用于问题定位，72小时后自动删除</text>

    <view wx:if="{{!screenshotPath}}" class="upload-btn" bindtap="onChooseImage">
      <text class="upload-icon">📷</text>
      <text class="upload-text">{{isUploading ? '上传中...' : '拍照或从相册选择'}}</text>
    </view>

    <view wx:else class="preview-box">
      <image class="preview-img" src="{{screenshotPath}}" mode="aspectFill" />
      <view class="preview-mask" bindtap="onRemoveScreenshot">
        <text class="remove-btn">✕</text>
      </view>
    </view>
  </view>

  <!-- 联系方式 + 匿名 -->
  <view class="card">
    <view class="anon-row" wx:if="{{nickname}}">
      <view class="anon-left">
        <text class="anon-label">提交身份</text>
        <text class="anon-hint">你的反馈将关联此昵称</text>
      </view>
      <text class="contact-nick">{{nickname}}</text>
    </view>
    <view class="anon-row">
      <view class="anon-left">
        <text class="anon-label">匿名提交</text>
        <text class="anon-hint">不关联你的账号身份</text>
      </view>
      <switch checked="{{isAnonymous}}" bindchange="onToggleAnonymous" color="#2563EB" />
    </view>
  </view>

  <!-- 提交按钮 -->
  <view class="submit-area">
    <button
      class="submit-btn {{canSubmit ? '' : 'disabled'}}"
      disabled="{{!canSubmit}}"
      loading="{{isSubmitting}}"
      bindtap="onSubmit"
    >
      {{isSubmitting ? '提交中...' : '提交反馈'}}
    </button>
    <view class="submit-hint" wx:if="{{!canSubmit && !isSubmitting}}">
      <text wx:if="{{!hasType}}">请先选择反馈类型</text>
      <text wx:elif="{{!hasContent}}">请输入至少10个字的问题描述</text>
    </view>
  </view>

  <!-- 底部入口 -->
  <view class="bottom-links">
    <view class="link-row" bindtap="goToList">
      <text class="link-text">📋 查看我的反馈</text>
      <text class="link-arrow">›</text>
    </view>
    <view class="link-row" bindtap="goToWeCom">
      <text class="link-text">💬 添加客服微信，1对1沟通</text>
      <text class="link-arrow">›</text>
    </view>
  </view>

  <view class="safe-bottom"></view>
</view>
